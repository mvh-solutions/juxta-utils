\tr
\tcr1 ἔχετε \tc2 vous avez
\tr
\tcr1 ἡμᾶς \tc2 nous
\tr
\tcr1 τύπον \tc2 \add comme\add* modèle.
\m
\v 18-19
\tr
\tcr1 γὰρ \tc2 Car
\tr
\tcr1 πολλοὶ περιπατοῦσιν \tc2 beaucoup marchent
\tr
\tcr1 οὓς πολλάκις \tc2 dont souvent
\tr
\tcr1 ἔλεγον ὑμῖν \tc2 je-parlais à-vous,
\tr
\tcr1 δὲ νῦν λέγω \tc2 mais \add dont\add* maintenant je-parle
\tr
\tcr1 καὶ κλαίων \tc2 aussi \add en\add* pleurant,
\tr
\tcr1 τοὺς ἐχθροὺς τοῦ σταυροῦ τοῦ Χριστοῦ \tc2 les ennemis de-la croix du Christ ;
\tr
\tcr1 ὧν τὸ τέλος \tc2 desquels la fin
\tr
\tcr1 ἀπώλεια \tc2 \add est la\add* ruine,
\tr
\tcr1 ὧν ὁ Θεὸς \tc2 desquels le dieu
\tr
\tcr1 ἡ κοιλία \tc2 \add est\add* le ventre
\tr
\tcr1 καὶ ἡ δόξα \tc2 et \add desquels\add* la gloire
\tr
\tcr1 ἐν τῇ αἰσχύνῃ αὐτῶν \tc2 \add est\add* dans la honte d'eux,
\tr
\tcr1 οἱ φρονοῦντες \tc2 eux pensant
\tr
\tcr1 τὰ ἐπίγεια \tc2 aux \add choses\add* terrestres.
\m
\v 20-21
\tr
\tcr1 γὰρ \tc2 Car
\tr
\tcr1 τὸ πολίτευμα ἡμῶν \tc2 la citoyenneté de-nous
\tr
\tcr1 ὑπάρχει \tc2 se trouve
\tr
\tcr1 ἐν οὐρανοῖς \tc2 dans \add les\add* cieux,
\tr
\tcr1 ἐξ οὗ καὶ \tc2 d' où aussi
\tr
\tcr1 ἀπεκδεχόμεθα \tc2 nous attendons avec impatience
\tr
\tcr1 Σωτῆρα \tc2 \add le\add* Sauveur,
\tr
\tcr1 Κύριον Ἰησοῦν Χριστόν \tc2 \add le\add* Seigneur Jésus Christ
\tr
\tcr1 ὃς μετασχηματίσει \tc2 qui transfigurera
\tr
\tcr1 τὸ σῶμα τῆς ταπεινώσεως ἡμῶν \tc2 le corps de-l' humiliation de-nous,
\tr
\tcr1 σύμμορφον \tc2 conforme
\tr
\tcr1 τῷ σώματι τῆς δόξης αὐτοῦ \tc2 au corps de-la gloire de-lui,
\tr
\tcr1 κατὰ τὴν ἐνέργειαν \tc2 selon la capacité
\tr
\tcr1 τοῦ αὐτὸν δύνασθαι \tc2 de lui pouvoir,
\tr
\tcr1 καὶ ὑποτάξαι αὑτῷ \tc2 et de-soumettre à-lui
\tr
\tcr1 τὰ πάντα \tc2 toutes les \add choses\add*.
\c 4
\m
\v 1
\tr
\tcr1 ὥστε \tc2 Ainsi,
\tr
\tcr1 ἀδελφοί μου \tc2 frères de-moi
\tr
\tcr1 ἀγαπητοὶ καὶ ἐπιπόθητοι \tc2 bien-aimés et désirés,
\tr
\tcr1 χαρὰ καὶ στέφανός μου \tc2 joie et couronne de-moi,
\tr
\tcr1 οὕτως στήκετε \tc2 de-cette-manière tenez-ferme
\tr
\tcr1 ἐν Κυρίῳ ἀγαπητοί \tc2 dans \add le\add* Seigneur, bien-aimés.
\m
\v 2
\tr
\tcr1 παρακαλῶ Εὐοδίαν \tc2 J'exhorte Évodie
\tr
\tcr1 καὶ παρακαλῶ Συντύχην \tc2 et j'exhorte Syntyche,
\tr
\tcr1 φρονεῖν τὸ αὐτὸ \tc2 \add à\add* penser la même \add chose\add*
\tr
\tcr1 ἐν Κυρίῳ \tc2 dans \add le\add* Seigneur.
\m
\v 3
\tr
\tcr1 ναὶ \tc2 Oui,
\tr
\tcr1 ἐρωτῶ σέ καὶ \tc2 je-demande à-toi aussi,
\tr
\tcr1 γνήσιε σύνζυγε \tc2 sincère collègue,
\tr
\tcr1 συνλαμβάνου αὐταῖς \tc2 aide elles,
\tr
\tcr1 αἵτινες συνήθλησάν μοι \tc2 elles-qui ont-combattu avec-moi
\tr
\tcr1 ἐν τῷ εὐαγγελίῳ \tc2 dans l' évangile
\tr
\tcr1 μετὰ καὶ Κλήμεντος \tc2 avec aussi Clément
\tr
\tcr1 καὶ τῶν συνεργῶν λοιπῶν μου \tc2 et les collaborateurs restants de-moi,
\tr
\tcr1 ὧν τὰ ὀνόματα \tc2 desquels les noms
\tr
\tcr1 ἐν βίβλῳ ζωῆς \tc2 \add sont\add* dans \add le\add* livre de-vie.
\m
\v 4
\tr
\tcr1 χαίρετε ἐν Κυρίῳ \tc2 Réjouissez-vous dans \add le\add* Seigneur,
\tr
\tcr1 πάντοτε \tc2 toujours,
\tr
\tcr1 ἐρῶ πάλιν \tc2 je-dirai à-nouveau,
\tr
\tcr1 χαίρετε \tc2 réjouissez-vous !
\m
\v 5
\tr
\tcr1 τὸ ἐπιεικὲς ὑμῶν \tc2 La modération de-vous
\tr
\tcr1 γνωσθήτω \tc2 qu'\add elle\add* soit connue
\tr
\tcr1 πᾶσιν ἀνθρώποις \tc2 par-tous \add les\add* hommes.
\tr
\tcr1 ὁ Κύριος \tc2 Le Seigneur
\tr
\tcr1 ἐγγύς \tc2 \add est\add* proche.
\m
\v 6
\tr
\tcr1 μεριμνᾶτε μηδὲν \tc2 Souciez-vous \add à propos\add* de-rien,
\tr
\tcr1 ἀλλ’ ἐν παντὶ \tc2 mais en tout,
\tr
\tcr1 τὰ αἰτήματα ὑμῶν \tc2 les demandes de-vous
\tr
\tcr1 γνωριζέσθω \tc2 qu'\add elles\add* soient connues
\tr
\tcr1 πρὸς τὸν Θεόν \tc2 pour Dieu,
\tr
\tcr1 τῇ προσευχῇ καὶ τῇ δεήσει \tc2 par-la prière et la supplication
\tr
\tcr1 μετὰ εὐχαριστίας \tc2 avec gratitude.
\m
\v 7
\tr
\tcr1 καὶ ἡ εἰρήνη τοῦ Θεοῦ \tc2 Et la paix de Dieu
\tr
\tcr1 ἡ ὑπερέχουσα \tc2 la \add paix\add* dépassant
\tr
\tcr1 πάντα νοῦν \tc2 toute compréhension,
\tr
\tcr1 φρουρήσει τὰς καρδίας ὑμῶν \tc2 protégera les cœurs de-vous
\tr
\tcr1 καὶ τὰ νοήματα ὑμῶν \tc2 et les pensées de-vous
\tr
\tcr1 ἐν Χριστῷ Ἰησοῦ \tc2 en Christ Jésus.
\m
\v 8
\tr
\tcr1 τὸ λοιπόν \tc2 Au reste,
