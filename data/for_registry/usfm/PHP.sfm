\c 1
\m
\v 1-2
\tr
\tcr1 Παῦλος καὶ Τιμόθεος \tc2 Paul et Timothée,
\tr
\tcr1 δοῦλοι Χριστοῦ Ἰησοῦ \tc2 serviteurs du-Christ Jésus ;
\tr
\tcr1 πᾶσιν τοῖς ἁγίοις \tc2 à-tous les saints
\tr
\tcr1 ἐν Χριστῷ Ἰησοῦ \tc2 en Christ Jésus
\tr
\tcr1 τοῖς οὖσιν \tc2 ceux étant
\tr
\tcr1 ἐν Φιλίπποις \tc2 à Philippes,
\tr
\tcr1 σὺν ἐπισκόποις καὶ διακόνοις \tc2 avec \add les\add* évêques et \add les\add* diacres :
\tr
\tcr1 χάρις καὶ εἰρήνη ὑμῖν \tc2 grâce et paix à-vous
\tr
\tcr1 ἀπὸ Θεοῦ Πατρὸς ἡμῶν \tc2 de-la-part de-Dieu \add le\add* Père de-nous
\tr
\tcr1 καὶ Κυρίου Ἰησοῦ Χριστοῦ \tc2 et du-Seigneur Jésus Christ.
\m
\v 3-7
\tr
\tcr1 εὐχαριστῶ \tc2 Je remercie
\tr
\tcr1 τῷ Θεῷ μου \tc2 le Dieu de-moi
\tr
\tcr1 ἐπὶ πάσῃ τῇ μνείᾳ \tc2 dans chaque souvenir
\tr
\tcr1 ὑμῶν \tc2 de vous,
\tr
\tcr1 ἐν πάσῃ δεήσει μου \tc2 dans chaque prière de-moi,
\tr
\tcr1 ποιούμενος τὴν δέησιν \tc2 faisant ma prière
\tr
\tcr1 πάντοτε μετὰ χαρᾶς \tc2 toujours avec joie
\tr
\tcr1 ὑπὲρ ὑμῶν πάντων \tc2 pour vous tous,
\tr
\tcr1 ἐπὶ τῇ κοινωνίᾳ ὑμῶν \tc2 à-cause-de la participation de-vous
\tr
\tcr1 εἰς τὸ εὐαγγέλιον \tc2 à \add l'avancement de\add* l'évangile,
\tr
\tcr1 ἀπὸ τῆς πρώτης ἡμέρας \tc2 depuis le premier jour
\tr
\tcr1 ἄχρι τοῦ νῦν \tc2 jusqu'à maintenant
\tr
\tcr1 πεποιθὼς \tc2 étant devenu confiant en
\tr
\tcr1 τοῦτο αὐτὸ \tc2 cette chose,
\tr
\tcr1 ὅτι \tc2 \add à savoir\add* que
\tr
\tcr1 ὁ ἐναρξάμενος \tc2 celui ayant-commencé
\tr
\tcr1 ἔργον ἀγαθὸν \tc2 une-œuvre bonne
\tr
\tcr1 ἐν ὑμῖν \tc2 en vous,
\tr
\tcr1 ἐπιτελέσει \tc2 \add la\add* complètera
\tr
\tcr1 ἄχρι ἡμέρας Χριστοῦ Ἰησοῦ \tc2 jusqu'au jour du-Christ Jésus ;
\tr
\tcr1 καθώς \tc2 ainsi
\tr
\tcr1 ἐστιν δίκαιον ἐμοὶ \tc2 il-est juste pour-moi
\tr
\tcr1 φρονεῖν τοῦτο \tc2 \add de\add* ressentir cela
\tr
\tcr1 ὑπὲρ ὑμῶν πάντων \tc2 pour vous tous
\tr
\tcr1 διὰ \tc2 à cause de
\tr
\tcr1 τὸ ἔχειν με \tc2 le fait-d'avoir quant-à-moi
\tr
\tcr1 ὑμᾶς \tc2 vous
\tr
\tcr1 ἐν τῇ καρδίᾳ \tc2 dans mon cœur
\tr
\tcr1 ὑμᾶς πάντας ὄντας \tc2 vous tous étant
\tr
\tcr1 συνκοινωνούς μου \tc2 participants-avec moi
\tr
\tcr1 τῆς χάριτος \tc2 de-la grâce
\tr
\tcr1 τε \tc2 non seulement
\tr
\tcr1 ἔν τοῖς δεσμοῖς μου \tc2 dans les chaînes de-moi,
\tr
\tcr1 καὶ \tc2 mais encore
\tr
\tcr1 ἐν τῇ ἀπολογίᾳ \tc2 dans ma défense
\tr
\tcr1 καὶ βεβαιώσει τοῦ εὐαγγελίου \tc2 et \add dans ma\add* consolidation de-l'évangile.
\m
\v 8
\tr
\tcr1 γάρ ὁ Θεός \tc2 Car Dieu
\tr
\tcr1 μάρτυς μου \tc2 \add est\add* témoin de-moi,
\tr
\tcr1 ὡς \tc2 que
\tr
\tcr1 ἐπιποθῶ \tc2 j'aime grandement
\tr
\tcr1 ὑμᾶς πάντας \tc2 vous tous
\tr
\tcr1 ἐν σπλάγχνοις \tc2 dans \add les\add* entrailles
\tr
\tcr1 Χριστοῦ Ἰησοῦ \tc2 du-Christ Jésus.
\m
\v 9-11
\tr
\tcr1 καὶ προσεύχομαι τοῦτο \tc2 Et je-prie cela,
\tr
\tcr1 ἵνα \tc2 que
\tr
\tcr1 ἡ ἀγάπη ὑμῶν \tc2 l'amour de-vous
\tr
\tcr1 περισσεύῃ \tc2 abonde
\tr
\tcr1 ἔτι μᾶλλον καὶ μᾶλλον \tc2 de plus en plus
\tr
\tcr1 ἐν ἐπιγνώσει \tc2 dans \add la\add* connaissance
\tr
\tcr1 καὶ πάσῃ αἰσθήσει \tc2 et \add dans\add* tout discernement,
\tr
\tcr1 εἰς τὸ δοκιμάζειν ὑμᾶς \tc2 pour le fait-de-distinguer quant-à-vous
\tr
\tcr1 τὰ διαφέροντα \tc2 les \add choses\add* meilleures
\tr
\tcr1 ἵνα \tc2 afin que
\tr
\tcr1 ἦτε εἰλικρινεῖς \tc2 vous-soyez purs
\tr
\tcr1 καὶ ἀπρόσκοποι \tc2 et sans-reproche
\tr
\tcr1 εἰς ἡμέραν Χριστοῦ \tc2 pour \add le\add* jour du-Christ,
\tr
\tcr1 πεπληρωμένοι \tc2 étant devenus pleins
\tr
\tcr1 καρπὸν δικαιοσύνης \tc2 \add du\add* fruit de-justice
\tr
\tcr1 τὸν \tc2 celui 
\tr
\tcr1 διὰ Ἰησοῦ Χριστοῦ \tc2 \add qui vient\add* par Jésus Christ,
\tr
\tcr1 εἰς δόξαν καὶ ἔπαινον Θεοῦ \tc2 pour \add la\add* gloire et \add la\add* louange de-Dieu.
\m
\v 12-14
\tr
\tcr1 δὲ \tc2 Maintenant,
\tr
\tcr1 ἀδελφοί \tc2 frères,
\tr
\tcr1 βούλομαι ὑμᾶς γινώσκειν \tc2 je-veux \add que\add* vous savoir,
\tr
\tcr1 ὅτι \tc2 que
\tr
\tcr1 τὰ \tc2 les \add choses\add*
\tr
\tcr1 κατ’ ἐμὲ \tc2 au-sujet-de moi,
\tr
\tcr1 ἐλήλυθεν \tc2 sont survenues
\tr
\tcr1 μᾶλλον εἰς προκοπὴν τοῦ εὐαγγελίου \tc2 plutôt pour \add le\add* progrès de-l'évangile ; 
\tr
\tcr1 ὥστε \tc2 de sorte que
\tr
\tcr1 τοὺς δεσμούς μου \tc2 les chaînes de-moi
\tr
\tcr1 ἐν Χριστῷ \tc2 en Christ
\tr
\tcr1 γενέσθαι φανεροὺς \tc2 sont-devenues manifestes
\tr
\tcr1 ἐν ὅλῳ τῷ πραιτωρίῳ \tc2 dans tout le prétoire
\tr
\tcr1 καὶ πᾶσιν τοῖς λοιποῖς \tc2 et pour-toutes les personnes-restantes ;
\tr
\tcr1 καὶ \tc2 et \add que\add*
\tr
\tcr1 τοὺς πλείονας τῶν ἀδελφῶν ἐν Κυρίῳ \tc2 la plupart des frères dans \add le\add* Seigneur
\tr
\tcr1 πεποιθότας \tc2 étant devenus confiants
\tr
\tcr1 τοῖς δεσμοῖς μου \tc2 \add grâce\add* aux chaînes de-moi
\tr
\tcr1 τολμᾶν \tc2 osent
\tr
\tcr1 περισσοτέρως \tc2 avec plus d'empressement
\tr
\tcr1 λαλεῖν τὸν λόγον ἀφόβως \tc2 annoncer la parole sans-peur.
\m
\v 15
\tr
\tcr1 καὶ τινὲς μὲν \tc2 Et plusieurs certes
\tr
\tcr1 κηρύσσουσιν τὸν Χριστὸν \tc2 proclament le Christ
\tr
\tcr1 διὰ φθόνον καὶ ἔριν \tc2 par jalousie et rivalité,
\tr
\tcr1 καὶ τινὲς δὲ \tc2 et d'autres pourtant
\tr
\tcr1 δι’ εὐδοκίαν \tc2 par bonne-intention.
\m
\v 16-17
\tr
\tcr1 οἱ μὲν \tc2 Les \add premiers\add* certes
\tr
\tcr1 ἐξ ἀγάπης \tc2 \add proclament le Christ\add* par amour
\tr
\tcr1 εἰδότες ὅτι \tc2 sachant que
\tr
\tcr1 κεῖμαι \tc2 je suis établi
\tr
\tcr1 εἰς ἀπολογίαν τοῦ εὐαγγελίου \tc2 pour \add la\add* défense de-l'évangile,
\tr
\tcr1 δὲ οἱ \tc2 mais les \add autres\add*
\tr
\tcr1 καταγγέλλουσιν τὸν Χριστὸν \tc2 proclament-ouvertement le Christ
\tr
\tcr1 ἐξ ἐριθείας \tc2 par ambition,
\tr
\tcr1 οἰόμενοι \tc2 pensant
\tr
\tcr1 οὐχ ἁγνῶς \tc2 pas purement
\tr
\tcr1 ἐγείρειν θλῖψιν \tc2 élever une-tribulation
\tr
\tcr1 τοῖς δεσμοῖς μου \tc2 dans-les chaînes de-moi.
\m
\v 18
\tr
\tcr1 τί γάρ \tc2 Quoi en-effet ?
\tr
\tcr1 πλὴν ὅτι \tc2 Seulement, que
\tr
\tcr1 παντὶ τρόπῳ \tc2 de-toute manière,
\tr
\tcr1 εἴτε προφάσει εἴτε ἀληθείᾳ \tc2 soit par-prétexte, soit par-vérité,
\tr
\tcr1 Χριστὸς καταγγέλλεται \tc2 Christ est-proclamé-ouvertement
\tr
\tcr1 καὶ ἐν τούτῳ χαίρω \tc2 et en cela je-me-réjouis,
\tr
\tcr1 ἀλλὰ καὶ \tc2 mais encore
\tr
\tcr1 χαρήσομαι \tc2 je me réjouirai.
\m
\v 19-20
\tr
\tcr1 γὰρ οἶδα ὅτι \tc2 Car je-sais que
\tr
\tcr1 τοῦτό ἀποβήσεται μοι \tc2 cela aboutira pour-moi
\tr
\tcr1 εἰς σωτηρίαν \tc2 au salut
\tr
\tcr1 διὰ τῆς δεήσεως ὑμῶν \tc2 à-travers la prière de-vous,
\tr
\tcr1 καὶ ἐπιχορηγίας \tc2 et \add à travers l'\add* assistance
\tr
\tcr1 τοῦ Πνεύματος Ἰησοῦ Χριστοῦ \tc2 de-l'Esprit de-Jésus Christ
\tr
\tcr1 κατὰ τὴν ἀποκαραδοκίαν \tc2 selon la ferme-assurance
\tr
\tcr1 καὶ ἐλπίδα μου \tc2 et \add l'\add* espoir de-moi,
\tr
\tcr1 ὅτι αἰσχυνθήσομαι ἐν οὐδενὶ \tc2 que je-n'aurai-honte de rien,
\tr
\tcr1 ἀλλ’ ἐν πάσῃ παρρησίᾳ \tc2 mais \add qu'\add* en toute assurance,
\tr
\tcr1 ὡς νῦν καὶ πάντοτε \tc2 comme maintenant aussi toujours,
\tr
\tcr1 Χριστὸς μεγαλυνθήσεται \tc2 Christ sera-glorifié
\tr
\tcr1 ἐν τῷ σώματί μου \tc2 à-travers le corps de-moi,
\tr
\tcr1 εἴτε διὰ ζωῆς \tc2 soit à-travers \add ma\add* vie
\tr
\tcr1 εἴτε διὰ θανάτου \tc2 soit à-travers \add ma\add* mort.
\m
\v 21
\tr
\tcr1 γὰρ ἐμοὶ \tc2 Car pour-moi
\tr
\tcr1 τὸ ζῆν Χριστὸς \tc2 le fait-de-vivre \add c'est\add* Christ,
\tr
\tcr1 καὶ τὸ ἀποθανεῖν κέρδος \tc2 et le fait-de-mourir \add c'est\add* un-gain.
\m
\v 22
\tr
\tcr1 δὲ \tc2 Cependant
\tr
\tcr1 εἰ \tc2 si 
\tr
\tcr1 τὸ ζῆν ἐν σαρκί \tc2 le fait-de-vivre dans la-chair,
\tr
\tcr1 τοῦτό μοι \tc2 \add alors\add* cela \add sera\add* pour-moi
\tr
\tcr1 καρπὸς ἔργου \tc2 \add du\add* fruit \add du\add* travail.
\tr
\tcr1 καὶ τί αἱρήσομαι \tc2 Et ce-que je-préfèrerai
\tr
\tcr1 οὐ γνωρίζω \tc2 je ne sais pas.
\m
\v 23-24
\tr
\tcr1 δὲ \tc2 En fait,
\tr
\tcr1 συνέχομαι ἐκ τῶν δύο \tc2 je-suis-pressé par les deux \add possibilités\add*,
\tr
\tcr1 ἔχων τὴν ἐπιθυμίαν εἰς τὸ ἀναλῦσαι \tc2 ayant le désir vers le fait-de-quitter \add cette vie\add*
\tr
\tcr1 καὶ εἶναι σὺν Χριστῷ \tc2 et d'être avec Christ,
\tr
\tcr1 γὰρ πολλῷ μᾶλλον κρεῖσσον \tc2 car \add c'est\add* de-beaucoup plus le-meilleur ;
\tr
\tcr1 δὲ τὸ ἐπιμένειν ἐν τῇ σαρκὶ \tc2 mais le fait-de-rester \add vivre\add* dans la chair
\tr
\tcr1 ἀναγκαιότερον δι’ ὑμᾶς \tc2 \add est\add* plus-nécessaire à-cause de-vous.
\m
\v 25-26
\tr
\tcr1 καὶ πεποιθὼς τοῦτο \tc2 Et confiant en-cela,
\tr
\tcr1 οἶδα ὅτι μενῶ \tc2 je-sais que je-resterai
\tr
\tcr1 καὶ παραμενῶ ὑμῖν πᾶσιν \tc2 et \add que\add* je-demeurerai pour-vous tous
\tr
\tcr1 εἰς τὴν προκοπὴν ὑμῶν \tc2 pour le progrès de-vous
\tr
\tcr1 καὶ χαρὰν τῆς πίστεως \tc2 et \add pour votre\add* joie dans-la-foi,
\tr
\tcr1 ἵνα τὸ καύχημα ὑμῶν \tc2 afin-que la glorification de-vous
\tr
\tcr1 περισσεύῃ ἐν Χριστῷ Ἰησοῦ \tc2 abonde en Christ Jésus
\tr
\tcr1 ἐν ἐμοὶ \tc2 à-travers moi,
\tr
\tcr1 διὰ τῆς ἐμῆς παρουσίας \tc2 par mon arrivée
\tr
\tcr1 πάλιν πρὸς ὑμᾶς \tc2 à-nouveau auprès-de vous.
\m
\v 27-30
\tr
\tcr1 μόνον πολιτεύεσθε \tc2 Seulement comportez-vous
\tr
\tcr1 ἀξίως \tc2 d'une manière digne
\tr
\tcr1 τοῦ εὐαγγελίου τοῦ Χριστοῦ \tc2 de-l'évangile du Christ,
\tr
\tcr1 ἵνα \tc2 afin que
\tr
\tcr1 εἴτε ἐλθὼν καὶ ἰδὼν ὑμᾶς \tc2 soit \add moi\add* venant et voyant vous,
\tr
\tcr1 εἴτε ἀπὼν \tc2 soit \add moi\add* absent,
\tr
\tcr1 ἀκούω τὰ περὶ ὑμῶν \tc2 j'entende les \add nouvelles\add* à-propos-de vous,
\tr
\tcr1 ὅτι στήκετε ἐν ἑνὶ πνεύματι \tc2 que vous-restez-fermes en un-seul esprit,
\tr
\tcr1 συναθλοῦντες μιᾷ ψυχῇ \tc2 combattant d'une-seule âme
\tr
\tcr1 τῇ πίστει τοῦ εὐαγγελίου \tc2 pour-la foi de-l'évangile ;
\tr
\tcr1 καὶ μὴ πτυρόμενοι \tc2 et n' étant-effrayés
\tr
\tcr1 ἐν μηδενὶ \tc2 en rien
\tr
\tcr1 ὑπὸ τῶν ἀντικειμένων \tc2 par les opposants,
\tr
\tcr1 ἔνδειξις ἥτις ἐστὶν αὐτοῖς \tc2 \add ce sera\add* un-signe qui est pour-eux
\tr
\tcr1 ἀπωλείας \tc2 \add un signe\add* de-ruine,
\tr
\tcr1 δὲ σωτηρίας ὑμῶν \tc2 mais \add un signe\add* du-salut de-nous,
\tr
\tcr1 καὶ τοῦτο ἀπὸ Θεοῦ \tc2 et cela de-la-part de-Dieu ;
\tr
\tcr1 ὅτι τὸ ὑπὲρ Χριστοῦ \tc2 parce-que cette \add chose\add* au-nom-de Christ
\tr
\tcr1 ἐχαρίσθη \tc2 a été accordée par grâce
\tr
\tcr1 ὑμῖν \tc2 à vous,
\tr
\tcr1 οὐ μόνον τὸ πιστεύειν εἰς αὐτὸν \tc2 non seulement le fait-de-croire en lui,
\tr
\tcr1 ἀλλὰ καὶ τὸ πάσχειν ὑπὲρ αὐτοῦ \tc2 mais encore le fait-de-souffrir pour lui,
\tr
\tcr1 ἔχοντες τὸν αὐτὸν ἀγῶνα \tc2 \add parce que vous\add* ayant le même combat,
\tr
\tcr1 οἷον εἴδετε \tc2 \add combat\add* que vous-avez-vu
\tr
\tcr1 ἐν ἐμοὶ \tc2 en moi
\tr
\tcr1 καὶ \tc2 et \add que\add*
\tr
\tcr1 ἀκούετε ἐν ἐμοί \tc2 vous-entendez en moi
\tr
\tcr1 νῦν \tc2 maintenant \add encore\add*.
\c 2
\m
\v 1-2
\tr
\tcr1 οὖν \tc2 Donc
\tr
\tcr1 εἴ τις παράκλησις ἐν Χριστῷ \tc2 s' \add il y a\add* quelque encouragement en Christ,
\tr
\tcr1 εἴ τι παραμύθιον ἀγάπης \tc2 s' \add il y a\add* quelque soulagement de-l'amour, 
\tr
\tcr1 εἴ τις κοινωνία Πνεύματος \tc2 s' \add il y a\add* quelque communion de-l'Esprit,
\tr
\tcr1 εἴ τις σπλάγχνα \tc2 s' \add il y a\add* quelque compassion
\tr
\tcr1 καὶ οἰκτιρμοί \tc2 et de-la-miséricorde,
\tr
\tcr1 πληρώσατέ τὴν χαρὰν μου \tc2 comblez la joie de-moi,
\tr
\tcr1 ἵνα φρονῆτε τὸ αὐτὸ \tc2 afin-que vous-ressentiez le même \add sentiment\add*
\tr
\tcr1 ἔχοντες τὴν αὐτὴν ἀγάπην \tc2 ayant le même amour,
\tr
\tcr1 σύνψυχοι \tc2 \add étant\add* d'une même âme,
\tr
\tcr1 φρονοῦντες τὸ ἓν \tc2 ayant un seul \add avis\add*.
\m
\v 3-4
\tr
\tcr1 μηδὲν κατ’ ἐριθείαν \tc2 \add Ne faites\add* rien par ambition,
\tr
\tcr1 μηδὲ κατὰ κενοδοξίαν \tc2 ni par vaine-gloire,
\tr
\tcr1 ἀλλὰ τῇ ταπεινοφροσύνῃ \tc2 mais par-humilité
\tr
\tcr1 ἡγούμενοι ἀλλήλους \tc2 pensant les-uns-les-autres
\tr
\tcr1 ὑπερέχοντας ἑαυτῶν \tc2 être-supérieurs à-vous-mêmes,
\tr
\tcr1 ἕκαστος \tc2 chacun \add de vous\add* 
\tr
\tcr1 μὴ σκοποῦντες \tc2 ne considérant pas
\tr
\tcr1 τὰ ἑαυτῶν \tc2 les \add intérêts\add* d'eux-mêmes,
\tr
\tcr1 ἀλλὰ \tc2 mais
\tr
\tcr1 ἕκαστοι καὶ \tc2 chacun \add de vous considérant\add* aussi
\tr
\tcr1 τὰ ἑτέρων \tc2 les \add intérêts\add* des-autres.
\m
\v 5-8
\tr
\tcr1 φρονεῖτε ἐν ὑμῖν \tc2 Pensez en vous
\tr
\tcr1 τοῦτο ὃ καὶ \tc2 cet \add état d'esprit\add* qui \add était\add* aussi
\tr
\tcr1 ἐν Χριστῷ Ἰησοῦ \tc2 en Christ Jésus ;
\tr
\tcr1 ὃς ὑπάρχων \tc2 \add Jésus\add* qui existant
\tr
\tcr1 ἐν μορφῇ Θεοῦ \tc2 en forme de-Dieu,
\tr
\tcr1 οὐχ ἡγήσατο \tc2 n'a pas considéré
\tr
\tcr1 τὸ εἶναι ἴσα Θεῷ \tc2 le fait-d'être égal à-Dieu
\tr
\tcr1 ἁρπαγμὸν \tc2 \add comme\add* un prix à arracher,
\tr
\tcr1 ἀλλὰ ἐκένωσεν \tc2 mais a-vidé
\tr
\tcr1 ἑαυτὸν \tc2 lui-même
\tr
\tcr1 λαβών μορφὴν δούλου \tc2 prenant une-forme de-serviteur,
\tr
\tcr1 γενόμενος \tc2 devenant
\tr
\tcr1 ἐν ὁμοιώματι ἀνθρώπων \tc2 dans l'apparence des-humains.
\tr
\tcr1 καὶ εὑρεθεὶς \tc2 Et ayant-été-trouvé
\tr
\tcr1 σχήματι \tc2 quant à son apparence
\tr
\tcr1 ὡς ἄνθρωπος \tc2 en-tant-qu' humain,
\tr
\tcr1 ἐταπείνωσεν ἑαυτὸν \tc2 il-a-humilié lui-même,
\tr
\tcr1 γενόμενος ὑπήκοος μέχρι θανάτου \tc2 devenant obéissant jusqu'à \add la\add* mort,
\tr
\tcr1 δὲ θανάτου σταυροῦ \tc2 même \add la\add* mort sur-la-croix.
\m
\v 9-11
\tr
\tcr1 διὸ καὶ \tc2 C'est-pourquoi aussi
\tr
\tcr1 ὁ Θεὸς ὑπερύψωσεν αὐτὸν \tc2 Dieu a-grandement-exalté lui,
\tr
\tcr1 καὶ ἐχαρίσατο \tc2 et il-a-accordé-gracieusement
\tr
\tcr1 αὐτῷ \tc2 à lui
\tr
\tcr1 τὸ ὄνομα \tc2 le nom
\tr
\tcr1 τὸ ὑπὲρ πᾶν ὄνομα \tc2 celui au-dessus-de tout nom,
\tr
\tcr1 ἵνα ἐν τῷ ὀνόματι Ἰησοῦ \tc2 afin-que dans le nom de-Jésus,
\tr
\tcr1 πᾶν γόνυ \tc2 tout genou
\tr
