\tr
\tcr1 ὅσα δίκαια \tc2 tout-ce-qui \add est\add* juste,
\tr
\tcr1 ὅσα ἁγνά \tc2 tout-ce-qui \add est\add* pur,
\tr
\tcr1 ὅσα προσφιλῆ \tc2 tout-ce-qui \add est\add* aimable,
\tr
\tcr1 ὅσα εὔφημα \tc2 tout-ce-qui \add est\add* recommandable,
\tr
\tcr1 εἴ τις ἀρετὴ \tc2 s' \add il y a\add* quelque vertu
\tr
\tcr1 καὶ εἴ τις ἔπαινος \tc2 et s' \add il y a\add* quelque louange,
\tr
\tcr1 λογίζεσθε ταῦτα \tc2 considérez ces \add choses\add*.
\m
\v 9
\tr
\tcr1 ἃ \tc2 \add Ce\add* que
