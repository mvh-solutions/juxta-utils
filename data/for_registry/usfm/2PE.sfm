\v 1-2
\tr
\tcr1 Σίμων Πέτρος \tc2 Simon Pierre,
\tr
\tcr1 δοῦλος καὶ ἀπόστολος Ἰησοῦ Χριστοῦ \tc2 esclave et apôtre de-Jésus Christ ;
\tr
\tcr1 τοῖς λαχοῦσιν πίστιν \tc2 à-ceux ayant-obtenu une-foi 
\tr
\tcr1 ἰσότιμον ἡμῖν \tc2 aussi-honorable \add que\add* nous,
\tr
\tcr1 ἐν δικαιοσύνῃ τοῦ Θεοῦ ἡμῶν \tc2 dans \add la\add* justice du Dieu de-nous
\tr
\tcr1 καὶ Σωτῆρος \tc2 et Sauveur
\tr
\tcr1 Ἰησοῦ Χριστοῦ \tc2 Jésus-Christ ;
\tr
\tcr1 χάρις καὶ εἰρήνη ὑμῖν \tc2 grâce et paix à-vous
\tr
