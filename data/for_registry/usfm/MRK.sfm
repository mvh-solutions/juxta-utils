\tr
\tcr1 πειραζόμενος \tc2 étant tenté
\tr
\tcr1 ὑπὸ τοῦ Σατανᾶ \tc2 par Satan,
\tr
\tcr1 καὶ ἦν \tc2 et il-était
\tr
\tcr1 μετὰ τῶν θηρίων \tc2 avec les bêtes-sauvages,
\tr
\tcr1 καὶ οἱ ἄγγελοι \tc2 et les anges
\tr
\tcr1 διηκόνουν αὐτῷ \tc2 servaient lui.
\m
\v 14-15
\tr
\tcr1 δὲ μετὰ \tc2 Et après
\tr
\tcr1 τὸν Ἰωάννην \tc2 \add que\add* Jean
\tr
