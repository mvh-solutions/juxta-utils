\m
\v 35
\tr
\tcr1 καὶ πρωῒ \tc2 Et tôt-le-matin
\tr
\tcr1 λείαν ἔννυχα \tc2 très nocturne,
\tr
\tcr1 ἀναστὰς \tc2 s'étant levé
\tr
