\tr
\tcr1 καὶ ἐβαπτίσθη \tc2 et il fut-baptisé
\tr
\tcr1 ὑπὸ Ἰωάννου \tc2 par Jean
\tr
\tcr1 εἰς τὸν Ἰορδάνην \tc2 dans le Jourdain.
\m
\v 10
\tr
\tcr1 καὶ εὐθὺς ἀναβαίνων \tc2 Et aussitôt se-relevant
\tr
\tcr1 ἐκ τοῦ ὕδατος \tc2 hors-de l' eau,
\tr
\tcr1 εἶδεν τοὺς οὐρανοὺς σχιζομένους \tc2 il vit les cieux se-fendant,
\tr
