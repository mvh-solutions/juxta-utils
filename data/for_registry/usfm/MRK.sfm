\tr
\tcr1 τὸν ἀδελφὸν αὐτοῦ \tc2 le frère de-lui,
\tr
\tcr1 αὐτοὺς καὶ \tc2 eux aussi
\tr
\tcr1 καταρτίζοντας τὰ δίκτυα \tc2 réparant les filets
\tr
\tcr1 ἐν τῷ πλοίῳ \tc2 dans la barque.
\m
\v 20
\tr
\tcr1 καὶ εὐθὺς \tc2 Et aussitôt
\tr
\tcr1 ἐκάλεσεν αὐτούς \tc2 il-appela eux,
\tr
\tcr1 καὶ ἀπῆλθον \tc2 et ils-partirent
\tr
\tcr1 ὀπίσω αὐτοῦ \tc2 derrière lui,
\tr
\tcr1 ἀφέντες Ζεβεδαῖον \tc2 laissant Zébédée
\tr
\tcr1 τὸν πατέρα αὐτῶν \tc2 le père d'eux
\tr
\tcr1 ἐν τῷ πλοίῳ \tc2 dans la barque
\tr
\tcr1 μετὰ τῶν μισθωτῶν \tc2 avec les employés.
\m
\v 21
\tr
\tcr1 καὶ εἰσπορεύονται \tc2 Et ils-entrent
\tr
\tcr1 εἰς Καφαρναούμ \tc2 dans Capharnaüm ;
\tr
\tcr1 καὶ εὐθέως τοῖς Σάββασιν \tc2 et aussitôt aux sabbats,
\tr
\tcr1 εἰσελθὼν \tc2 entrant
\tr
