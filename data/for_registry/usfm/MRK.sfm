\tr
\tcr1 παρ’ ἧς \tc2 de laquelle
\tr
\tcr1 ἐκβεβλήκει \tc2 il avait chassé
\tr
\tcr1 ἑπτὰ δαιμόνια \tc2 sept démons.
\m
\v 10
\tr
\tcr1 Ἐκείνη πορευθεῖσα \tc2 Celle-ci s'en-étant-allée
\tr
\tcr1 ἀπήγγειλεν \tc2 annonça
\tr
\tcr1 τοῖς γενομένοις μετ’ αὐτοῦ \tc2 à-ceux ayant-été avec lui,
\tr
\tcr1 πενθοῦσιν \tc2 étant en deuil
\tr
\tcr1 καὶ κλαίουσιν \tc2 et pleurant.
\m
\v 11
\tr
\tcr1 Κἀκεῖνοι ἀκούσαντες ὅτι \tc2 Et-ceux-là ayant-entendu que
\tr
\tcr1 ζῇ \tc2 il vit,
\tr
\tcr1 καὶ ἐθεάθη \tc2 et \add qu'\add* il-fut-vu
\tr
\tcr1 ὑπ’ αὐτῆς \tc2 par elle,
\tr
\tcr1 ἠπίστησαν \tc2 ils n'ont pas cru.
\m
\v 12
\tr
\tcr1 δὲ Μετὰ ταῦτα \tc2 Et après ces \add choses\add*-là,
\tr
\tcr1 ἐφανερώθη \tc2 il apparut
\tr
\tcr1 ἐν μορφῇ ἑτέρᾳ \tc2 dans une-forme autre
\tr
\tcr1 δυσὶν ἐξ αὐτῶν \tc2 à-deux parmi eux
\tr
\tcr1 περιπατοῦσιν \tc2 marchant
\tr
\tcr1 πορευομένοις εἰς ἀγρόν \tc2 allant dans un-champ.
\m
\v 13
\tr
\tcr1 Κἀκεῖνοι ἀπελθόντες \tc2 Et-ceux-là étant-partis
\tr
\tcr1 ἀπήγγειλαν τοῖς λοιποῖς \tc2 annoncèrent aux \add disciples\add* restants ;
\tr
\tcr1 ἐκείνοις ἐπίστευσαν \tc2 ceux-là crurent
\tr
\tcr1 οὐδὲ \tc2 nullement.
\m
\v 14
\tr
\tcr1 δὲ Ὕστερον \tc2 Mais plus-tard,
\tr
\tcr1 ἐφανερώθη \tc2 il apparut
\tr
\tcr1 τοῖς ἕνδεκα \tc2 aux onze
\tr
\tcr1 αὐτοῖς ἀνακειμένοις \tc2 eux étant-couchés-à-table,
\tr
\tcr1 καὶ ὠνείδισεν \tc2 et il-reprocha
\tr
\tcr1 τὴν ἀπιστίαν αὐτῶν \tc2 l' incrédulité d'eux
\tr
\tcr1 καὶ σκληροκαρδίαν \tc2 et \add leur\add* dureté-de-cœur 
\tr
\tcr1 ὅτι \tc2 parce que
\tr
\tcr1 οὐκ ἐπίστευσαν \tc2 ils ne crurent pas
\tr
\tcr1 τοῖς θεασαμένοις αὐτὸν \tc2 ceux ayant-vu lui
\tr
\tcr1 ἐγηγερμένον ἐκ νεκρῶν \tc2 ayant-été-relevé des morts.
\m
\v 15
\tr
\tcr1 Καὶ εἶπεν αὐτοῖς \tc2 Et il-dit à-eux :
\tr
\tcr1 Πορευθέντες \tc2 « Allant
\tr
\tcr1 εἰς τὸν κόσμον ἅπαντα \tc2 dans le monde entier,
\tr
\tcr1 κηρύξατε τὸ εὐαγγέλιον \tc2 proclamez l' évangile
\tr
\tcr1 πάσῃ τῇ κτίσει \tc2 à-toute la création.
\m
\v 16
\tr
\tcr1 Ὁ πιστεύσας \tc2 Celui ayant-cru 
\tr
\tcr1 καὶ βαπτισθεὶς \tc2 et ayant-été-baptisé
\tr
\tcr1 σωθήσεται \tc2 sera sauvé ;
\tr
\tcr1 δὲ \tc2 mais
\tr
\tcr1 ὁ ἀπιστήσας \tc2 celui n'ayant pas cru
\tr
\tcr1 κατακριθήσεται \tc2 sera jugé.
\m
\v 17-18
\tr
\tcr1 δὲ ταῦτα Σημεῖα \tc2 Et ces signes
\tr
\tcr1 παρακολουθήσει \tc2 suivront de près
\tr
\tcr1 τοῖς πιστεύσασιν \tc2 ceux ayant-cru,
\tr
\tcr1 ἐκβαλοῦσιν δαιμόνια \tc2 ils-chasseront des-démons
\tr
\tcr1 ἐν τῷ ὀνόματί μου \tc2 dans le nom de-moi ;
\tr
\tcr1 λαλήσουσιν γλώσσαις καιναῖς \tc2 ils-parleront en-des-langues nouvelles ;
\tr
\tcr1 ἀροῦσιν ὄφεις \tc2 ils-prendront des-serpents ;
\tr
\tcr1 κἂν πίωσιν \tc2 et-si ils-boivent
\tr
\tcr1 τι θανάσιμόν \tc2 une \add chose\add* mortelle,
\tr
\tcr1 οὐ μὴ βλάψῃ \tc2 elle ne fera certainement pas de mal
\tr
\tcr1 αὐτοὺς \tc2 à eux ;
\tr
\tcr1 ἐπιθήσουσιν χεῖρας \tc2 ils-imposeront \add les\add* mains
\tr
\tcr1 ἐπὶ ἀρρώστους \tc2 sur des-malades,
\tr
\tcr1 καὶ ἕξουσιν καλῶς \tc2 et ils-se-porteront bellement. »
\m
\v 19
\tr
\tcr1 μὲν Ὁ κύριος Ἰησοῦς \tc2 Le seigneur Jésus
\tr
\tcr1 ἀνελήφθη \tc2 fut enlevé
\tr
\tcr1 εἰς τὸν οὐρανόν \tc2 dans le ciel
\tr
\tcr1 μετὰ τὸ λαλῆσαι αὐτοῖς \tc2 après le \add fait de\add* parler à-eux,
\tr
\tcr1 καὶ ἐκάθισεν \tc2 et s'assit
\tr
\tcr1 ἐκ δεξιῶν τοῦ θεοῦ \tc2 aux droites de Dieu.
\m
\v 20
\tr
\tcr1 δὲ Ἐκεῖνοι ἐξελθόντες \tc2 Et ceux-là étant-partis
\tr
\tcr1 ἐκήρυξαν πανταχοῦ \tc2 prêchèrent partout,
\tr
\tcr1 τοῦ κυρίου συνεργοῦντος \tc2 le Seigneur œuvrant-avec-\add eux\add*
\tr
\tcr1 καὶ βεβαιοῦντος τὸν λόγον \tc2 et affermissant la parole
\tr
\tcr1 διὰ τῶν σημείων ἐπακολουθούντων \tc2 à-travers les signes \add les\add* accompagnant.
\tr
\tcr1 Ἀμήν \tc2  Amen.
