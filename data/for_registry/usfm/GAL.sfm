\v 8
\tr
\tcr1 ἡ πεισμονὴ \tc2 La persuasion
\tr
\tcr1 οὐκ \tc2 n' \add est\add* pas
\tr
\tcr1 ἐκ τοῦ καλοῦντος ὑμᾶς \tc2 de celui appelant vous. 
\m
\v 9
\tr
\tcr1 μικρὰ ζύμη \tc2 Peu de-levain
\tr
\tcr1 ζυμοῖ \tc2 fait lever
\tr
