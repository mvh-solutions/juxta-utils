\tr
\tcr1 ἀλλὰ δουλεύετε ἀλλήλοις \tc2 mais servez les-uns-les-autres
\tr
\tcr1 διὰ τῆς ἀγάπης \tc2 par l' amour. 
\m
\v 14
\tr
\tcr1 γὰρ πᾶς ὁ νόμος \tc2 Car toute la loi
\tr
\tcr1 πεπλήρωται \tc2 est accomplie
\tr
\tcr1 ἐν ἑνὶ λόγῳ \tc2 en une parole,
\tr
\tcr1 ἐν τῷ \tc2 dans le : 
\tr
\tcr1 ἀγαπήσεις τὸν πλησίον σου \tc2 « Tu-aimeras le prochain de-toi
\tr
\tcr1 ὡς σεαυτόν \tc2 comme toi-même. »
\m
\v 15
\tr
\tcr1 δὲ εἰ δάκνετε \tc2 Mais si vous-mordez
\tr
\tcr1 καὶ κατεσθίετε ἀλλήλους \tc2 et dévorez les-uns-les-autres,
\tr
\tcr1 βλέπετε \tc2 prenez garde
\tr
\tcr1 μὴ ἀναλωθῆτε \tc2 \add que\add* vous ne soyez pas détruits
\tr
\tcr1 ὑπ’ ἀλλήλων \tc2 les uns par les autres. 
\m
\v 16
\tr
\tcr1 δέ λέγω \tc2 Mais je-dis,
\tr
\tcr1 περιπατεῖτε Πνεύματι \tc2 marchez par-\add l'\add*-Esprit,
\tr
\tcr1 καὶ \tc2 et
\tr
\tcr1 οὐ μὴ τελέσητε \tc2 vous n'accomplirez certainement pas
\tr
\tcr1 ἐπιθυμίαν σαρκὸς \tc2 \add le\add* désir de-\add la\add*-chair. 
\m
\v 17
\tr
\tcr1 γὰρ ἡ σὰρξ ἐπιθυμεῖ \tc2 Car la chair désire
\tr
\tcr1 κατὰ τοῦ Πνεύματος \tc2 contre l' Esprit,
\tr
\tcr1 δὲ τὸ Πνεῦμα \tc2 mais l' Esprit
\tr
\tcr1 κατὰ τῆς σαρκός \tc2 contre la chair ; 
\tr
\tcr1 γὰρ ταῦτα ἀντίκειται \tc2 car ces \add choses\add* s'opposent-contre
\tr
\tcr1 ἀλλήλοις \tc2 les unes aux autres,
\tr
\tcr1 ἵνα \tc2 afin que
\tr
\tcr1 μὴ ποιῆτε \tc2 vous ne fassiez pas
\tr
\tcr1 ταῦτα \tc2 ces \add choses\add* 
\tr
\tcr1 ἐὰν ἃ θέλητε \tc2 que vous-voudriez. 
\m
\v 18
\tr
\tcr1 δὲ εἰ ἄγεσθε \tc2 Mais si vous-êtes-conduits
\tr
\tcr1 Πνεύματι \tc2 par \add l'\add* Esprit,
\tr
\tcr1 οὐκ ἐστὲ \tc2 vous n'êtes pas
\tr
\tcr1 ὑπὸ νόμον \tc2 sous \add la\add* loi. 
\m
\v 19-21
\tr
\tcr1 δέ τὰ ἔργα τῆς σαρκός \tc2 Mais les œuvres de-la chair
\tr
\tcr1 ἐστιν φανερὰ \tc2 sont manifestes,
\tr
\tcr1 ἅτινά ἐστιν \tc2 lesquelles sont : 
\tr
\tcr1 πορνεία ἀκαθαρσία \tc2 fornication, impureté, 
\tr
\tcr1 ἀσέλγεια εἰδωλολατρία \tc2 grossièreté, idolâtrie, 
\tr
\tcr1 φαρμακεία ἔχθραι \tc2 empoisonnements, inimitiés, 
\tr
\tcr1 ἔρις ζῆλοι \tc2 querelles, jalousies, 
\tr
\tcr1 θυμοί ἐριθεῖαι \tc2 désirs, luttes,
\tr
\tcr1 διχοστασίαι αἱρέσεις \tc2 discordes, sectes, 
\tr
\tcr1 φθόνοι μέθαι κῶμοι \tc2 malveillances, ivresses, plaisirs,
\tr
\tcr1 καὶ τὰ ὅμοια τούτοις \tc2 et les \add choses\add* semblables à-celles-ci ;
\tr
\tcr1 ἃ προλέγω ὑμῖν \tc2 \add ce\add* que je-dis-d'avance à-vous
\tr
\tcr1 καθὼς προεῖπον \tc2 tout-comme j'ai-dit-d'avance,
\tr
\tcr1 ὅτι οἱ πράσσοντες \tc2 parce-que les \add humains\add* pratiquant
\tr
\tcr1 τὰ τοιαῦτα \tc2 les telles \add choses\add*
\tr
\tcr1 οὐ κληρονομήσουσιν \tc2 n'hériteront pas
\tr
\tcr1 Βασιλείαν Θεοῦ \tc2 du-Royaume de-Dieu. 
\m
\v 22-23
\tr
\tcr1 δὲ ὁ καρπὸς τοῦ Πνεύματός ἐστιν \tc2 Mais le fruit de-l' Esprit est : 
\tr
\tcr1 ἀγάπη χαρά \tc2 amour, joie,
\tr
\tcr1 εἰρήνη μακροθυμία \tc2 paix, patience, 
\tr
\tcr1 χρηστότης ἀγαθωσύνη \tc2 bonté, bienveillance,
\tr
\tcr1 πίστις πραΰτης \tc2 foi, douceur,
\tr
\tcr1 ἐνκράτεια \tc2 maîtrise de soi, 
\tr
\tcr1 οὐκ ἔστιν \tc2 il n'y a pas
\tr
\tcr1 νόμος \tc2 une loi
\tr
\tcr1 κατὰ τῶν τοιούτων \tc2 contre les telles \add choses\add*. 
\m
\v 24
\tr
\tcr1 δὲ οἱ τοῦ Χριστοῦ Ἰησοῦ \tc2 Mais les \add humains\add* du Christ Jésus
\tr
\tcr1 ἐσταύρωσαν τὴν σάρκα \tc2 ont-crucifié la chair
\tr
\tcr1 σὺν τοῖς παθήμασιν \tc2 avec les passions
\tr
\tcr1 καὶ ταῖς ἐπιθυμίαις \tc2 et les désirs. 
\m
\v 25
\tr
\tcr1 εἰ ζῶμεν Πνεύματι \tc2 Si nous-vivons par-\add l'\add*-Esprit,
\tr
\tcr1 Πνεύματι καὶ στοιχῶμεν \tc2 par-\add l'\add*-Esprit aussi nous-marchons. 
\m
\v 26
\tr
\tcr1 μὴ γινώμεθα \tc2 Ne devenons pas
\tr
\tcr1 κενόδοξοι \tc2 épris de vaine gloire,
\tr
\tcr1 προκαλούμενοι ἀλλήλους \tc2 provoquant les-uns-les-autres,
\tr
\tcr1 φθονοῦντες ἀλλήλοις \tc2 jalousant les-uns-les-autres.
\c 6
\m
\v 1
\tr
\tcr1 ἀδελφοί \tc2 Frères,
\tr
\tcr1 ἐὰν καὶ ἄνθρωπος προλημφθῇ \tc2 si aussi un-homme est-avancé
\tr
\tcr1 ἔν τινι παραπτώματι \tc2 en quelque violation, 
\tr
\tcr1 ὑμεῖς οἱ πνευματικοὶ \tc2 vous, les \add croyants\add* spirituels,
\tr
\tcr1 καταρτίζετε τὸν τοιοῦτον \tc2 remets-en-ordre l' \add homme\add* tel
\tr
\tcr1 ἐν πνεύματι πραΰτητος \tc2 en un-esprit de-douceur,
\tr
\tcr1 σκοπῶν σεαυτόν \tc2 ayant-en-vue pour-toi-même
\tr
\tcr1 σὺ καὶ \tc2 \add que\add* toi aussi
\tr
\tcr1 μὴ πειρασθῇς \tc2 tu ne sois pas corrompu. 
\m
\v 2
\tr
\tcr1 βαστάζετε τὰ βάρη ἀλλήλων \tc2 Portez les fardeaux les-uns-des-autres,
\tr
\tcr1 καὶ οὕτως ἀναπληρώσετε \tc2 et ainsi vous-accomplirez
\tr
\tcr1 τὸν νόμον τοῦ Χριστοῦ \tc2 la loi du Christ. 
\m
\v 3
\tr
\tcr1 γὰρ εἰ τις \tc2 Car si quelqu'un 
\tr
\tcr1 δοκεῖ εἶναί τι \tc2 pense être quelque \add chose\add*,
\tr
\tcr1 μηδὲν ὤν \tc2 n'étant rien, 
\tr
\tcr1 φρεναπατᾷ ἑαυτόν \tc2 il-a-séduit lui-même. 
\m
\v 4-5
\tr
\tcr1 δὲ ἕκαστος δοκιμαζέτω \tc2 Mais \add que\add* chacun éprouve
\tr
\tcr1 τὸ ἔργον ἑαυτοῦ \tc2 l' œuvre de-lui-même,
\tr
\tcr1 καὶ μόνον τότε ἕξει \tc2 et seulement alors il-aura
\tr
\tcr1 τὸ καύχημα \tc2 la vantardise
\tr
\tcr1 εἰς ἑαυτὸν \tc2 en lui-même
\tr
\tcr1 καὶ οὐκ εἰς τὸν ἕτερον \tc2 et non dans l' autre,
\tr
\tcr1 γὰρ ἕκαστος βαστάσει \tc2 car chacun porte
\tr
\tcr1 τὸ ἴδιον φορτίον \tc2 le propre fardeau. 
\m
\v 6
\tr
\tcr1 δὲ \tc2 Mais
\tr
\tcr1 ὁ κατηχούμενος \tc2 celui étant-enseigné-à-propos-de
\tr
\tcr1 τὸν λόγον \tc2 la parole
\tr
\tcr1 κοινωνείτω \tc2 qu'il fasse part
\tr
\tcr1 τῷ κατηχοῦντι \tc2 à-celui enseignant
\tr
\tcr1 ἐν πᾶσιν ἀγαθοῖς \tc2 dans tous \add ses\add* biens.
\m
\v 7
\tr
\tcr1 μὴ πλανᾶσθε \tc2 Ne vous égarez pas,
\tr
\tcr1 Θεὸς \tc2 Dieu
\tr
\tcr1 οὐ μυκτηρίζεται \tc2 n'est pas moqué. 
\tr
\tcr1 γὰρ ἐὰν ὃ ἄνθρωπος σπείρῃ \tc2 Car si \add ce\add*-qu' un-homme sème,
\tr
\tcr1 θερίσει τοῦτο καὶ \tc2 il-moissonnera cela aussi. 
\m
\v 8
\tr
\tcr1 ὅτι ὁ σπείρων \tc2 Parce-que l' \add homme\add* semant
\tr
\tcr1 εἰς τὴν σάρκα ἑαυτοῦ \tc2 dans la chair de-lui-même
\tr
\tcr1 θερίσει φθοράν \tc2 moissonnera \add la\add* ruine
\tr
\tcr1 ἐκ τῆς σαρκὸς \tc2 de la chair, 
\tr
\tcr1 δὲ ὁ σπείρων \tc2 mais celui semant
\tr
\tcr1 εἰς τὸ Πνεῦμα \tc2 pour l' Esprit,
\tr
\tcr1 θερίσει ζωὴν αἰώνιον \tc2 moissonnera \add la\add* vie éternelle
\tr
\tcr1 ἐκ τοῦ Πνεύματος \tc2 de l' Esprit. 
\m
\v 9
\tr
\tcr1 δὲ ποιοῦντες τὸ καλὸν \tc2 Mais faisant le bien,
\tr
\tcr1 μὴ ἐνκακῶμεν \tc2 nous n'avons pas mal agi ;
\tr
\tcr1 γὰρ καιρῷ ἰδίῳ \tc2 car au-moment propre,
\tr
\tcr1 θερίσομεν \tc2 nous moissonerons
\tr
\tcr1 μὴ ἐκλυόμενοι \tc2 n'étant pas délivrés. 
\m
\v 10
\tr
\tcr1 ἄρα οὖν \tc2 Alors donc
\tr
\tcr1 ὡς ἔχομεν καιρὸν \tc2 comme nous-avons un-moment, 
\tr
\tcr1 ἐργαζώμεθα τὸ ἀγαθὸν \tc2 nous-œuvrons le bien 
\tr
\tcr1 πρὸς πάντας \tc2 pour tous,
\tr
\tcr1 δὲ μάλιστα \tc2 mais surtout
\tr
\tcr1 πρὸς τοὺς οἰκείους τῆς πίστεως \tc2 pour ceux de-la-maison de-la foi. 
\m
\v 11
\tr
\tcr1 ἴδετε πηλίκοις γράμμασιν \tc2 Voyez par-quelles-grandes lettres
\tr
\tcr1 ἔγραψα ὑμῖν \tc2 j'ai-écrit à-vous
\tr
\tcr1 ἐμῇ τῇ χειρί \tc2 par-ma main. 
\m
\v 12
\tr
\tcr1 ὅσοι θέλουσιν εὐπροσωπῆσαι \tc2 De-tels veulent plaire
\tr
\tcr1 ἐν σαρκί \tc2 en \add la\add* chair, 
\tr
\tcr1 οὗτοι ἀναγκάζουσιν ὑμᾶς περιτέμνεσθαι \tc2 ceux-ci contraignent vous \add à\add* être-circoncis,
\tr
\tcr1 μόνον ἵνα \tc2 seulement afin-que
\tr
\tcr1 μὴ διώκωνται \tc2 ils ne soient pas persécutés
\tr
\tcr1 τῷ σταυρῷ τοῦ Χριστοῦ Ἰησοῦ \tc2 pour-la croix du Christ Jésus. 
\m
\v 13
\tr
\tcr1 γὰρ οἱ περιτετμημένοι αὐτοὶ \tc2 Car ceux étant-circoncis eux-mêmes
\tr
\tcr1 οὐδὲ φυλάσσουσιν \tc2 ne gardent pas
\tr
\tcr1 νόμον \tc2 \add la\add* loi,
\tr
\tcr1 ἀλλὰ θέλουσιν ὑμᾶς περιτέμνεσθαι \tc2 mais ils-veulent vous être-circoncis
\tr
\tcr1 ἵνα καυχήσωνται \tc2 afin-qu' ils-se-glorifient
\tr
\tcr1 ἐν ὑμετέρᾳ τῇ σαρκὶ \tc2 dans votre chair. 
\m
\v 14
\tr
\tcr1 δὲ ἐμοὶ \tc2 Mais pour-moi,
\tr
\tcr1 μὴ γένοιτο \tc2 qu'il n'advienne pas
\tr
\tcr1 καυχᾶσθαι \tc2 \add de me\add* glorifier,
\tr
\tcr1 εἰ μὴ ἐν τῷ σταυρῷ \tc2 si non dans la croix
\tr
\tcr1 τοῦ Κυρίου ἡμῶν \tc2 du Seigneur de-nous,
\tr
\tcr1 Ἰησοῦ Χριστοῦ \tc2 Jésus Christ, 
\tr
\tcr1 δι’ οὗ κόσμος ἐσταύρωται \tc2 par qui \add le\add* monde a-été-crucifié
\tr
\tcr1 ἐμοὶ \tc2 pour moi,
\tr
\tcr1 κἀγὼ κόσμῳ \tc2 et-moi pour-\add le\add*-monde. 
\m
\v 15
\tr
\tcr1 γὰρ τὶ ἐστιν \tc2 Car ce-qui est
\tr
\tcr1 οὔτε περιτομή \tc2 \add est\add* ni \add la\add* circoncision,
\tr
\tcr1 οὔτε ἀκροβυστία \tc2 ni \add l'\add* incirconcision,
\tr
\tcr1 ἀλλὰ καινὴ κτίσις \tc2 mais \add la\add* nouvelle création. 
\m
\v 16
\tr
\tcr1 καὶ ὅσοι στοιχήσουσιν \tc2 Et les-tels-qui marchent
\tr
\tcr1 τούτῳ τῷ κανόνι \tc2 par-cette règle, 
\tr
\tcr1 εἰρήνη ἐπ’ αὐτοὺς \tc2 paix sur eux,
\tr
\tcr1 καὶ ἔλεος \tc2 et compassion,
\tr
\tcr1 καὶ ἐπὶ τὸν Ἰσραὴλ τοῦ Θεοῦ \tc2 et sur l' Israël de Dieu. 
\m
\v 17
\tr
\tcr1 τοῦ λοιποῦ \tc2 Le reste, 
\tr
\tcr1 μηδεὶς παρεχέτω \tc2 que-personne-ne donne
\tr
\tcr1 κόπους μοι \tc2 des-souffrances à-moi,
\tr
\tcr1 γὰρ ἐγὼ βαστάζω \tc2 car moi je-porte
\tr
\tcr1 τὰ στίγματα τοῦ Ἰησοῦ \tc2 les stigmates de Jésus
\tr
\tcr1 ἐν τῷ σώματί μου \tc2 dans le corps de-moi. 
\m
\v 18
\tr
\tcr1 ἡ χάρις τοῦ Κυρίου ἡμῶν \tc2 La grâce du Seigneur de-nous,
\tr
\tcr1 Ἰησοῦ Χριστοῦ \tc2 Jésus Christ,
\tr
\tcr1 μετὰ τοῦ πνεύματος ὑμῶν \tc2 avec l' esprit de-vous,
\tr
\tcr1 ἀδελφοί \tc2 frères. 
\tr
\tcr1 ἀμήν \tc2 Amen ! 
