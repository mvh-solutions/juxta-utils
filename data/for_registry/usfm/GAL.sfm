\tcr1 δὲ ὁ ταράσσων ὑμᾶς \tc2 Mais celui agitant vous
\tr
\tcr1 βαστάσει τὸ κρίμα \tc2 portera le jugement, 
\tr
\tcr1 ὅστις \tc2 qui
\tr
\tcr1 ἐὰν ᾖ \tc2 qu'il soit.
\m
\v 11
\tr
\tcr1 δέ ἐγὼ \tc2 Mais moi,
\tr
\tcr1 ἀδελφοί \tc2 frères,
\tr
