\tcr1 μετ’ αὐτῶν \tc2 avec eux,
\tr
\tcr1 λαβὼν τὸν ἄρτον \tc2 ayant-pris le pain,
\tr
\tcr1 εὐλόγησεν καὶ κλάσας \tc2 il-remercia et ayant-rompu,
\tr
\tcr1 ἐπεδίδου αὐτοῖς \tc2 il-donna à-eux.
\m
\v 31
\tr
\tcr1 δὲ οἱ ὀφθαλμοὶ αὐτῶν διηνοίχθησαν \tc2 Mais les yeux d'eux s'ouvrirent
\tr
\tcr1 καὶ ἐπέγνωσαν αὐτόν \tc2 et ils-reconnurent lui. 
\tr
\tcr1 καὶ αὐτὸς ἐγένετο ἄφαντος \tc2 Et lui devint invisible
\tr
\tcr1 ἀπ’ αὐτῶν \tc2 d' eux. 
\m
\v 32
\tr
\tcr1 καὶ εἶπαν \tc2 Et ils-dirent
\tr
\tcr1 πρὸς ἀλλήλους \tc2 les uns vers les autres : 
\tr
\tcr1 ἡ καρδία ἡμῶν \tc2 « Le cœur de-nous
\tr
\tcr1 οὐχὶ ἦν \tc2 n'était-il pas
\tr
\tcr1 καιομένη \tc2 étant brûlant
\tr
\tcr1 ὡς ἐλάλει ἡμῖν \tc2 comme il-parlait à-nous
\tr
\tcr1 ἐν τῇ ὁδῷ \tc2 sur le chemin,
\tr
\tcr1 ὡς διήνοιγεν ἡμῖν τὰς Γραφάς \tc2 comme il-ouvrait à-nous les Écritures ? »
\m
\v 33-34
\tr
\tcr1 καὶ ἀναστάντες αὐτῇ τῇ ὥρᾳ \tc2 Et se-levant à-cette heure,
\tr
\tcr1 ὑπέστρεψαν εἰς Ἰερουσαλήμ \tc2 ils-retournèrent à Jérusalem
\tr
\tcr1 καὶ εὗρον \tc2 et trouvèrent
\tr
\tcr1 τοὺς ἕνδεκα ἠθροισμένους \tc2 les onze étant-rassemblés
\tr
\tcr1 καὶ τοὺς σὺν αὐτοῖς λέγοντας ὅτι \tc2 et ceux avec eux disant : 
\tr
\tcr1 ὄντως ὁ Κύριος ἠγέρθη \tc2 « Vraiment, le Seigneur a-été-relevé
\tr
\tcr1 καὶ ὤφθη Σίμωνι \tc2 et il-a-été-vu par-Simon ! »
\m
\v 35
\tr
\tcr1 καὶ αὐτοὶ ἐξηγοῦντο \tc2 Et ceux-ci expliquaient
\tr
\tcr1 τὰ ἐν τῇ ὁδῷ \tc2 les \add choses\add* sur le chemin
\tr
\tcr1 καὶ ὡς ἐγνώσθη αὐτοῖς \tc2 et comme il-a-été-connu à-eux
\tr
\tcr1 ἐν τῇ κλάσει τοῦ ἄρτου \tc2 à la rupture du pain.
\m
\v 36
\tr
\tcr1 δὲ αὐτῶν λαλούντων ταῦτα \tc2 Mais eux parlant \add de\add* ces \add choses\add*,
\tr
\tcr1 αὐτὸς ἔστη \tc2 il se-tint
\tr
\tcr1 ἐν μέσῳ αὐτῶν \tc2 au milieu d'eux
\tr
\tcr1 καὶ λέγει αὐτοῖς \tc2 et dit à-eux : 
\tr
\tcr1 εἰρήνη ὑμῖν \tc2 « Paix à-vous. »
\m
\v 37
\tr
\tcr1 δὲ πτοηθέντες \tc2 Mais étant-terrifiés 
\tr
\tcr1 καὶ γενόμενοι ἔμφοβοι \tc2 et étant-devenus épouvantés,
\tr
\tcr1 ἐδόκουν θεωρεῖν πνεῦμα \tc2 ils-pensaient voir un-esprit.
\m
\v 38
\tr
\tcr1 καὶ εἶπεν αὐτοῖς \tc2 Et il-dit à-eux : 
\tr
\tcr1 τί ἐστέ τεταραγμένοι \tc2 « Pourquoi êtes-vous troublés,
\tr
\tcr1 καὶ διὰ τί \tc2 et à-cause-de quoi
\tr
\tcr1 διαλογισμοὶ ἀναβαίνουσιν \tc2 des-raisonnements se-lèvent
\tr
\tcr1 ἐν τῇ καρδίᾳ ὑμῶν \tc2 dans le cœur de-vous ? 
\m
\v 39
\tr
\tcr1 ἴδετε τὰς χεῖράς μου \tc2 Voyez les mains de-moi
\tr
\tcr1 καὶ τοὺς πόδας μου \tc2 et les pieds de-moi,
\tr
\tcr1 ὅτι ἐγώ εἰμι αὐτός \tc2 que moi, je-suis moi-même. 
\tr
\tcr1 ψηλαφήσατέ με καὶ ἴδετε \tc2 Tâtez moi et voyez,
\tr
\tcr1 ὅτι πνεῦμα \tc2 parce-qu' un-esprit 
\tr
\tcr1 οὐκ ἔχει \tc2 n'a pas
\tr
\tcr1 σάρκα καὶ ὀστέα \tc2 chair et os,
\tr
\tcr1 καθὼς θεωρεῖτε ἐμὲ ἔχοντα \tc2 tout-comme vous-voyez moi ayant. »
\m
\v 40
\tr
\tcr1 καὶ εἰπὼν τοῦτο \tc2 Et ayant-dit cela,
\tr
\tcr1 ἔδειξεν αὐτοῖς \tc2 il-montra à-eux
\tr
\tcr1 τὰς χεῖρας καὶ τοὺς πόδας \tc2 les mains et les pieds. 
\m
\v 41
\tr
\tcr1 δὲ ἔτι αὐτῶν ἀπιστούντων \tc2 Mais encore eux étant-incrédules
\tr
\tcr1 ἀπὸ τῆς χαρᾶς καὶ θαυμαζόντων \tc2 de la joie et étant-étonnés,
\tr
\tcr1 εἶπεν αὐτοῖς \tc2 il-dit à-eux : 
\tr
\tcr1 ἔχετέ τι \tc2 « Avez-vous quelque \add chose\add* 
\tr
\tcr1 βρώσιμον ἐνθάδε \tc2 comestible ici ? »
\m
\v 42
\tr
\tcr1 δὲ οἱ ἐπέδωκαν αὐτῷ \tc2 Et ils donnèrent à-lui
\tr
\tcr1 μέρος ἰχθύος ὀπτοῦ \tc2 une-portion de-poisson grillé. 
\m
\v 43
\tr
\tcr1 καὶ λαβὼν ἐνώπιον αὐτῶν \tc2 Et ayant-pris devant eux, 
\tr
\tcr1 ἔφαγεν \tc2 il mangea. 
\m
\v 44
\tr
\tcr1 δὲ εἶπεν πρὸς αὐτούς \tc2 Mais il-dit vers eux : 
\tr
\tcr1 οὗτοι οἱ λόγοι μου \tc2 « Ces paroles de-moi
\tr
\tcr1 οὓς ἐλάλησα πρὸς ὑμᾶς \tc2 dont je-parlai vers vous
\tr
\tcr1 ὢν ἔτι σὺν ὑμῖν \tc2 \add moi\add* étant encore avec vous,
\tr
\tcr1 ὅτι δεῖ \tc2 parce-qu' il-faut 
\tr
\tcr1 πάντα τὰ γεγραμμένα \tc2 toutes les \add choses\add* ayant-été-écrites
\tr
\tcr1 περὶ ἐμοῦ \tc2 au-sujet de-moi
\tr
\tcr1 ἐν τῷ νόμῳ Μωϋσέως \tc2 dans la loi de-Moïse
\tr
\tcr1 καὶ τοῖς προφήταις καὶ ψαλμοῖς \tc2 et les prophètes et psaumes
\tr
\tcr1 πληρωθῆναι \tc2 être accomplies. »
\m
\v 45-47
\tr
\tcr1 τότε διήνοιξεν \tc2 Alors il-ouvrit
\tr
\tcr1 τὸν νοῦν αὐτῶν \tc2 l' intelligence d'eux
\tr
\tcr1 τοῦ συνιέναι τὰς Γραφάς \tc2 \add pour\add* comprendre les Écritures. 
\tr
\tcr1 καὶ εἶπεν αὐτοῖς ὅτι \tc2 Et il-dit à-eux : 
\tr
\tcr1 οὕτως γέγραπται \tc2 « Ainsi il-a-été-écrit
\tr
\tcr1 τὸν Χριστὸν παθεῖν \tc2 le Christ souffrir
\tr
\tcr1 καὶ ἀναστῆναι ἐκ νεκρῶν \tc2 et ressusciter des morts
\tr
\tcr1 τῇ τρίτῃ ἡμέρᾳ \tc2 au troisième jour,
\tr
\tcr1 καὶ μετάνοιαν κηρυχθῆναι \tc2 et \add la\add* repentance être-prêchée
\tr
\tcr1 ἐπὶ τῷ ὀνόματι αὐτοῦ \tc2 sur le nom de-lui
\tr
\tcr1 εἰς ἄφεσιν ἁμαρτιῶν \tc2 pour \add le\add* pardon des-péchés
\tr
\tcr1 εἰς πάντα τὰ ἔθνη \tc2 dans toutes les nations
\tr
\tcr1 ἀρξάμενοι ἀπὸ Ἰερουσαλήμ \tc2 ayant-commencé de Jérusalem. 
\m
\v 48
\tr
\tcr1 ὑμεῖς \tc2 Vous 
\tr
\tcr1 μάρτυρες τούτων \tc2 \add vous êtes\add* témoins de-ces \add choses\add*. 
\m
\v 49
\tr
\tcr1 καὶ ἐγὼ ἀποστέλλω \tc2 Et moi j'envoie
\tr
\tcr1 τὴν ἐπαγγελίαν τοῦ Πατρός μου \tc2 la promesse du Père de-moi
\tr
\tcr1 ἐφ’ ὑμᾶς \tc2 sur vous,
\tr
\tcr1 δὲ ὑμεῖς καθίσατε ἐν τῇ πόλει \tc2 mais vous demeurez dans la ville
\tr
\tcr1 ἕως οὗ ἐνδύσησθε \tc2 jusqu'à \add ce\add* que vous-soyez-revêtus
\tr
\tcr1 ἐξ δύναμιν ὕψους \tc2 de \add la\add* puissance d'en-haut. »
\m
\v 50
\tr
\tcr1 δὲ ἐξήγαγεν αὐτοὺς \tc2 Mais il-emmena eux
\tr
\tcr1 ἕως πρὸς Βηθανίαν \tc2 jusqu'à vers Béthanie,
\tr
\tcr1 καὶ ἐπάρας τὰς χεῖρας αὐτοῦ \tc2 et ayant-levé les mains de-lui,
\tr
\tcr1 εὐλόγησεν αὐτούς \tc2 il-bénit eux. 
\m
\v 51
\tr
\tcr1 καὶ ἐγένετο \tc2 Et il-advint
\tr
\tcr1 ἐν τῷ αὐτὸν εὐλογεῖν αὐτοὺς \tc2 dans le lui bénir eux,
\tr
\tcr1 διέστη ἀπ’ αὐτῶν \tc2 il-se-sépara d' eux
\tr
\tcr1 καὶ ἀνεφέρετο εἰς τὸν οὐρανόν \tc2 et il-fut-emporté dans le ciel.
\m
\v 52
\tr
\tcr1 καὶ αὐτοὶ προσκυνήσαντες αὐτὸν \tc2 Et ceux-ci ayant-adoré lui,
\tr
\tcr1 ὑπέστρεψαν εἰς Ἰερουσαλὴμ \tc2 retournèrent à Jérusalem.
\tr
\tcr1 μετὰ μεγάλης χαρᾶς \tc2 avec une-grande joie. 
\m
\v 53
\tr
\tcr1 καὶ ἦσαν διὰ παντὸς \tc2 Et ils-étaient à tout-moment
\tr
\tcr1 ἐν τῷ ἱερῷ \tc2 dans le temple,
\tr
\tcr1 εὐλογοῦντες τὸν Θεόν \tc2 bénissant Dieu. 
