\tr
\tcr1 εἶπεν αὐτῷ \tc2 a-dit à-lui :
\tr
\tcr1 γέγραπται \tc2 « Il a été écrit :
\tr
\tcr1 προσκυνήσεις \tc2 "Tu adoreras
\tr
\tcr1 Κύριον τὸν Θεόν σου \tc2 le-Seigneur le Dieu de-toi
\tr
\tcr1 καὶ λατρεύσεις \tc2 et tu-serviras
\tr
\tcr1 αὐτῷ μόνῳ \tc2 lui seul". »
\m
\v 9-11
\tr
\tcr1 δὲ ἤγαγεν αὐτὸν \tc2 Et il-a-conduit lui
\tr
\tcr1 εἰς Ἰερουσαλὴμ \tc2 à Jérusalem,
\tr
\tcr1 καὶ ἔστησεν \tc2 et il-a-placé \add lui\add*
\tr
\tcr1 ἐπὶ τὸ πτερύγιον τοῦ ἱεροῦ \tc2 sur le pinacle du temple
\tr
\tcr1 καὶ εἶπεν αὐτῷ \tc2 et dit à-lui :
\tr
\tcr1 εἰ \tc2 « Si
\tr
\tcr1 εἶ Υἱὸς τοῦ Θεοῦ \tc2 tu-es Fils de Dieu,
\tr
\tcr1 βάλε σεαυτὸν \tc2 jette toi-même
\tr
\tcr1 ἐντεῦθεν κάτω \tc2 d'ici vers-en-bas ;
\tr
\tcr1 γὰρ γέγραπται ὅτι \tc2 car il-a-été-écrit :
\tr
\tcr1 ἐντελεῖται τοῖς ἀγγέλοις αὐτοῦ \tc2 "Il-commandera aux anges de-lui
\tr
\tcr1 περὶ σοῦ \tc2 au-sujet de-toi
\tr
\tcr1 τοῦ διαφυλάξαι σε \tc2 pour garder toi",
\tr
\tcr1 καὶ ὅτι \tc2 et :
\tr
\tcr1 ἀροῦσίν σε \tc2 "Ils-soutiendront toi
\tr
\tcr1 ἐπὶ χειρῶν \tc2 sur \add leurs\add* mains,
\tr
\tcr1 μήποτε προσκόψῃς \tc2 de-peur-que tu-ne-heurtes
\tr
\tcr1 τὸν πόδα σου \tc2 le pied de-toi
\tr
\tcr1 πρὸς λίθον \tc2 contre une-pierre". »
\m
\v 12
\tr
\tcr1 καὶ ὁ Ἰησοῦς \tc2 Et Jésus
\tr
\tcr1 ἀποκριθεὶς \tc2 ayant-répondu
\tr
\tcr1 εἶπεν αὐτῷ ὅτι \tc2 dit à-lui :
\tr
\tcr1 εἴρηται \tc2 « Il a été dit :
\tr
\tcr1 οὐκ ἐκπειράσεις \tc2 "Tu ne tenteras pas
\tr
\tcr1 Κύριον τὸν Θεόν σου \tc2 le-Seigneur le Dieu de-toi". »
\m
\v 13
\tr
\tcr1 καὶ συντελέσας \tc2 Et ayant-achevé
\tr
\tcr1 πάντα πειρασμὸν \tc2 toute tentation,
\tr
\tcr1 ὁ διάβολος \tc2 le diable
\tr
\tcr1 ἀπέστη ἀπ’ αὐτοῦ \tc2 s'est éloigné de lui
\tr
\tcr1 ἄχρι καιροῦ \tc2 jusqu'à un-temps.
\m
\v 14
\tr
\tcr1 καὶ ὁ Ἰησοῦς \tc2 Et Jésus
\tr
\tcr1 ὑπέστρεψεν \tc2 est rentré
\tr
\tcr1 εἰς τὴν Γαλιλαίαν \tc2 dans la Galilée
\tr
\tcr1 ἐν τῇ δυνάμει τοῦ Πνεύματος \tc2 par la puissance de l'Esprit.
\tr
\tcr1 καὶ φήμη \tc2 Et une-réputation
\tr
\tcr1 περὶ αὐτοῦ \tc2 au-sujet de-lui
\tr
\tcr1 ἐξῆλθεν \tc2 est sortie
\tr
\tcr1 καθ’ ὅλης τῆς περιχώρου \tc2 dans toute la \add région\add* avoisinante. 
\m
\v 15
\tr
\tcr1 καὶ αὐτὸς ἐδίδασκεν \tc2 Et lui-même enseignait
\tr
