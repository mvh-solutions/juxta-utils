\tcr1 οἴδαμεν ὅτι λέγεις ὀρθῶς \tc2 nous-savons que tu-dis droitement,
\tr
\tcr1 καὶ διδάσκεις \tc2 et tu-enseignes,
\tr
\tcr1 καὶ \tc2 et
\tr
\tcr1 οὐ λαμβάνεις \tc2 tu ne reçois pas
\tr
\tcr1 πρόσωπον \tc2 un visage,
\tr
\tcr1 ἀλλ’ ἐπ’ ἀληθείας \tc2 mais sur \add la\add* vérité
\tr
\tcr1 διδάσκεις τὴν ὁδὸν τοῦ Θεοῦ \tc2 tu-enseignes la voie de Dieu. 
\m
\v 22
\tr
\tcr1 ἔξεστιν ἡμᾶς \tc2 Est-il-permis \add à\add* nous
\tr
\tcr1 δοῦναι φόρον Καίσαρι \tc2 \add de\add* donner \add un\add* impôt à-César 
\tr
\tcr1 ἢ οὔ \tc2 ou non ? »
\m
\v 23-24
\tr
\tcr1 δὲ κατανοήσας \tc2 Mais ayant-compris 
\tr
\tcr1 τὴν πανουργίαν αὐτῶν \tc2 la méchanceté d'eux,
\tr
\tcr1 εἶπεν πρὸς αὐτούς \tc2 il-dit vers eux : 
\tr
\tcr1 δείξατέ δηνάριον μοι \tc2 « Donnez un-denier à-moi,
\tr
\tcr1 τίνος ἔχει \tc2 de-qui a-t-il
\tr
\tcr1 εἰκόνα καὶ ἐπιγραφήν \tc2 une-image et une-effigie ? »
\tr
\tcr1 δὲ οἱ εἶπαν \tc2 Mais ils dirent : 
\tr
\tcr1 Καίσαρος \tc2 « De César. »
\m
\v 25
\tr
\tcr1 δὲ ὁ εἶπεν πρὸς αὐτούς \tc2 Et il dit vers eux : 
\tr
\tcr1 τοίνυν \tc2 « Eh bien donc,
\tr
\tcr1 ἀπόδοτε τὰ Καίσαρος \tc2 rendez les \add choses\add* de-César
\tr
\tcr1 Καίσαρι \tc2 à César,
\tr
\tcr1 καὶ τὰ τοῦ Θεοῦ \tc2 et les \add choses\add* de Dieu
\tr
\tcr1 τῷ Θεῷ \tc2 à Dieu. »
\m
\v 26
\tr
\tcr1 καὶ \tc2 Et
\tr
\tcr1 οὐκ ἴσχυσαν \tc2 ils n'ont pas été capables
\tr
\tcr1 ἐπιλαβέσθαι τοῦ ῥήματος \tc2 \add de\add* mettre-les-mains-sur la parole
\tr
\tcr1 ἐναντίον τοῦ λαοῦ \tc2 devant le peuple,
\tr
\tcr1 καὶ θαυμάσαντες \tc2 et ayant-été-émerveillés
\tr
\tcr1 ἐπὶ τῇ ἀποκρίσει αὐτοῦ \tc2 par la réponse de-lui,
\tr
\tcr1 ἐσίγησαν \tc2 ils ont gardé le silence. 
\m
\v 27-28
\tr
\tcr1 δέ τινες τῶν Σαδδουκαίων \tc2 Mais quelques-uns des Sadducéens 
\tr
\tcr1 προσελθόντες \tc2 s'étant approchés,
\tr
\tcr1 οἱ λέγοντες \tc2 ceux disant 
\tr
\tcr1 μὴ εἶναι \tc2 ne-pas y-avoir 
\tr
\tcr1 ἀνάστασιν \tc2 \add de\add* résurrection,
\tr
\tcr1 ἐπηρώτησαν αὐτὸν λέγοντες \tc2 ils-interrogèrent lui disant : 
\tr
\tcr1 Διδάσκαλε \tc2 « Maître,
\tr
\tcr1 Μωϋσῆς ἔγραψεν ἡμῖν \tc2 Moïse a-écrit à-nous \add que\add*
\tr
\tcr1 ἐάν ἀδελφὸς τινος ἀποθάνῃ \tc2 si un-frère de-quelqu'un meurt
\tr
\tcr1 ἔχων γυναῖκα \tc2 ayant une-femme,
\tr
\tcr1 καὶ οὗτος ᾖ ἄτεκνος \tc2 et celui-ci était sans-enfant,
\tr
\tcr1 ἵνα ὁ ἀδελφὸς αὐτοῦ \tc2 que le frère de-lui
\tr
\tcr1 λάβῃ τὴν γυναῖκα \tc2 prenne la femme,
\tr
\tcr1 καὶ ἐξαναστήσῃ σπέρμα \tc2 et lève une-semence
\tr
\tcr1 τῷ ἀδελφῷ αὐτοῦ \tc2 au frère de-lui. 
\m
\v 29-31
\tr
\tcr1 ἦσαν οὖν ἑπτὰ ἀδελφοὶ \tc2 Il-y-avait donc sept frères,
\tr
\tcr1 καὶ ὁ πρῶτος \tc2 et le premier
\tr
\tcr1 λαβὼν γυναῖκα \tc2 ayant-pris \add la\add* femme,
\tr
\tcr1 ἀπέθανεν ἄτεκνος \tc2 il-mourut sans-enfant,
\tr
\tcr1 καὶ ὁ δεύτερος \tc2 aussi le deuxième,
\tr
\tcr1 καὶ ὁ τρίτος ἔλαβεν αὐτήν \tc2 et le troisième prit elle,
\tr
\tcr1 δὲ ὡσαύτως καὶ \tc2 mais de-même aussi
\tr
\tcr1 οἱ ἑπτὰ \tc2 les sept 
\tr
\tcr1 οὐ κατέλιπον \tc2 ne laissèrent pas 
\tr
\tcr1 τέκνα \tc2 d'enfants
\tr
\tcr1 καὶ ἀπέθανον \tc2 et moururent. 
\m
\v 32
\tr
\tcr1 ὕστερον καὶ \tc2 Après aussi 
\tr
\tcr1 ἡ γυνὴ ἀπέθανεν \tc2 la femme mourut. 
\m
\v 33
\tr
\tcr1 οὖν \tc2 Donc,
\tr
\tcr1 ἐν τῇ ἀναστάσει \tc2 à la résurrection,
\tr
\tcr1 τίνος αὐτῶν γίνεται γυνή \tc2 de-qui d'eux est-elle \add la\add* femme ?
\tr
\tcr1 γὰρ οἱ ἑπτὰ ἔσχον αὐτὴν \tc2 Car les sept avaient elle 
\tr
\tcr1 γυναῖκα \tc2 \add pour\add* femme. »
\m
\v 34-36
\tr
\tcr1 καὶ ὁ Ἰησοῦς εἶπεν αὐτοῖς \tc2 Et Jésus dit à-eux : 
\tr
\tcr1 οἱ υἱοὶ τούτου τοῦ αἰῶνος \tc2 « Les fils de-ce siècle
\tr
\tcr1 γαμοῦσιν καὶ γαμίσκονται \tc2 épousent et marient ;
\tr
\tcr1 οἱ δὲ καταξιωθέντες \tc2 mais ceux étant-jugés-dignes
\tr
\tcr1 τυχεῖν \tc2 d'obtenir
\tr
\tcr1 ἐκείνου τοῦ αἰῶνος \tc2 ce siècle-là, 
\tr
\tcr1 καὶ τῆς ἀναστάσεως τῆς ἐκ νεκρῶν \tc2 et la résurrection celle des morts,
\tr
\tcr1 οὔτε γαμοῦσιν \tc2 ils n'épouseront plus
\tr
\tcr1 οὔτε γαμίζονται \tc2 ni ne marieront,
\tr
\tcr1 γὰρ \tc2 car
\tr
\tcr1 οὐδὲ δύνανται \tc2 ils ne pourront plus
\tr
\tcr1 ἔτι ἀποθανεῖν \tc2 encore mourir,
\tr
\tcr1 γάρ εἰσιν ἰσάγγελοι \tc2 car ils-sont semblables-aux-anges,
\tr
\tcr1 καὶ εἰσιν υἱοί Θεοῦ \tc2 et ils-sont fils de-Dieu,
\tr
\tcr1 ὄντες υἱοὶ τῆς ἀναστάσεως \tc2 étant fils de-la résurrection.
\m
\v 37-38
\tr
\tcr1 δὲ ὅτι οἱ νεκροὶ ἐγείρονται \tc2 Mais parce-que les morts se-relèvent,
\tr
\tcr1 καὶ Μωϋσῆς ἐμήνυσεν ἐπὶ τῆς βάτου \tc2 et Moïse indiqua sur le buisson
\tr
\tcr1 ὡς λέγει Κύριον \tc2 comme désigne "Seigneur"
\tr
\tcr1 τὸν Θεὸν Ἀβραὰμ \tc2 le Dieu d'Abraham,
\tr
\tcr1 καὶ Θεὸν Ἰσαὰκ \tc2 et Dieu d'Isaac,
\tr
\tcr1 καὶ Θεὸν Ἰακώβ \tc2 et Dieu de-Jacob,
\tr
\tcr1 δὲ \tc2 mais
\tr
\tcr1 οὐκ ἔστιν \tc2 il n'est pas
\tr
\tcr1 Θεὸς νεκρῶν \tc2 Dieu des morts,
\tr
\tcr1 ἀλλὰ ζώντων \tc2 mais des-vivants,
\tr
\tcr1 γὰρ πάντες ζῶσιν αὐτῷ \tc2 car tous vivent pour-lui. »
\m
\v 39
\tr
\tcr1 δέ τινες τῶν γραμματέων \tc2 Mais quelques-uns des scribes
\tr
\tcr1 ἀποκριθέντες εἶπαν \tc2 ayant-répondu dirent : 
\tr
\tcr1 Διδάσκαλε εἶπας καλῶς \tc2 « Maître, tu-dis bien. »
\m
\v 40
\tr
\tcr1 γὰρ \tc2 Car
\tr
\tcr1 οὐκέτι ἐτόλμων \tc2 ils n'osaient plus
\tr
\tcr1 ἐπερωτᾶν αὐτὸν οὐδέν \tc2 interroger lui \add sur\add* rien.
\m
\v 41
\tr
\tcr1 δὲ εἶπεν πρὸς αὐτούς \tc2 Mais il-dit vers eux : 
\tr
\tcr1 πῶς λέγουσιν \tc2 « Comment disent-ils \add que\add*
\tr
\tcr1 τὸν Χριστὸν εἶναι Υἱόν Δαυεὶδ \tc2 le Christ être Fils de-David ? 
\m
\v 42-43
\tr
\tcr1 γὰρ Δαυεὶδ αὐτὸς \tc2 Car David lui-même
\tr
\tcr1 λέγει ἐν βίβλῳ Ψαλμῶν \tc2 dit dans \add le\add* livre des-Psaumes : 
\tr
\tcr1 ὁ Κύριος εἶπεν τῷ Κυρίῳ μου \tc2 "Le Seigneur dit au Seigneur de-moi : 
\tr
\tcr1 κάθου ἐκ δεξιῶν μου \tc2 'Assieds-toi aux droites de-moi
\tr
\tcr1 ἕως ἂν θῶ \tc2 jusqu'à-ce-que j'établisse 
\tr
\tcr1 τοὺς ἐχθρούς σου \tc2 les ennemis de-toi
\tr
\tcr1 ὑποπόδιον τῶν ποδῶν σου \tc2 marchepied des pieds de-toi'."
\m
\v 44
\tr
\tcr1 Δαυεὶδ καλεῖ οὖν αὐτὸν Κύριον \tc2 David appelle donc lui "Seigneur",
\tr
\tcr1 πῶς ἐστιν καὶ υἱός αὐτοῦ \tc2 comment est-il aussi fils de-lui ? »
\m
\v 45-47
\tr
\tcr1 δὲ παντὸς τοῦ λαοῦ ἀκούοντος \tc2 Mais tout le peuple entendant, 
\tr
\tcr1 εἶπεν τοῖς μαθηταῖς αὐτοῦ \tc2 il-dit aux disciples de-lui : 
\tr
\tcr1 προσέχετε ἀπὸ τῶν γραμματέων \tc2 « Soyez-attentifs des scribes,
\tr
\tcr1 τῶν θελόντων περιπατεῖν ἐν στολαῖς \tc2 de-ceux voulant marcher en robes,
\tr
\tcr1 καὶ φιλούντων ἀσπασμοὺς \tc2 et aimant des-salutations
\tr
\tcr1 ἐν ταῖς ἀγοραῖς \tc2 dans les marchés
\tr
\tcr1 καὶ πρωτοκαθεδρίας \tc2 et des-premiers-sièges
\tr
\tcr1 ἐν ταῖς συναγωγαῖς \tc2 dans les synagogues,
\tr
\tcr1 καὶ πρωτοκλισίας ἐν τοῖς δείπνοις \tc2 et des-places-d'honneur dans les dîners,
\tr
\tcr1 οἳ κατεσθίουσιν \tc2 qui dévorent
\tr
\tcr1 τὰς οἰκίας τῶν χηρῶν \tc2 les maisons des veuves,
\tr
\tcr1 καὶ προσεύχονται μακρὰ \tc2 et \add qui\add* prient longuement
\tr
\tcr1 προφάσει \tc2 par prétexte,
\tr
\tcr1 οὗτοι λήμψονται \tc2 ceux-ci recevront 
\tr
\tcr1 περισσότερον κρίμα \tc2 un-plus-grand jugement. »
\c 21
\m
\v 1
\tr
\tcr1 δὲ ἀναβλέψας \tc2 Mais ayant-levé-les-yeux,
\tr
\tcr1 εἶδεν πλουσίους \tc2 il-vit des-riches
\tr
\tcr1 τοὺς βάλλοντας \tc2 ceux jetant
\tr
\tcr1 τὰ δῶρα αὐτῶν \tc2 les dons d'eux
\tr
\tcr1 εἰς τὸ γαζοφυλάκιον \tc2 dans le trésor. 
\m
\v 2
\tr
\tcr1 δέ εἶδεν τινα χήραν πενιχρὰν \tc2 Mais il-vit quelque veuve indigente,
\tr
\tcr1 βάλλουσαν ἐκεῖ \tc2 ayant-jeté là 
\tr
\tcr1 δύο λεπτὰ \tc2 deux petites-pièces. 
\m
\v 3-4
\tr
\tcr1 καὶ εἶπεν \tc2 Et il-dit : 
\tr
\tcr1 ἀληθῶς λέγω ὑμῖν ὅτι \tc2 « Vraiment je-dis à-vous que
\tr
\tcr1 αὕτη ἡ πτωχὴ ἡ χήρα \tc2 cette pauvre veuve
\tr
\tcr1 ἔβαλεν πλεῖον πάντων \tc2 a-jeté plus \add que\add* tous,
\tr
\tcr1 γὰρ πάντες οὗτοι ἔβαλον \tc2 car tous ceux-ci ont-jeté
\tr
\tcr1 ἐκ τοῦ περισσεύοντος αὐτοῖς \tc2 de l' abondance à-eux
\tr
\tcr1 εἰς τὰ δῶρα \tc2 dans les dons,
\tr
\tcr1 δὲ αὕτη ἔβαλεν \tc2 mais elle elle-a-jeté
\tr
\tcr1 ἐκ τοῦ ὑστερήματος αὐτῆς \tc2 de l' indigence d'elle
\tr
\tcr1 πάντα τὸν βίον ὃν εἶχεν \tc2 toute la vie qu' elle-avait. »
\m
\v 5-6
\tr
\tcr1 καί τινων λεγόντων \tc2 Et quelques-uns disant
\tr
\tcr1 περὶ τοῦ ἱεροῦ ὅτι \tc2 au-sujet du temple que
\tr
\tcr1 καλοῖς λίθοις καὶ ἀναθέμασιν \tc2 des-belles pierres et des-offrandes 
\tr
\tcr1 κεκόσμηται \tc2 \add l'\add* ornaient,
\tr
\tcr1 εἶπεν \tc2 il dit : 
\tr
\tcr1 ταῦτα ἃ θεωρεῖτε \tc2 « Ces \add choses\add* que vous-voyez,
\tr
\tcr1 ἡμέραι ἐλεύσονται ἐν αἷς \tc2 des-jours viendront dans lesquels
\tr
\tcr1 οὐκ ἀφεθήσεται \tc2 il ne sera laissé
\tr
\tcr1 λίθος ἐπὶ λίθῳ \tc2 pierre sur pierre
\tr
\tcr1 ὃς οὐ καταλυθήσεται \tc2 qui ne sera-renversée. »
\m
\v 7
\tr
\tcr1 ἐπηρώτησαν δὲ αὐτὸν λέγοντες \tc2 Mais ils-interrogèrent lui, disant : 
\tr
\tcr1 Διδάσκαλε \tc2 « Maître, 
\tr
\tcr1 πότε οὖν ταῦτα ἔσται \tc2 quand donc ces \add choses\add* seront,
\tr
\tcr1 καὶ τί τὸ σημεῖον \tc2 et quel \add est\add* le signe
\tr
\tcr1 ὅταν ταῦτα μέλλῃ γίνεσθαι \tc2 lorsque ces \add choses\add* devront advenir ? »
\m
\v 8
\tr
\tcr1 δὲ ὁ εἶπεν \tc2 Mais il dit : 
\tr
\tcr1 βλέπετε \tc2 « Regardez 
\tr
\tcr1 μὴ πλανηθῆτε \tc2 ne soyez pas égarés ;
\tr
\tcr1 γὰρ πολλοὶ ἐλεύσονται \tc2 car de-nombreux viendront
\tr
\tcr1 ἐπὶ τῷ ὀνόματί μου λέγοντες \tc2 sur le nom de-moi disant : 
\tr
\tcr1 ἐγώ εἰμι \tc2 "moi, je-suis",
\tr
\tcr1 καί ὁ καιρὸς ἤγγικεν \tc2 et, le moment s'est-approché. 
\tr
\tcr1 μὴ πορευθῆτε \tc2 N'allez pas
\tr
\tcr1 ὀπίσω αὐτῶν \tc2 derrière eux. 
\m
\v 9
\tr
\tcr1 δὲ ὅταν ἀκούσητε \tc2 Mais lorsque vous-entendrez
\tr
\tcr1 πολέμους καὶ ἀκαταστασίας \tc2 des-tumultes et des-agitations,
\tr
\tcr1 μὴ πτοηθῆτε \tc2 ne soyez pas terrifiés, 
\tr
\tcr1 γὰρ δεῖ ταῦτα \tc2 car il-faut \add que\add* ces \add choses\add* 
\tr
\tcr1 γενέσθαι πρῶτον \tc2 advenir premièrement,
\tr
\tcr1 ἀλλ’ οὐκ εὐθέως τὸ τέλος \tc2 mais pas aussitôt la fin. »
\m
\v 10-11
\tr
\tcr1 τότε ἔλεγεν αὐτοῖς \tc2 Alors il-disait à-eux : 
\tr
\tcr1 ἔθνος ἐγερθήσεται ἐπ’ ἔθνος \tc2 « Une-nation se-lèvera sur une-nation,
\tr
\tcr1 καὶ βασιλεία ἐπὶ βασιλείαν \tc2 et un-royaume sur un-royaume, 
\tr
\tcr1 τε μεγάλοι σεισμοί \tc2 et de-grands séismes,
\tr
\tcr1 καὶ ἔσονται κατὰ τόπους \tc2 et il-y-aura en tous lieux,
\tr
\tcr1 λιμοὶ καὶ λοιμοὶ \tc2 des-famines et des-fléaux,
\tr
\tcr1 τε ἔσται φόβηθρά \tc2 et il-y-aura des-terreurs
\tr
\tcr1 καὶ μεγάλα σημεῖα \tc2 et de-grands signes
\tr
\tcr1 ἀπ’ οὐρανοῦ \tc2 du ciel. 
\m
\v 12
\tr
\tcr1 πρὸ δὲ πάντων τούτων \tc2 Mais avant tout cela,
\tr
\tcr1 ἐπιβαλοῦσιν τὰς χεῖρας αὐτῶν \tc2 ils-jetteront les mains d'eux
\tr
\tcr1 ἐφ’ ὑμᾶς \tc2 sur vous,
\tr
\tcr1 καὶ διώξουσιν \tc2 et persécuteront,
\tr
\tcr1 παραδιδόντες εἰς τὰς συναγωγὰς καὶ φυλακάς \tc2 livrant dans les synagogues et prisons,
\tr
\tcr1 ἀπαγομένους ἐπὶ βασιλεῖς καὶ ἡγεμόνας \tc2 conduisant devant des-rois et dirigeants,
\tr
\tcr1 ἕνεκεν τοῦ ὀνόματός μου \tc2 à-cause du nom de-moi. 
\m
\v 13
\tr
\tcr1 ἀποβήσεται ὑμῖν \tc2 \add Cela\add* arrivera à-vous
\tr
\tcr1 εἰς μαρτύριον \tc2 en-vue d'un-témoignage. 
\m
\v 14-15
\tr
\tcr1 θέτε οὖν \tc2 Établissez donc
\tr
\tcr1 ἐν ταῖς καρδίαις ὑμῶν \tc2 dans les cœurs de-vous,
\tr
\tcr1 μὴ προμελετᾶν \tc2 \add de\add* ne-pas s'exercer-d'avance 
\tr
\tcr1 ἀπολογηθῆναι \tc2 \add à\add* se-défendre,
\tr
\tcr1 γὰρ ἐγὼ δώσω ὑμῖν \tc2 car moi je-donnerai à-vous
\tr
\tcr1 στόμα καὶ σοφίαν \tc2 une-bouche et une-sagesse,
\tr
\tcr1 ᾗ πάντες οἱ ἀντικείμενοι ὑμῖν \tc2 à-laquelle tous ceux s'opposant à-vous
\tr
\tcr1 οὐ δυνήσονται \tc2 ne pourront pas
\tr
\tcr1 ἀντιστῆναι ἢ ἀντειπεῖν \tc2 se-dresser-contre ou contredire. 
\m
\v 16
\tr
\tcr1 δὲ παραδοθήσεσθε καὶ \tc2 Mais vous-serez-livrés aussi 
\tr
\tcr1 ὑπὸ γονέων \tc2 par des-parents,
\tr
\tcr1 καὶ ἀδελφῶν καὶ συγγενῶν \tc2 et des-frères, et des-gens-de-parenté,
\tr
\tcr1 καὶ φίλων \tc2 et des-amis,
\tr
\tcr1 καὶ θανατώσουσιν \tc2 et ils-feront-mourir 
\tr
\tcr1 ἐξ ὑμῶν \tc2 \add des gens\add* de \add parmi\add* vous.
\m
\v 17
\tr
\tcr1 καὶ ἔσεσθε μισούμενοι ὑπὸ πάντων \tc2 Et vous-serez étant-haïs par tous
\tr
\tcr1 διὰ τὸ ὄνομά μου \tc2 à-cause du nom de-moi. 
\m
\v 18
\tr
\tcr1 καὶ θρὶξ ἐκ τῆς κεφαλῆς ὑμῶν \tc2 Et un-cheveu de la tête de-vous
\tr
\tcr1 οὐ μὴ ἀπόληται \tc2 ne sera certainement pas perdu. 
\m
\v 19
\tr
\tcr1 ἐν τῇ ὑπομονῇ ὑμῶν \tc2 Dans la persévérance de-vous,
\tr
\tcr1 κτήσασθε τὰς ψυχὰς ὑμῶν \tc2 vous-gagnerez les âmes de-vous. 
\m
\v 20
\tr
\tcr1 δὲ ὅταν ἴδητε \tc2 Mais lorsque vous-verrez
\tr
\tcr1 Ἰερουσαλήμ κυκλουμένην \tc2 Jérusalem étant-entourée 
\tr
\tcr1 ὑπὸ στρατοπέδων \tc2 par des-armées,
\tr
\tcr1 τότε γνῶτε ὅτι \tc2 alors vous-connaîtrez que
\tr
\tcr1 ἡ ἐρήμωσις αὐτῆς ἤγγικεν \tc2 la dévastation d'elle s'est-approchée. 
\m
\v 21-22
\tr
\tcr1 τότε οἱ ἐν τῇ Ἰουδαίᾳ \tc2 Alors ceux dans la Judée,
\tr
\tcr1 φευγέτωσαν εἰς τὰ ὄρη \tc2 \add qu'\add* ils-fuient dans les montagnes,
\tr
\tcr1 καὶ οἱ ἐν μέσῳ αὐτῆς \tc2 et ceux au milieu d'elle,
\tr
\tcr1 ἐκχωρείτωσαν \tc2 \add qu'\add* ils quittent le pays,
\tr
\tcr1 καὶ οἱ ἐν ταῖς χώραις \tc2 et ceux dans les contrées,
\tr
\tcr1 μὴ εἰσερχέσθωσαν \tc2 \add qu'\add* ils n'entrent pas 
\tr
\tcr1 εἰς αὐτήν \tc2 en elle,
\tr
\tcr1 ὅτι αὗταί εἰσιν \tc2 parce-que ceux-ci sont
\tr
\tcr1 ἡμέραι ἐκδικήσεως \tc2 des-jours de-vengeance,
\tr
\tcr1 τοῦ \tc2 le \add fait que\add* 
\tr
\tcr1 πάντα τὰ γεγραμμένα \tc2 toutes les \add choses\add* ayant-été-écrites 
\tr
\tcr1 πλησθῆναι \tc2 être-accomplies.
\m
\v 23
\tr
\tcr1 δὲ οὐαὶ \tc2 Mais malheur 
\tr
\tcr1 ταῖς ἐχούσαις ἐν γαστρὶ \tc2 à-celles ayant \add un enfant\add* dans \add le\add* ventre
\tr
\tcr1 καὶ ταῖς θηλαζούσαις \tc2 et à-celles allaitant
\tr
\tcr1 ἐν ἐκείναις ταῖς ἡμέραις \tc2 dans ces jours-là,
\tr
\tcr1 γὰρ ἔσται μεγάλη ἀνάγκη \tc2 car il-y-aura une-grande souffrance
\tr
\tcr1 ἐπὶ τῆς γῆς \tc2 sur la terre,
\tr
\tcr1 καὶ ὀργὴ \tc2 et une-colère 
\tr
\tcr1 τούτῳ τῷ λαῷ \tc2 pour-ce peuple.
\m
\v 24
\tr
\tcr1 καὶ πεσοῦνται \tc2 Et ils-tomberont
\tr
\tcr1 στόματι μαχαίρης \tc2 par-le-tranchant d'un-couteau,
\tr
\tcr1 καὶ αἰχμαλωτισθήσονται \tc2 et ils-seront-emmenés-en-captivité
\tr
\tcr1 εἰς πάντα τὰ ἔθνη \tc2 dans toutes les nations,
\tr
\tcr1 καὶ Ἰερουσαλὴμ ἔσται πατουμένη \tc2 et Jérusalem sera étant-foulée-au-pied
\tr
\tcr1 ὑπὸ ἐθνῶν \tc2 par \add les\add* nations,
\tr
\tcr1 ἄχρι οὗ καιροὶ ἐθνῶν \tc2 jusqu'à \add ce\add* que \add les\add* temps des-nations 
\tr
\tcr1 πληρωθῶσιν \tc2 soient-accomplis.
\m
\v 25-26
\tr
\tcr1 καὶ ἔσονται σημεῖα \tc2 Et il-y-aura des-signes
\tr
\tcr1 ἐν ἡλίῳ καὶ σελήνῃ καὶ ἄστροις \tc2 dans \add le\add* soleil, et \add la\add* lune, et \add les\add* astres,
\tr
\tcr1 καὶ ἐπὶ τῆς γῆς \tc2 et sur la terre
\tr
\tcr1 συνοχὴ ἐθνῶν \tc2 \add l'\add* inquiétude des-nations,
\tr
\tcr1 ἐν ἀπορίᾳ \tc2 dans \add la\add* perplexité 
\tr
\tcr1 ἤχους θαλάσσης καὶ σάλου \tc2 du-bruit de-\add la\add*-mer et de-\add la\add*-vague,
\tr
\tcr1 ἀνθρώπων ἀποψυχόντων \tc2 des-hommes rendant-l'âme
\tr
\tcr1 ἀπὸ φόβου \tc2 de peur,
\tr
\tcr1 καὶ προσδοκίας \tc2 et de-crainte 
\tr
\tcr1 τῶν ἐπερχομένων τῇ οἰκουμένῃ \tc2 de-ceux approchant-sur le monde,
\tr
\tcr1 γὰρ αἱ δυνάμεις τῶν οὐρανῶν \tc2 car les puissances des cieux 
\tr
\tcr1 σαλευθήσονται \tc2 seront-ébranlées.
\m
\v 27
\tr
\tcr1 καὶ τότε ὄψονται \tc2 Et alors ils-verront 
\tr
\tcr1 τὸν Υἱὸν τοῦ Ἀνθρώπου \tc2 le Fils de-l' Homme,
\tr
\tcr1 ἐρχόμενον ἐν νεφέλῃ \tc2 venant dans une-nuée
\tr
\tcr1 μετὰ δυνάμεως καὶ πολλῆς δόξης \tc2 avec puissance et une-grande gloire.
\m
\v 28
\tr
\tcr1 δὲ τούτων ἀρχομένων γίνεσθαι \tc2 Mais ces \add choses\add* devant advenir, 
\tr
\tcr1 ἀνακύψατε καὶ ἐπάρατε \tc2 levez-vous et relevez 
\tr
\tcr1 τὰς κεφαλὰς ὑμῶν \tc2 les têtes de-vous,
\tr
\tcr1 διότι ἡ ἀπολύτρωσις ὑμῶν \tc2 parce-que la rédemption de-vous 
\tr
\tcr1 ἐγγίζει \tc2 s'approche. »
\m
\v 29-30
\tr
\tcr1 καὶ εἶπεν παραβολὴν αὐτοῖς \tc2 Et il-a-dit une-parabole à-eux : 
\tr
\tcr1 ἴδετε τὴν συκῆν \tc2 « Voyez le figuier
\tr
\tcr1 καὶ πάντα τὰ δένδρα \tc2 et tous les arbres,
\tr
\tcr1 ὅταν ἤδη προβάλωσιν \tc2 lorsque déjà ils-produisent
\tr
\tcr1 βλέποντες ἀφ’ ἑαυτῶν \tc2 voyant d' eux-mêmes,
\tr
\tcr1 γινώσκετε ὅτι ἤδη \tc2 vous-connaissez que déjà
\tr
\tcr1 τὸ θέρος ἐστίν ἐγγὺς \tc2 la moisson est proche. 
\m
\v 31
\tr
\tcr1 οὕτως ὑμεῖς καὶ \tc2 Ainsi vous aussi,
\tr
\tcr1 ὅταν ἴδητε ταῦτα γινόμενα \tc2 lorsque vous-verrez ces \add choses\add* advenant,
\tr
\tcr1 γινώσκετε ὅτι \tc2 vous-savez que
\tr
\tcr1 ἡ Βασιλεία τοῦ Θεοῦ \tc2 le Royaume de Dieu
\tr
\tcr1 ἐστιν ἐγγύς \tc2 est proche. 
\m
\v 32
\tr
\tcr1 ἀμὴν λέγω ὑμῖν ὅτι \tc2 En-vérité je-dis à-vous que
\tr
\tcr1 αὕτη ἡ γενεὰ \tc2 cette génération
\tr
\tcr1 οὐ μὴ παρέλθῃ \tc2 ne passera certainement pas
\tr
\tcr1 ἕως ἂν πάντα \tc2 jusqu'à \add ce\add* que toutes \add ces choses\add* 
\tr
\tcr1 γένηται \tc2 adviennent.
\m
\v 33
\tr
\tcr1 ὁ οὐρανὸς καὶ ἡ γῆ παρελεύσονται \tc2 Le ciel et la terre passeront,
\tr
\tcr1 δὲ οἱ λόγοι μου \tc2 mais les paroles de-moi
\tr
\tcr1 οὐ μὴ παρελεύσονται \tc2 ne passeront certainement pas.
\m
\v 34-35
\tr
\tcr1 δὲ προσέχετε ἑαυτοῖς \tc2 Mais priez pour-vous-mêmes,
\tr
\tcr1 αἱ καρδίαι ὑμῶν \tc2 \add que\add* les cœurs de-vous
\tr
\tcr1 μήποτε βαρηθῶσιν \tc2 ne soient jamais alourdis
\tr
\tcr1 ἐν κρεπάλῃ καὶ μέθῃ \tc2 en ivresse et excès-de-boisson,
\tr
\tcr1 καὶ μερίμναις βιωτικαῖς \tc2 et par-des-solicitudes de-la-vie ;
\tr
\tcr1 καὶ ἐκείνη ἡ ἡμέρα \tc2 et ce jour-là
\tr
\tcr1 ἐπιστῇ αἰφνίδιος ἐφ’ ὑμᾶς \tc2 se-posera soudainement sur vous
\tr
\tcr1 ὡς παγίς \tc2 comme un-filet,
\tr
\tcr1 γὰρ ἐπεισελεύσεται \tc2 car il-surviendra
\tr
\tcr1 ἐπὶ πάντας τοὺς καθημένους \tc2 sur tous ceux demeurant
\tr
\tcr1 ἐπὶ πρόσωπον πάσης τῆς γῆς \tc2 sur \add la\add* face de-toute la terre.
\m
\v 36
\tr
\tcr1 δὲ ἀγρυπνεῖτε \tc2 Mais soyez-éveillés 
\tr
\tcr1 ἐν παντὶ καιρῷ δεόμενοι \tc2 à tout moment priant,
\tr
\tcr1 ἵνα κατισχύσητε ἐκφυγεῖν \tc2 afin-que vous-ayiez-la-force \add de\add* fuir
\tr
\tcr1 πάντα ταῦτα τὰ μέλλοντα γίνεσθαι \tc2 toutes ces \add choses\add* devant advenir,
\tr
\tcr1 καὶ σταθῆναι \tc2 et \add vous\add* tenir
\tr
\tcr1 ἔμπροσθεν τοῦ Υἱοῦ τοῦ Ἀνθρώπου \tc2 devant le Fils de-l' Homme. »
\m
\v 37
\tr
\tcr1 δὲ ἦν διδάσκων \tc2 Mais il-était enseignant
\tr
\tcr1 τὰς ἡμέρας \tc2 les jours
\tr
\tcr1 ἐν τῷ ἱερῷ \tc2 dans le temple, 
\tr
\tcr1 δὲ ἐξερχόμενος τὰς νύκτας \tc2 mais sortant les nuits,
\tr
\tcr1 ηὐλίζετο \tc2 il séjournait
\tr
\tcr1 εἰς τὸ ὄρος \tc2 dans la montagne 
\tr
\tcr1 τὸ καλούμενον Ἐλαιῶν \tc2 celle étant-appelée des-Oliviers.
\m
\v 38
\tr
\tcr1 καὶ πᾶς ὁ λαὸς \tc2 Et tout le peuple
\tr
\tcr1 ὤρθριζεν πρὸς αὐτὸν \tc2 se-dressait vers lui
\tr
\tcr1 ἐν τῷ ἱερῷ \tc2 dans le temple
\tr
\tcr1 ἀκούειν αὐτοῦ \tc2 \add pour\add* écouter lui. 
\c 22
\m
\v 1
\tr
\tcr1 δὲ ἡ ἑορτὴ τῶν Ἀζύμων ἤγγιζεν \tc2 Mais la fête des Azymes s'approchait,
\tr
\tcr1 ἡ λεγομένη Πάσχα \tc2 celle étant-dite Pâque. 
\m
\v 2
\tr
\tcr1 καὶ οἱ ἀρχιερεῖς καὶ οἱ γραμματεῖς \tc2 Et les chefs-des-prêtres et les scribes 
\tr
\tcr1 ἐζήτουν \tc2 cherchaient
\tr
\tcr1 τὸ πῶς ἀνέλωσιν αὐτόν \tc2 le comment ils-enlèveraient lui,
\tr
\tcr1 γὰρ ἐφοβοῦντο τὸν λαόν \tc2 car ils-craignaient le peuple. 
\m
\v 3
\tr
\tcr1 δὲ Σατανᾶς εἰσῆλθεν εἰς Ἰούδαν \tc2 Mais Satan entra en Judas,
\tr
\tcr1 τὸν καλούμενον Ἰσκαριώτην \tc2 celui étant-appelé Iscariot,
\tr
\tcr1 ὄντα ἐκ τοῦ ἀριθμοῦ \tc2 étant du compte 
\tr
\tcr1 τῶν δώδεκα \tc2 des douze. 
\m
\v 4
\tr
\tcr1 καὶ ἀπελθὼν \tc2 Et étant-parti,
\tr
\tcr1 συνελάλησεν \tc2 il-parla-avec 
\tr
\tcr1 τοῖς ἀρχιερεῦσιν καὶ στρατηγοῖς \tc2 les chefs-des-prêtres et \add les\add* officiers
\tr
\tcr1 τὸ πῶς παραδῷ αὐτόν \tc2 le comment il-livrerait lui 
\tr
\tcr1 αὐτοῖς \tc2 à-eux. 
\m
\v 5
\tr
\tcr1 καὶ \tc2 Et 
\tr
\tcr1 ἐχάρησαν καὶ συνέθεντο αὐτῷ \tc2 ils-se-réjouirent et établirent-avec lui
\tr
\tcr1 δοῦναι ἀργύριον \tc2 \add de\add* donner \add de l'\add* argent. 
\m
\v 6
\tr
\tcr1 καὶ ἐξωμολόγησεν \tc2 Et il-consentit,
\tr
\tcr1 καὶ ἐζήτει εὐκαιρίαν \tc2 et il-cherchait un-bon-moment
\tr
\tcr1 τοῦ παραδοῦναι αὐτὸν αὐτοῖς \tc2 \add pour\add* le livrer lui à-eux.
\tr
\tcr1 ἄτερ ὄχλου \tc2 à-l'écart \add de la\add* foule.
\m
\v 7
\tr
\tcr1 δὲ ἡ ἡμέρα τῶν Ἀζύμων ἦλθεν \tc2 Mais le jour des Azymes vint
\tr
\tcr1 ᾗ ἔδει \tc2 où il-fallait 
\tr
\tcr1 τὸ Πάσχα θύεσθαι \tc2 la Pâque être-sacrifiée. 
\m
\v 8
\tr
\tcr1 καὶ ἀπέστειλεν Πέτρον καὶ Ἰωάννην εἰπών \tc2 Et il-envoya Pierre et Jean disant : 
\tr
\tcr1 πορευθέντες \tc2 « Allant,
\tr
\tcr1 ἑτοιμάσατε τὸ Πάσχα ἡμῖν \tc2 préparez la Pâque pour-nous
\tr
\tcr1 ἵνα φάγωμεν \tc2 afin-que nous-mangions. »
\m
\v 9
\tr
\tcr1 δὲ οἱ εἶπαν αὐτῷ \tc2 Mais ils dirent à-lui : 
\tr
\tcr1 ποῦ θέλεις \tc2 « Où veux-tu \add que\add* 
\tr
\tcr1 ἑτοιμάσωμεν \tc2 nous-préparions ? »
\m
\v 10
\tr
\tcr1 δὲ ὁ εἶπεν αὐτοῖς \tc2 Mais il dit à-eux : 
\tr
\tcr1 ἰδοὺ \tc2 « Voici,
\tr
\tcr1 ὑμῶν εἰσελθόντων εἰς τὴν πόλιν \tc2 vous étant-entrés dans la ville,
\tr
\tcr1 ἄνθρωπος συναντήσει ὑμῖν \tc2 un-homme rencontrera vous
\tr
\tcr1 βαστάζων κεράμιον ὕδατος \tc2 portant un-vase d'eau, 
\tr
\tcr1 ἀκολουθήσατε αὐτῷ \tc2 suivez lui
\tr
\tcr1 εἰς τὴν οἰκίαν εἰς ἣν εἰσπορεύεται \tc2 dans la maison dans laquelle il-entre. 
\m
\v 11
\tr
\tcr1 καὶ ἐρεῖτε τῷ οἰκοδεσπότῃ τῆς οἰκίας \tc2 Et vous-direz au maître de-la maison : 
\tr
\tcr1 ὁ διδάσκαλος λέγει σοι \tc2 "Le maître dit à-toi : 
\tr
\tcr1 ποῦ ἐστιν τὸ κατάλυμα \tc2 'Où est le séjour,
\tr
\tcr1 ὅπου φάγω τὸ Πάσχα \tc2 là-où je-mangerai la Pâque
\tr
\tcr1 μετὰ τῶν μαθητῶν μου \tc2 avec les disciples de moi ?'"
\m
\v 12
\tr
\tcr1 κἀκεῖνος δείξει ὑμῖν \tc2 Et-celui-là montrera à-vous
\tr
\tcr1 μέγα ἀνάγαιον \tc2 une-grande pièce-à-l'étage
\tr
\tcr1 ἐστρωμένον \tc2 aménagée ;
\tr
\tcr1 ἐκεῖ ἑτοιμάσατε \tc2 là vous-préparerez. »
\m
\v 13
\tr
\tcr1 δὲ ἀπελθόντες \tc2 Mais étant-partis,
\tr
\tcr1 εὗρον καθὼς \tc2 ils-trouvèrent tout-comme 
\tr
\tcr1 εἰρήκει αὐτοῖς \tc2 il-avait-dit à-eux,
\tr
\tcr1 καὶ ἡτοίμασαν τὸ Πάσχα \tc2 et ils-préparèrent la Pâque. 
\m
\v 14
\tr
\tcr1 καὶ ὅτε ἡ ὥρα ἐγένετο \tc2 Et lorsque l' heure advint,
\tr
\tcr1 οἱ ἀπόστολοι ἀνέπεσεν καὶ \tc2 les apôtres se-couchèrent \add à table\add* aussi
\tr
\tcr1 σὺν αὐτῷ \tc2 avec lui. 
\m
\v 15
\tr
\tcr1 καὶ εἶπεν πρὸς αὐτούς \tc2 Et il-dit vers eux : 
\tr
\tcr1 ἐπεθύμησα ἐπιθυμίᾳ \tc2 « Je-désirai d'un-désir 
\tr
\tcr1 φαγεῖν τοῦτο τὸ Πάσχα \tc2 manger cette Pâque
\tr
\tcr1 μεθ’ ὑμῶν \tc2 avec vous,
\tr
\tcr1 πρὸ τοῦ με παθεῖν \tc2 avant le moi souffrir. 
\m
\v 16
\tr
\tcr1 γὰρ λέγω ὑμῖν ὅτι \tc2 Car je-dis à-vous que
\tr
\tcr1 οὐ μὴ φάγω \tc2 je ne mange certainement pas
\tr
\tcr1 αὐτὸ \tc2 elle,
\tr
\tcr1 ἕως ὅτου πληρωθῇ \tc2 jusqu'à \add ce\add* qu' elle-soit-accomplie
\tr
\tcr1 ἐν τῇ Βασιλείᾳ τοῦ Θεοῦ \tc2 dans le Royaume de Dieu. »
\m
\v 17
\tr
\tcr1 καὶ δεξάμενος ποτήριον \tc2 Et ayant-pris une-coupe,
\tr
\tcr1 εὐχαριστήσας εἶπεν \tc2 ayant-remercié il-dit : 
\tr
\tcr1 λάβετε τοῦτο καὶ διαμερίσατε \tc2 « Prenez ceci et partagez
\tr
\tcr1 εἰς ἑαυτούς \tc2 les uns envers les autres. 
\m
\v 18
\tr
\tcr1 γὰρ λέγω ὑμῖν \tc2 Car je-dis à-vous,
\tr
\tcr1 οὐ μὴ πίω \tc2 je ne boirai certainement pas
\tr
\tcr1 ἀπὸ τοῦ νῦν \tc2 dès maintenant
\tr
\tcr1 ἀπὸ τοῦ γενήματος \tc2 du produit 
\tr
\tcr1 τῆς ἀμπέλου \tc2 de-la vigne,
\tr
\tcr1 ἕως οὗ \tc2 jusqu'à \add ce\add* que 
\tr
\tcr1 ἡ Βασιλεία τοῦ Θεοῦ ἔλθῃ \tc2 le Royaume de Dieu vienne. »
\m
\v 19
\tr
\tcr1 καὶ λαβὼν ἄρτον \tc2 Et ayant-pris du-pain,
\tr
\tcr1 εὐχαριστήσας \tc2 ayant remercié,
\tr
\tcr1 ἔκλασεν καὶ ἔδωκεν αὐτοῖς λέγων \tc2 il-rompit et donna à-eux disant : 
\tr
\tcr1 τοῦτό ἐστιν τὸ σῶμά μου \tc2 « Ceci est le corps de-moi,
\tr
\tcr1 τὸ διδόμενον ὑπὲρ ὑμῶν \tc2 celui étant-donné pour vous,
\tr
\tcr1 ποιεῖτε τοῦτο \tc2 faites ceci 
\tr
\tcr1 εἰς τὴν ἐμὴν ἀνάμνησιν \tc2 en-vue-de ma mémoire. »
\m
\v 20
\tr
\tcr1 καὶ τὸ ποτήριον \tc2 Et la coupe
\tr
\tcr1 ὡσαύτως μετὰ τὸ δειπνῆσαι λέγων \tc2 de-même après le dîner disant : 
\tr
\tcr1 τοῦτο τὸ ποτήριον \tc2 « Cette coupe,
\tr
\tcr1 ἡ καινὴ διαθήκη \tc2 la nouvelle alliance
\tr
\tcr1 ἐν τῷ αἵματί μου \tc2 dans le sang de-moi,
\tr
\tcr1 τὸ ἐκχυννόμενον ὑπὲρ ὑμῶν \tc2 celle étant-répandue pour vous. 
\m
\v 21-22
\tr
\tcr1 πλὴν ἰδοὺ \tc2 Seulement voici,
\tr
\tcr1 ἡ χεὶρ τοῦ παραδιδόντος με \tc2 la main de-l' \add homme\add* livrant moi
\tr
\tcr1 μετ’ ἐμοῦ ἐπὶ τῆς τραπέζης \tc2 avec moi sur la table, 
\tr
\tcr1 ὅτι μὲν ὁ Υἱὸς τοῦ Ἀνθρώπου \tc2 que certes le Fils de-l' Homme
\tr
\tcr1 πορεύεται κατὰ τὸ ὡρισμένον \tc2 va selon cela ayant-été-déterminé,
\tr
\tcr1 πλὴν \tc2 seulement 
\tr
\tcr1 οὐαὶ ἐκείνῳ τῷ ἀνθρώπῳ \tc2 malheur à-cet homme-là
\tr
\tcr1 δι’ οὗ παραδίδοται \tc2 par qui il-est-livré. »
\m
\v 23
\tr
\tcr1 καὶ αὐτοὶ ἤρξαντο συνζητεῖν \tc2 Et ceux-ci commencèrent \add à\add* chercher
\tr
\tcr1 πρὸς ἑαυτοὺς \tc2 les uns envers les autres
\tr
\tcr1 τὸ τίς ἄρα ἐξ αὐτῶν εἴη \tc2 ce qui donc d' eux est
\tr
\tcr1 τοῦτο ὁ μέλλων πράσσειν \tc2 celui allant exécuter. 
\m
\v 24
\tr
\tcr1 δὲ ἐγένετο καὶ φιλονικία \tc2 Mais il-advint aussi une-querelle
\tr
\tcr1 ἐν αὐτοῖς \tc2 parmi eux,
\tr
\tcr1 τὸ τίς αὐτῶν δοκεῖ εἶναι \tc2 le qui d'eux pense être 
\tr
\tcr1 μείζων \tc2 \add le\add* plus-grand. 
\m
\v 25
\tr
\tcr1 δὲ ὁ εἶπεν αὐτοῖς \tc2 Mais il dit à-eux : 
\tr
\tcr1 οἱ βασιλεῖς τῶν ἐθνῶν \tc2 « Les rois des nations
\tr
\tcr1 κυριεύουσιν αὐτῶν \tc2 dominent eux,
\tr
\tcr1 καὶ οἱ ἐξουσιάζοντες αὐτῶν \tc2 et ceux exercant-l'autorité-sur eux
\tr
\tcr1 καλοῦνται εὐεργέται \tc2 sont-appelés bienfaiteurs. 
\m
\v 26
\tr
\tcr1 δὲ ὑμεῖς οὐχ οὕτως \tc2 Mais vous, pas ainsi, 
\tr
\tcr1 ἀλλ’ ὁ μείζων ἐν ὑμῖν \tc2 mais celui plus-grand parmi vous,
\tr
\tcr1 γενέσθω ὡς ὁ νεώτερος \tc2 \add qu'\add* il-devienne comme le plus-jeune,
\tr
\tcr1 καὶ ὁ ἡγούμενος \tc2 et celui ayant-autorité
\tr
\tcr1 ὡς ὁ διακονῶν \tc2 comme celui servant. 
\m
\v 27
\tr
\tcr1 γὰρ τίς μείζων \tc2 Car qui \add est\add* plus-grand,
\tr
\tcr1 ὁ ἀνακείμενος \tc2 celui étant-couché-à-table 
\tr
\tcr1 ἢ ὁ διακονῶν \tc2 ou celui servant ? 
\tr
\tcr1 οὐχὶ \tc2 N' \add est-ce\add* pas 
\tr
\tcr1 ὁ ἀνακείμενος \tc2 celui étant-couché-à-table ?
\tr
\tcr1 δὲ ἐγὼ \tc2 Mais moi 
\tr
\tcr1 εἰμι ἐν μέσῳ ὑμῶν \tc2 je-suis au milieu de-vous
\tr
\tcr1 ὡς ὁ διακονῶν \tc2 comme celui servant.
\m
\v 28
\tr
\tcr1 δέ ὑμεῖς \tc2 Mais vous 
\tr
\tcr1 ἐστε \tc2 vous-êtes 
\tr
\tcr1 οἱ διαμεμενηκότες \tc2 ceux ayant-demeuré-jusqu'au-bout
\tr
\tcr1 μετ’ ἐμοῦ \tc2 avec moi
\tr
\tcr1 ἐν τοῖς πειρασμοῖς μου \tc2 dans les épreuves de-moi.
\m
\v 29-30
\tr
\tcr1 κἀγὼ διατίθεμαι ὑμῖν \tc2 Et-moi je-dispose pour-vous,
\tr
\tcr1 καθὼς ὁ Πατήρ μου \tc2 tout-comme le Père de-moi
\tr
\tcr1 διέθετό βασιλείαν μοι \tc2 disposa \add le\add* royaume pour-moi,
\tr
\tcr1 ἵνα ἔσθητε καὶ πίνητε \tc2 afin-que vous-mangiez et buviez
\tr
\tcr1 ἐπὶ τῆς τραπέζης μου \tc2 sur la table de-moi
\tr
\tcr1 ἐν τῇ βασιλείᾳ μου \tc2 dans le royaume de-moi,
\tr
\tcr1 καὶ καθῆσθε ἐπὶ θρόνων \tc2 et vous-serez-assis sur des-trônes
\tr
\tcr1 κρίνοντες \tc2 jugeant 
\tr
\tcr1 τὰς δώδεκα φυλὰς τοῦ Ἰσραήλ \tc2 les douze tribus d' Israël.
\m
\v 31-32
\tr
\tcr1 Σίμων Σίμων \tc2 Simon, Simon,
\tr
\tcr1 ἰδοὺ \tc2 voici, 
\tr
\tcr1 ὁ Σατανᾶς ἐξῃτήσατο ὑμᾶς \tc2 Satan a-réclamé vous
\tr
\tcr1 τοῦ σινιάσαι ὡς τὸν σῖτον \tc2 \add pour\add* le passer-au-crible comme le blé,
\tr
\tcr1 δὲ ἐγὼ ἐδεήθην περὶ σοῦ \tc2 mais moi j'ai-prié au-sujet de-toi
\tr
\tcr1 ἵνα ἡ πίστις σου \tc2 afin-que la foi de-toi
\tr
\tcr1 μὴ ἐκλίπῃ \tc2 ne disparaisse pas ;
\tr
\tcr1 καὶ σύ ποτε ἐπιστρέψας \tc2 et toi lorsque étant-revenu,
\tr
\tcr1 στήρισον τοὺς ἀδελφούς σου \tc2 affermis les frères de-toi. »
\m
\v 33
\tr
\tcr1 δὲ ὁ εἶπεν αὐτῷ \tc2 Mais il a-dit à-lui : 
\tr
\tcr1 Κύριε \tc2 « Seigneur, 
\tr
\tcr1 εἰμι ἕτοιμός μετὰ σοῦ \tc2 je-suis prêt avec toi
\tr
\tcr1 πορεύεσθαι καὶ εἰς φυλακὴν \tc2 \add à\add* aller et en prison
\tr
\tcr1 καὶ εἰς θάνατον \tc2 et dans \add la\add* mort. »
\m
\v 34
\tr
\tcr1 δὲ ὁ εἶπεν \tc2 Mais il dit : 
\tr
\tcr1 λέγω σοι Πέτρε \tc2 « Je-dis à-toi, Pierre, 
\tr
\tcr1 ἀλέκτωρ \tc2 un coq
\tr
\tcr1 οὐ φωνήσει \tc2 ne criera pas
\tr
\tcr1 σήμερον \tc2 aujourd'hui,
\tr
\tcr1 ἕως ἀπαρνήσῃ τρίς \tc2 jusqu'à \add ce que\add* tu-renies trois \add fois\add*
\tr
\tcr1 εἰδέναι με \tc2 connaître moi. »
\m
\v 35
\tr
\tcr1 καὶ εἶπεν αὐτοῖς \tc2 Et il-dit à-eux : 
\tr
\tcr1 ὅτε ἀπέστειλα ὑμᾶς \tc2 « Lorsque j'envoyai vous
\tr
\tcr1 ἄτερ βαλλαντίου \tc2 sans bourse,
\tr
\tcr1 καὶ πήρας \tc2 et besace,
\tr
\tcr1 καὶ ὑποδημάτων \tc2 et souliers,
\tr
\tcr1 μή ὑστερήσατε \tc2 n'avez-vous pas manqué
\tr
\tcr1 τινος \tc2 de quelque chose ? »
\tr
\tcr1 δὲ οἱ εἶπαν \tc2 Mais ils dirent : 
\tr
\tcr1 οὐθενός \tc2 « De rien. »
\m
\v 36
\tr
\tcr1 δὲ εἶπεν αὐτοῖς \tc2 Mais il-dit à-eux : 
\tr
\tcr1 ἀλλὰ νῦν \tc2 « Mais maintenant, 
\tr
\tcr1 ὁ ἔχων βαλλάντιον \tc2 celui ayant une-bourse, 
\tr
\tcr1 ἀράτω \tc2 \add qu'\add* il \add la\add* porte, 
\tr
\tcr1 ὁμοίως καὶ πήραν \tc2 tout-comme aussi une-besace ;
\tr
\tcr1 καὶ ὁ \tc2 et celui
\tr
\tcr1 μὴ ἔχων \tc2 n'ayant pas,
\tr
\tcr1 πωλησάτω τὸ ἱμάτιον αὐτοῦ \tc2 \add qu'\add* il-vende le manteau de-lui,
\tr
\tcr1 καὶ ἀγορασάτω μάχαιραν \tc2 et achète un-grand-couteau. 
\m
\v 37
\tr
\tcr1 γὰρ λέγω ὑμῖν ὅτι \tc2 Car je-dis à-vous que
\tr
\tcr1 τοῦτο τὸ γεγραμμένον \tc2 ceci ayant-été-écrit
\tr
\tcr1 δεῖ τελεσθῆναι ἐν ἐμοί τό \tc2 doit être-accompli en moi, le : 
\tr
\tcr1 καὶ ἐλογίσθη μετὰ ἀνόμων \tc2 "Et il-fut-compté avec des-sans-lois"
\tr
\tcr1 καὶ γὰρ τὸ περὶ ἐμοῦ \tc2 et car la \add chose\add* au-sujet de-moi
\tr
\tcr1 ἔχει τέλος \tc2 a \add son\add* terme. »
\m
\v 38
\tr
\tcr1 δὲ οἱ εἶπαν \tc2 Mais ils dirent : 
\tr
\tcr1 Κύριε ἰδοὺ \tc2 « Seigneur, voici, 
\tr
\tcr1 ὧδε δύο μάχαιραι \tc2 ici deux grands-couteaux. »
\tr
\tcr1 δὲ ὁ εἶπεν αὐτοῖς \tc2 Mais il dit à-eux : 
\tr
\tcr1 ἐστιν ἱκανόν \tc2 « \add C'\add* est suffisant. »
\m
\v 39
\tr
\tcr1 καὶ ἐξελθὼν \tc2 Et étant-sortit,
\tr
\tcr1 ἐπορεύθη κατὰ τὸ ἔθος \tc2 il-partit selon l' habitude
\tr
\tcr1 εἰς τὸ Ὄρος τῶν Ἐλαιῶν \tc2 sur le Mont des Oliviers,
\tr
\tcr1 δὲ οἱ μαθηταί καὶ \tc2 mais les disciples aussi
\tr
\tcr1 ἠκολούθησαν αὐτῷ \tc2 suivirent lui. 
\m
\v 40
\tr
\tcr1 δὲ γενόμενος ἐπὶ τοῦ τόπου \tc2 Mais étant-advenu sur le lieu,
\tr
\tcr1 εἶπεν αὐτοῖς \tc2 il-dit à-eux : 
\tr
\tcr1 προσεύχεσθε \tc2 « Priez
\tr
\tcr1 μὴ εἰσελθεῖν εἰς πειρασμόν \tc2 \add pour\add* ne-pas entrer en tentation. »
\m
\v 41-42
\tr
\tcr1 καὶ αὐτὸς ἀπεσπάσθη ἀπ’ αὐτῶν \tc2 Et lui s'éloigna d' eux
\tr
\tcr1 ὡσεὶ βολήν λίθου \tc2 d'environ un-jet de-pierre,
\tr
\tcr1 καὶ θεὶς τὰ γόνατα \tc2 et disposant les genoux,
\tr
\tcr1 προσηύχετο λέγων \tc2 il-pria disant : 
\tr
\tcr1 Πάτερ εἰ βούλει \tc2 « Perre, si tu-veux,
\tr
\tcr1 παρένεγκε τοῦτο τὸ ποτήριον \tc2 emporte cette coupe
\tr
\tcr1 ἀπ’ ἐμοῦ \tc2 de moi,
\tr
\tcr1 πλὴν τὸ θέλημά μου \tc2 seulement, \add que\add* la volonté de-moi
\tr
\tcr1 μὴ γινέσθω \tc2 n'advienne pas,
\tr
\tcr1 ἀλλὰ τὸ σὸν \tc2 mais la tienne. 
\m
\v 43
\tr
\tcr1 δὲ ἄγγελος Ὤφθη αὐτῷ \tc2 Mais un-ange se-fit-voir à-lui
\tr
\tcr1 ἀπ’ οὐρανοῦ \tc2 du ciel,
\tr
\tcr1 ἐνισχύων αὐτόν \tc2 fortifiant lui. 
\m
\v 44
\tr
\tcr1 Καὶ γενόμενος ἐν ἀγωνίᾳ \tc2 Et étant-advenu en agonie, 
\tr
\tcr1 προσηύχετο ἐκτενέστερον \tc2 il-pria plus-intensément.
\tr
\tcr1 καὶ ὁ ἱδρὼς αὐτοῦ Ἐγένετο \tc2 Et la sueur de-lui advint
\tr
\tcr1 ὡσεὶ θρόμβοι αἵματος \tc2 comme des-grumeaux de-sang
\tr
\tcr1 καταβαίνοντες ἐπὶ τὴν γῆν \tc2 tombant sur la terre. 
\m
\v 45-46
\tr
\tcr1 καὶ ἀναστὰς ἀπὸ τῆς προσευχῆς \tc2 Et s'étant-levé de la prière,
\tr
\tcr1 ἐλθὼν πρὸς τοὺς μαθητὰς \tc2 étant-venu vers les disciples,
\tr
\tcr1 εὗρεν αὐτοὺς κοιμωμένους \tc2 il-trouva eux étant-couchés
\tr
\tcr1 ἀπὸ τῆς λύπης \tc2 par le chagrin,
\tr
\tcr1 καὶ εἶπεν αὐτοῖς \tc2 et il-dit à-eux : 
\tr
\tcr1 τί καθεύδετε \tc2 « Pourquoi dormez-vous ? »
\tr
\tcr1 προσεύχεσθε ἀναστάντες \tc2 Priez, \add vous\add* étant-levés,
\tr
\tcr1 ἵνα \tc2 afin que
\tr
\tcr1 μὴ εἰσέλθητε \tc2 vous n'entriez pas
\tr
\tcr1 εἰς πειρασμόν \tc2 en tentation. »
\m
\v 47
\tr
\tcr1 ἔτι αὐτοῦ λαλοῦντος \tc2 Encore lui parlant, 
\tr
\tcr1 ἰδοὺ \tc2 voici,
\tr
\tcr1 ὄχλος καὶ ὁ λεγόμενος Ἰούδας \tc2 une-foule et celui étant-dit Judas,
\tr
\tcr1 εἷς τῶν δώδεκα \tc2 un des douze,
\tr
\tcr1 προήρχετο αὐτούς \tc2 approcha eux
\tr
\tcr1 καὶ ἤγγισεν τῷ Ἰησοῦ \tc2 et approcha Jésus
\tr
\tcr1 φιλῆσαι αὐτόν \tc2 \add pour\add* embrasser lui. 
\m
\v 48
\tr
\tcr1 δὲ Ἰησοῦς εἶπεν αὐτῷ \tc2 Mais Jésus dit à-lui : 
\tr
\tcr1 Ἰούδα \tc2 « Judas,
\tr
\tcr1 παραδίδως τὸν Υἱὸν τοῦ Ἀνθρώπου \tc2 livres-tu le Fils de-l' Homme
\tr
\tcr1 φιλήματι \tc2 par un baiser ? »
\m
\v 49
\tr
\tcr1 δὲ οἱ περὶ αὐτὸν \tc2 Mais ceux autour-de lui
\tr
\tcr1 ἰδόντες τὸ ἐσόμενον \tc2 ayant-vu cela allant-être,
\tr
\tcr1 εἶπαν \tc2 dirent : 
\tr
\tcr1 Κύριε \tc2 « Seigneur,
\tr
\tcr1 εἰ πατάξομεν ἐν μαχαίρῃ \tc2 si nous-frapperons par \add le\add* grand-couteau ? »
\m
\v 50
\tr
\tcr1 καὶ εἷς τις ἐξ αὐτῶν \tc2 Et un certain de \add parmi\add* eux
\tr
\tcr1 ἐπάταξεν \tc2 frappa
\tr
\tcr1 τὸν δοῦλον τοῦ ἀρχιερέως \tc2 le serviteur du grand-prêtre,
\tr
\tcr1 καὶ ἀφεῖλεν \tc2 et enleva
\tr
\tcr1 τὸ οὖς τὸ δεξιόν αὐτοῦ \tc2 l' oreille droite de-lui. 
\m
\v 51
\tr
\tcr1 δὲ ὁ Ἰησοῦς ἀποκριθεὶς εἶπεν \tc2 Mais Jésus ayant-répondu dit : 
\tr
\tcr1 ἐᾶτε ἕως τούτου \tc2 « Renoncez jusqu'à cela ! »
\tr
\tcr1 καὶ ἁψάμενος τοῦ ὠτίου \tc2 Et ayant-touché l'oreille,
\tr
\tcr1 ἰάσατο αὐτόν \tc2 il-soigna lui. 
\m
\v 52
\tr
\tcr1 δὲ Ἰησοῦς εἶπεν \tc2 Mais Jésus dit 
\tr
\tcr1 πρὸς τοὺς παραγενομένους \tc2 vers ceux étant-à-côté
\tr
\tcr1 ἐπ’ αὐτὸν \tc2 sur lui,
\tr
\tcr1 ἀρχιερεῖς καὶ στρατηγοὺς τοῦ ἱεροῦ \tc2 chefs-des-prêtres et officiers du temple,
\tr
\tcr1 καὶ πρεσβυτέρους \tc2 et anciens : 
\tr
\tcr1 ἐξήλθατε \tc2 « Vous êtes sortis 
\tr
\tcr1 ὡς ἐπὶ λῃστὴν \tc2 comme pour un-brigand
\tr
\tcr1 μετὰ μαχαιρῶν \tc2 avec des-grands-couteaux 
\tr
\tcr1 καὶ ξύλων \tc2 et des-massues ?
\m
\v 53
\tr
\tcr1 μου ὄντος μεθ’ ὑμῶν \tc2 Moi étant avec vous
\tr
\tcr1 καθ’ ἡμέραν \tc2 chaque jour
\tr
\tcr1 ἐν τῷ ἱερῷ \tc2 dans le temple,
\tr
\tcr1 οὐκ ἐξετείνατε \tc2 vous n'avez pas déployé
\tr
\tcr1 τὰς χεῖρας \tc2 les mains
\tr
\tcr1 ἐπ’ ἐμέ \tc2 sur moi,
\tr
\tcr1 ἀλλ’ αὕτη ἐστὶν \tc2 mais celle-ci est
\tr
\tcr1 ἡ ὥρα ὑμῶν \tc2 l' heure de-vous
\tr
\tcr1 καὶ ἡ ἐξουσία τοῦ σκότους \tc2 et l' autorité de-l' obscurité. »
\m
\v 54
\tr
\tcr1 δὲ συνλαβόντες αὐτὸν \tc2 Et ayant-pris-ensemble lui,
\tr
\tcr1 ἤγαγον καὶ εἰσήγαγον \tc2 ils-emportèrent et firent-entrer
\tr
\tcr1 εἰς τὴν οἰκίαν τοῦ ἀρχιερέως \tc2 dans la maison du grand-prêtre.
\tr
\tcr1 δὲ ὁ Πέτρος \tc2 Mais Pierre
\tr
\tcr1 ἠκολούθει μακρόθεν \tc2 suivait de-loin. 
\m
\v 55
\tr
\tcr1 δὲ περιαψάντων πῦρ \tc2 Mais \add ceux-ci\add* ayant-allumé un-feu
\tr
\tcr1 ἐν μέσῳ τῆς αὐλῆς \tc2 au milieu de-la cour,
\tr
\tcr1 καὶ συνκαθισάντων \tc2 et s'étant-assis-ensemble,
\tr
\tcr1 ὁ Πέτρος ἐκάθητο \tc2 Pierre s'asseyait
\tr
\tcr1 μέσος αὐτῶν \tc2 au-milieu d'eux.
\m
\v 56
\tr
\tcr1 δὲ τις παιδίσκη \tc2 Mais une-certaine jeune-servante 
\tr
\tcr1 ἰδοῦσα \tc2 ayant vu
\tr
\tcr1 αὐτὸν καθήμενον \tc2 lui étant-assis
\tr
\tcr1 πρὸς τὸ φῶς \tc2 près de-la lumière,
\tr
\tcr1 καὶ αὐτῷ ἀτενίσασα \tc2 et l' ayant-regardé-fixement 
\tr
\tcr1 εἶπεν \tc2 dit :
\tr
\tcr1 οὗτος καὶ ἦν σὺν αὐτῷ \tc2 « Celui-ci aussi était avec lui. »
\m
\v 57
\tr
\tcr1 δὲ ὁ ἠρνήσατο λέγων \tc2 Mais il nia disant :
\tr
\tcr1 οὐκ οἶδα \tc2 « Je ne sais pas 
\tr
\tcr1 αὐτόν \tc2 lui,
\tr
\tcr1 γύναι \tc2 femme. »
\m
\v 58
\tr
\tcr1 καὶ μετὰ βραχὺ \tc2 Et après un-peu \add de temps\add*,
\tr
\tcr1 ἕτερος ἰδὼν αὐτὸν ἔφη \tc2 un-autre ayant-vu lui dit : 
\tr
\tcr1 σὺ καὶ \tc2 « Toi aussi,
\tr
\tcr1 εἶ ἐξ αὐτῶν \tc2 tu-es d' eux. »
\tr
\tcr1 δὲ ὁ Πέτρος ἔφη \tc2 Mais Pierre dit : 
\tr
\tcr1 ἄνθρωπε \tc2 « Homme,
\tr
\tcr1 οὐκ εἰμί \tc2 je ne suis pas. »
\m
\v 59
\tr
\tcr1 καὶ ὡσεὶ μιᾶς ὥρας διαστάσης \tc2 Et environ une heure s'étant-écoulée,
\tr
\tcr1 τις ἄλλος διϊσχυρίζετο λέγων \tc2 quelqu'un d'autre insista-fortement disant : 
\tr
\tcr1 ἐπ’ ἀληθείας \tc2 « Sur \add la\add* vérité
\tr
\tcr1 οὗτος καὶ ἦν μετ’ αὐτοῦ \tc2 celui-ci aussi était avec lui,
\tr
\tcr1 γὰρ ἐστιν καὶ Γαλιλαῖός \tc2 car il-est aussi Galiléen.
\m
\v 60
\tr
\tcr1 δὲ ὁ Πέτρος εἶπεν \tc2 Mais Pierre dit : 
\tr
\tcr1 ἄνθρωπε \tc2 « Homme, 
\tr
\tcr1 οὐκ οἶδα \tc2 je ne sais pas
\tr
\tcr1 ὃ λέγεις \tc2 \add ce\add* que tu-dis. »
\tr
\tcr1 καὶ παραχρῆμα \tc2 Et à-l'instant-même
\tr
\tcr1 αὐτοῦ λαλοῦντος ἔτι \tc2 lui parlant encore,
\tr
\tcr1 ἀλέκτωρ ἐφώνησεν \tc2 un-coq cria. 
\m
\v 61
\tr
\tcr1 καὶ στραφεὶς \tc2 Et s'étant-retourné,
\tr
\tcr1 ὁ Κύριος ἐνέβλεψεν τῷ Πέτρῳ \tc2 le Seigneur regarda Pierre,
\tr
\tcr1 καὶ ὁ Πέτρος ὑπεμνήσθη \tc2 et Pierre se-souvint
\tr
\tcr1 τοῦ ῥήματος τοῦ Κυρίου \tc2 de-la parole du Seigneur,
\tr
\tcr1 ὡς εἶπεν αὐτῷ ὅτι \tc2 comme il-dit à-lui : 
\tr
\tcr1 πρὶν ἀλέκτορα φωνῆσαι σήμερον \tc2 « Avant un-coq crier aujourd'hui,
\tr
\tcr1 ἀπαρνήσῃ με τρίς \tc2 tu-renieras moi trois \add fois\add*. »
\m
\v 62
\tr
\tcr1 καὶ ἐξελθὼν ἔξω \tc2 Et étant-sorti dehors,
\tr
\tcr1 ἔκλαυσεν πικρῶς \tc2 il-pleura amèrement.
\m
\v 63
\tr
\tcr1 καὶ οἱ ἄνδρες οἱ συνέχοντες αὐτὸν \tc2 Et les hommes tenant lui
\tr
\tcr1 ἐνέπαιζον αὐτῷ \tc2 se-moquaient de-lui 
\tr
\tcr1 δέροντες \tc2 \add le\add* châtiant. 
\m
\v 64
\tr
\tcr1 καὶ περικαλύψαντες αὐτὸν \tc2 Et ayant-enveloppé-dans-un-vêtement lui,
\tr
\tcr1 ἐπηρώτων λέγοντες \tc2 ils-interrogeaient disant : 
\tr
\tcr1 προφήτευσον \tc2 « Prophétise,
\tr
\tcr1 τίς ἐστιν ὁ παίσας σε \tc2 qui est celui ayant-frappé toi ? »
\m
\v 65
\tr
