\tr
\tcr1 ὅτι \tc2 que
\tr
\tcr1 οὐδείς ἐστιν \tc2 il n'y a personne
\tr
\tcr1 ὃς ἀφῆκεν \tc2 qui a-laissé
\tr
\tcr1 οἰκίαν ἢ γυναῖκα \tc2 une-maison ou une-femme,
\tr
\tcr1 ἢ ἀδελφοὺς ἢ γονεῖς \tc2 ou des-frères ou des-parents,
\tr
\tcr1 ἢ τέκνα \tc2 ou des-enfants,
\tr
\tcr1 εἵνεκεν τῆς Βασιλείας τοῦ Θεοῦ \tc2 à-cause du Royaume de Dieu,
\tr
\tcr1 ὃς \tc2 qui
\tr
\tcr1 οὐχὶ μὴ ἀπολάβῃ \tc2 ne reçoive pas
\tr
\tcr1 πολλαπλασίονα \tc2 plusieurs fois
\tr
\tcr1 ἐν τούτῳ τῷ καιρῷ \tc2 dans ce moment,
\tr
\tcr1 καὶ ζωὴν αἰώνιον \tc2 et \add la\add* vie éternelle,
\tr
\tcr1 ἐν τῷ αἰῶνι τῷ ἐρχομένῳ \tc2 et le siècle celui venant. »
\m
\v 31
\tr
\tcr1 δὲ παραλαβὼν τοὺς δώδεκα \tc2 Mais ayant-pris les douze,
\tr
\tcr1 εἶπεν πρὸς αὐτούς \tc2 il-a-dit vers eux : 
\tr
\tcr1 ἰδοὺ \tc2 « Voici,
\tr
\tcr1 ἀναβαίνομεν εἰς Ἰερουσαλήμ \tc2 nous-montons vers Jérusalem,
\tr
\tcr1 καὶ πάντα τὰ γεγραμμένα \tc2 et toutes les \add choses\add* ayant-été-écrites
\tr
\tcr1 διὰ τῶν προφητῶν \tc2 par les prophètes
\tr
\tcr1 τῷ Υἱῷ τοῦ Ἀνθρώπου \tc2 sur-le Fils de-l' Homme
\tr
\tcr1 τελεσθήσεται \tc2 seront accomplies. 
\m
\v 32
\tr
\tcr1 γὰρ παραδοθήσεται τοῖς ἔθνεσιν \tc2 Car il-sera-remis aux nations,
\tr
\tcr1 καὶ ἐμπαιχθήσεται \tc2 et il-sera-moqué,
\tr
\tcr1 καὶ ὑβρισθήσεται \tc2 et il-sera-injurié,
\tr
\tcr1 καὶ ἐμπτυσθήσεται \tc2 et il-sera-craché. 
\m
\v 33
\tr
\tcr1 καὶ μαστιγώσαντες ἀποκτενοῦσιν αὐτόν \tc2 Et ayant-fouetté ils-tueront lui,
\tr
\tcr1 καὶ ἀναστήσεται \tc2 et il-ressuscitera
\tr
\tcr1 τῇ ἡμέρᾳ τῇ τρίτῃ \tc2 au jour le troisième. »
\m
\v 34
\tr
\tcr1 καὶ αὐτοὶ \tc2 Et eux
\tr
\tcr1 οὐδὲν συνῆκαν \tc2 n'ont pas compris
\tr
\tcr1 τούτων \tc2 ces \add choses\add*,
\tr
\tcr1 καὶ τοῦτο τὸ ῥῆμα ἦν \tc2 et cette parole était
\tr
\tcr1 κεκρυμμένον ἀπ’ αὐτῶν \tc2 ayant-été-cachée d' eux,
\tr
\tcr1 καὶ \tc2 et
\tr
\tcr1 οὐκ ἐγίνωσκον \tc2 ils ne comprenaient pas
\tr
\tcr1 τὰ λεγόμενα \tc2 les \add choses\add* étant-dites. 
\m
\v 35
\tr
\tcr1 δὲ ἐγένετο \tc2 Mais il-est-advenu
\tr
\tcr1 ἐν τῷ αὐτὸν ἐγγίζειν \tc2 dans le lui s'approcher
\tr
\tcr1 εἰς Ἰερειχὼ \tc2 de Jéricho,
\tr
\tcr1 τις τυφλός ἐκάθητο \tc2 quelqu' aveugle était-assis
\tr
\tcr1 ἐπαιτῶν \tc2 mendiant
\tr
\tcr1 παρὰ τὴν ὁδὸν \tc2 le-long du chemin. 
\m
\v 36
\tr
\tcr1 δὲ ἀκούσας ὄχλου διαπορευομένου \tc2 Mais ayant-entendu une-foule passant,
\tr
\tcr1 ἐπυνθάνετο \tc2 il cherchait à savoir
\tr
\tcr1 τί εἴη τοῦτο \tc2 qu' était ceci. 
\m
\v 37
\tr
\tcr1 δὲ ἀπήγγειλαν αὐτῷ ὅτι \tc2 Mais ils-ont-annoncé à-lui que
\tr
\tcr1 Ἰησοῦς ὁ Ναζωραῖος παρέρχεται \tc2 Jésus le Nazaréen passe. 
\m
\v 38
\tr
\tcr1 καὶ ἐβόησεν λέγων \tc2 Et il-a-crié disant : 
\tr
\tcr1 Ἰησοῦ Υἱὲ Δαυείδ \tc2 « Jésus, Fils de-David,
\tr
\tcr1 ἐλέησόν με \tc2 aie-pitié-de moi ! »
\m
\v 39
\tr
\tcr1 καὶ οἱ προάγοντες \tc2 Et ceux avançant
\tr
\tcr1 ἐπετίμων αὐτῷ \tc2 réprimandaient lui,
\tr
\tcr1 ἵνα σιγήσῃ \tc2 afin-qu' il-se-taise. 
\tr
\tcr1 δὲ αὐτὸς ἔκραζεν \tc2 Mais lui criait
\tr
\tcr1 πολλῷ μᾶλλον \tc2 beaucoup plus : 
\tr
\tcr1 Υἱὲ Δαυείδ \tc2 « Fils de-David, 
\tr
\tcr1 ἐλέησόν με \tc2 aie-pitié-de moi ! »
\m
\v 40-41
\tr
\tcr1 δὲ ὁ Ἰησοῦς σταθεὶς \tc2 Mais Jésus s'étant-tenu
\tr
\tcr1 ἐκέλευσεν \tc2 a ordonné
\tr
\tcr1 αὐτὸν ἀχθῆναι πρὸς αὐτόν \tc2 lui être-porté vers lui.
\tr
\tcr1 δὲ αὐτοῦ ἐγγίσαντος \tc2 Mais lui s'étant-approché
\tr
\tcr1 ἐπηρώτησεν αὐτόν \tc2 a-interrogé lui : 
\tr
\tcr1 τί θέλεις \tc2 « Que veux-tu 
\tr
\tcr1 ποιήσω σοι \tc2 \add que\add* je-fasse pour-toi ? »
\tr
\tcr1 δὲ ὁ εἶπεν \tc2 Mais il a-dit : 
\tr
\tcr1 Κύριε \tc2 « Seigneur,
\tr
\tcr1 ἵνα ἀναβλέψω \tc2 que je-recouvre-la-vue. »
\m
\v 42
\tr
\tcr1 καὶ ὁ Ἰησοῦς εἶπεν αὐτῷ \tc2 Et Jésus a-dit à-lui : 
\tr
\tcr1 ἀνάβλεψον \tc2 « Recouvre la vue,
\tr
\tcr1 ἡ πίστις σου σέσωκέν σε \tc2 la foi de-toi a-sauvé toi. »
\m
\v 43
\tr
\tcr1 καὶ παραχρῆμα ἀνέβλεψεν \tc2 Et instantanément il-a-recouvré-la-vue,
\tr
\tcr1 καὶ ἠκολούθει αὐτῷ \tc2 et il-suivait lui,
\tr
\tcr1 δοξάζων τὸν Θεόν \tc2 glorifiant Dieu. 
\tr
\tcr1 καὶ πᾶς ὁ λαὸς ἰδὼν \tc2 Et toute la foule ayant-vu
\tr
\tcr1 ἔδωκεν αἶνον τῷ Θεῷ \tc2 a-donné une-louange à Dieu. 
\c 19
\m
\v 1
\tr
\tcr1 καὶ εἰσελθὼν \tc2 Et étant-entré,
\tr
\tcr1 διήρχετο τὴν Ἰερειχώ \tc2 il-traversait Jéricho.
\m
\v 2
\tr
\tcr1 καὶ ἰδοὺ \tc2 Et voici,
\tr
\tcr1 ἀνὴρ καλούμενος \tc2 un-homme étant-appelé 
\tr
\tcr1 ὀνόματι Ζακχαῖος \tc2 par-le-nom \add de\add* Zachée,
\tr
\tcr1 καὶ αὐτὸς ἦν ἀρχιτελώνης \tc2 et lui était chef-des-collecteurs-d'impôts,
\tr
\tcr1 καὶ αὐτὸς πλούσιος \tc2 et lui \add était\add* riche.
\m
\v 3
\tr
\tcr1 καὶ ἐζήτει ἰδεῖν τὸν Ἰησοῦν \tc2 Et il-cherchait \add à\add* voir Jésus,
\tr
\tcr1 τίς ἐστιν \tc2 qui il-est,
\tr
\tcr1 καὶ \tc2 et
\tr
\tcr1 οὐκ ἠδύνατο \tc2 il ne pouvait pas
\tr
\tcr1 ἀπὸ τοῦ ὄχλου \tc2 depuis la foule,
\tr
\tcr1 ὅτι ἦν μικρὸς τῇ ἡλικίᾳ \tc2 parce-qu' il-était petit par-la stature.
\m
\v 4
\tr
\tcr1 καὶ προδραμὼν \tc2 Et ayant-couru-en-avant
\tr
\tcr1 εἰς τὸ ἔμπροσθεν \tc2 au devant,
\tr
\tcr1 ἀνέβη ἐπὶ συκομορέαν \tc2 il-monta sur un-sycomore
\tr
\tcr1 ἵνα ἴδῃ αὐτόν \tc2 afin-qu' il-voie lui,
\tr
\tcr1 ὅτι ἤμελλεν διέρχεσθαι ἐκείνης \tc2 parce-que il-allait traverser ce \add chemin\add*.
\m
\v 5
\tr
\tcr1 καὶ ὡς ἦλθεν \tc2 Et comme il-vint
\tr
\tcr1 ἐπὶ τὸν τόπον \tc2 sur le lieu,
\tr
\tcr1 ὁ Ἰησοῦς ἀναβλέψας εἶπεν πρὸς αὐτόν \tc2 Jésus ayant-vu dit à lui :
\tr
\tcr1 Ζακχαῖε \tc2 « Zachée,
\tr
\tcr1 σπεύσας κατάβηθι \tc2 t'étant-pressé descends,
\tr
\tcr1 γὰρ σήμερον \tc2 car aujourd'hui
\tr
\tcr1 δεῖ με μεῖναι \tc2 il-faut moi rester
\tr
\tcr1 ἐν τῷ οἴκῳ σου \tc2 dans la maison de-toi. »
\m
\v 6
\tr
\tcr1 καὶ κατέβη σπεύσας \tc2 Et il-descendit s'étant-pressé,
\tr
\tcr1 καὶ ὑπεδέξατο αὐτὸν \tc2 et accueillit lui 
\tr
\tcr1 χαίρων \tc2 se-réjouissant. 
\m
\v 7
\tr
\tcr1 καὶ ἰδόντες \tc2 Et ayant-vu,
\tr
\tcr1 πάντες διεγόγγυζον λέγοντες ὅτι \tc2 tous murmuraient disant : 
\tr
\tcr1 εἰσῆλθεν καταλῦσαι \tc2 « Il-entra loger
\tr
\tcr1 παρὰ ἀνδρὶ ἁμαρτωλῷ \tc2 chez un-homme pécheur. »
\m
\v 8
\tr
\tcr1 δὲ σταθεὶς \tc2 Mais s'étant-tenu,
\tr
\tcr1 Ζακχαῖος εἶπεν πρὸς τὸν Κύριον \tc2 Zachée dit au Seigneur : 
\tr
\tcr1 ἰδοὺ Κύριε \tc2 « Voici Seigneur,
\tr
\tcr1 δίδωμι τοῖς πτωχοῖς \tc2 je-donne aux pauvres
\tr
\tcr1 τὰ ἡμίσιά τῶν ὑπαρχόντων μου \tc2 les moitiés des possédant de-moi,
\tr
\tcr1 καὶ εἴ ἐσυκοφάντησα \tc2 et si j'extorquai 
\tr
\tcr1 τι τινός \tc2 quelque \add chose\add* de-quelqu'un,
\tr
\tcr1 ἀποδίδωμι τετραπλοῦν \tc2 je-restitue \add le\add* quadruple. »
\m
\v 9-10
\tr
\tcr1 δὲ ὁ Ἰησοῦς \tc2 Mais Jésus
\tr
\tcr1 εἶπεν πρὸς αὐτὸν ὅτι \tc2 dit à lui :
\tr
\tcr1 σήμερον \tc2 « Aujourd'hui,
\tr
\tcr1 σωτηρία ἐγένετο \tc2 \add le\add* salut a-été
\tr
\tcr1 τούτῳ τῷ οἴκῳ \tc2 pour-cette maison,
\tr
\tcr1 καθότι \tc2 en ce que
\tr
\tcr1 αὐτὸς καὶ ἐστιν υἱὸς Ἀβραάμ \tc2 lui aussi est un-fils d'Abraham,
\tr
\tcr1 γὰρ ὁ Υἱὸς τοῦ Ἀνθρώπου \tc2 car le Fils de-l' Homme
\tr
\tcr1 ἦλθεν ζητῆσαι \tc2 vint chercher
\tr
\tcr1 καὶ σῶσαι τὸ ἀπολωλός \tc2 et sauver ce ayant-été-perdu. »
\m
\v 11
\tr
\tcr1 δὲ αὐτῶν ἀκουόντων ταῦτα \tc2 Mais eux entendant ces \add choses\add*,
\tr
\tcr1 εἶπεν προσθεὶς παραβολὴν \tc2 il-dit ajoutant une-parabole
\tr
\tcr1 διὰ τὸ \tc2 à-cause du-fait-de
\tr
\tcr1 αὐτὸν εἶναι ἐγγὺς Ἰερουσαλὴμ \tc2 lui être proche de-Jérusalem,
\tr
\tcr1 καὶ αὐτοὺς δοκεῖν ὅτι \tc2 et eux penser que
\tr
\tcr1 ἡ Βασιλεία τοῦ Θεοῦ \tc2 le Royaume de Dieu
\tr
\tcr1 μέλλει ἀναφαίνεσθαι παραχρῆμα \tc2 doit se-montrer sur-le-champ.
\m
\v 12
\tr
\tcr1 εἶπεν οὖν \tc2 Il-a-dit donc : 
\tr
\tcr1 τις ἄνθρωπός εὐγενὴς \tc2 « Un homme noble
\tr
\tcr1 ἐπορεύθη εἰς μακρὰν χώραν \tc2 alla dans un-grand champ
\tr
\tcr1 λαβεῖν βασιλείαν ἑαυτῷ \tc2 \add pour\add* recevoir un-royaume pour-lui-même
\tr
\tcr1 καὶ ὑποστρέψαι \tc2 et revenir. 
\m
\v 13
\tr
\tcr1 δὲ καλέσας δέκα δούλους ἑαυτοῦ \tc2 Mais ayant-appelé dix esclaves de-lui-même,
\tr
\tcr1 ἔδωκεν αὐτοῖς δέκα μνᾶς \tc2 il-donna à-eux dix mines,
\tr
\tcr1 καὶ εἶπεν πρὸς αὐτούς \tc2 et dit vers eux : 
\tr
\tcr1 πραγματεύσασθαι \tc2 "Du commerce être fait
\tr
\tcr1 ἐν ᾧ ἔρχομαι \tc2 durant \add le moment que\add* que je-viens."
\m
\v 14
\tr
\tcr1 δὲ οἱ πολῖται αὐτοῦ \tc2 Mais les citoyens de-lui
\tr
\tcr1 ἐμίσουν αὐτόν \tc2 détestaient lui,
\tr
\tcr1 καὶ ἀπέστειλαν ὀπίσω αὐτοῦ \tc2 et ils-envoyèrent devant lui
\tr
\tcr1 πρεσβείαν λέγοντες \tc2 une-ambassade disant : 
\tr
\tcr1 οὐ θέλομεν \tc2 "Nous ne voulons pas
\tr
\tcr1 τοῦτον βασιλεῦσαι \tc2 celui-ci régner
\tr
\tcr1 ἐφ’ ἡμᾶς \tc2 sur nous."
\m
\v 15
\tr
\tcr1 καὶ ἐγένετο \tc2 Et il-advint \add que\add*
\tr
\tcr1 αὐτὸν ἐν τῷ ἐπανελθεῖν \tc2 lui dans le revenir,
\tr
\tcr1 λαβόντα τὴν βασιλείαν \tc2 ayant-reçu le royaume
\tr
\tcr1 καὶ εἶπεν \tc2 et il-dit
\tr
\tcr1 τούτους τοὺς δούλους \tc2 ces serviteurs
\tr
\tcr1 φωνηθῆναι αὐτῷ \tc2 être-appelés à-lui,
\tr
\tcr1 οἷς δεδώκει τὸ ἀργύριον \tc2 à-qui il-a-donné l' argent
\tr
\tcr1 ἵνα γνοῖ \tc2 afin-qu' il-connaisse 
\tr
\tcr1 τί διεπραγματεύσαντο \tc2 \add ce\add* qui fut-gagné-dans-les-affaires.
\m
\v 16
\tr
\tcr1 δὲ ὁ πρῶτος παρεγένετο λέγων \tc2 Mais le premier parut disant : 
\tr
\tcr1 Κύριε \tc2 "Seigneur, 
\tr
\tcr1 ἡ μνᾶ σου προσηργάσατο \tc2 la mine de-toi fit-acquérir 
\tr
\tcr1 δέκα μνᾶς \tc2 dix mines."
\m
\v 17
\tr
\tcr1 καὶ εἶπεν αὐτῷ \tc2 Et il-dit à-lui : 
\tr
\tcr1 εὖ ἀγαθὲ δοῦλε \tc2 "Bien, bon serviteur !
\tr
\tcr1 ὅτι ἐγένου πιστὸς \tc2 Parce-que tu-fus fidèle
\tr
\tcr1 ἐν ἐλαχίστῳ \tc2 dans une-petite-chose,
\tr
\tcr1 ἴσθι ἔχων ἐξουσίαν \tc2 je-\add te\add*-place ayant autorité
\tr
\tcr1 ἐπάνω δέκα πόλεων \tc2 au-dessus-de dix villes." 
\m
\v 18
\tr
\tcr1 καὶ ὁ δεύτερος ἦλθεν λέγων \tc2 Et le deuxième vint disant : 
\tr
\tcr1 Κύριε \tc2 "Seigneur,
\tr
\tcr1 ἡ μνᾶ σου ἐποίησεν πέντε μνᾶς \tc2 la mine de-toi a-fait cinq mines." 
\m
\v 19
\tr
\tcr1 δὲ εἶπεν καὶ τούτῳ \tc2 Et il-dit aussi à-celui-ci : 
\tr
\tcr1 καὶ σὺ \tc2 "Et toi, 
\tr
\tcr1 γίνου ἐπάνω πέντε πόλεων \tc2 adviens au-dessus-de cinq villes." 
\m
\v 20
\tr
\tcr1 καὶ ὁ ἕτερος ἦλθεν λέγων \tc2 Et l' autre vint disant : 
\tr
\tcr1 Κύριε \tc2 "Seigneur,
\tr
\tcr1 ἰδοὺ ἡ μνᾶ σου \tc2 voici la mine de-toi
\tr
\tcr1 ἣν εἶχον ἀποκειμένην \tc2 que j'avais étant-placée
\tr
\tcr1 ἐν σουδαρίῳ \tc2 dans un-suaire.
\m
\v 21
\tr
\tcr1 γάρ ἐφοβούμην σε \tc2 Car je-craignais toi
\tr
\tcr1 ὅτι εἶ ἄνθρωπος αὐστηρὸς \tc2 parce-que tu-es un-homme sévère,
\tr
\tcr1 αἴρεις ὃ \tc2 tu-emportes \add ce\add* que tu ne plaças pas
\tr
\tcr1 οὐκ ἔθηκας \tc2 tu n'as pas placé
\tr
\tcr1 καὶ θερίζεις \tc2 et tu-moissonnes
\tr
\tcr1 ὃ \tc2 \add ce\add* que 
\tr
\tcr1 οὐκ ἔσπειρας \tc2  tu n'as pas semé."
\m
\v 22
\tr
\tcr1 λέγει αὐτῷ \tc2 Il-dit à-lui :
\tr
\tcr1 κρίνω σε \tc2 "Je-juge toi
\tr
\tcr1 ἐκ τοῦ στόματός σου \tc2 de la bouche de-toi,
\tr
\tcr1 πονηρὲ δοῦλε \tc2 mauvais serviteur,
\tr
\tcr1 ᾔδεις ὅτι \tc2 tu-savais que
\tr
\tcr1 ἐγὼ εἰμι ἄνθρωπος αὐστηρός \tc2 moi, je-suis un-homme sévère,
\tr
\tcr1 αἴρων ὃ \tc2 emportant \add ce\add* que 
\tr
\tcr1 οὐκ ἔθηκα \tc2 il n'a pas placé,
\tr
\tcr1 καὶ θερίζων ὃ \tc2 et moissonnant \add ce\add* que 
\tr
\tcr1 οὐκ ἔσπειρα \tc2 il n'a pas semé.
\m
\v 23
\tr
\tcr1 καὶ διὰ τί \tc2 Et à-cause-de quoi
\tr
\tcr1 οὐκ ἔδωκάς \tc2 n'as-tu pas donné
\tr
\tcr1 τὸ ἀργύριον μου \tc2 l' argent de-moi
\tr
\tcr1 ἐπὶ τράπεζαν \tc2 sur une-banque,
\tr
\tcr1 κἀγὼ ἐλθὼν \tc2 et-moi étant-venu
\tr
\tcr1 σὺν τόκῳ \tc2 avec un-intérêt
\tr
\tcr1 ἂν ἔπραξα αὐτὸ \tc2 si je-réclamai cela ?"
\m
\v 24
\tr
\tcr1 καὶ εἶπεν τοῖς παρεστῶσιν \tc2 Et il-dit à-ceux s'étant-tenus-à-côté : 
\tr
\tcr1 ἄρατε ἀπ’ αὐτοῦ τὴν μνᾶν \tc2 "Enlevez de lui la mine,
\tr
\tcr1 καὶ δότε τῷ ἔχοντι \tc2 et donnez à-celui ayant 
\tr
\tcr1 τὰς δέκα μνᾶς \tc2 les dix mines."
\m
\v 25
\tr
\tcr1 καὶ εἶπαν αὐτῷ \tc2 Et ils-dirent à-lui : 
\tr
\tcr1 Κύριε \tc2 "Seigneur,
\tr
\tcr1 ἔχει δέκα μνᾶς \tc2 il-a dix mines !"
\m
\v 26
\tr
\tcr1 λέγω ὑμῖν ὅτι \tc2 Je-dis à-vous que
\tr
\tcr1 δοθήσεται τῷ παντὶ ἔχοντι \tc2 il-sera-donné à quiconque ayant,
\tr
\tcr1 ἀπὸ δὲ τοῦ \tc2 mais de celui 
\tr
\tcr1 μὴ ἔχοντος \tc2 n'ayant pas,
\tr
\tcr1 ὃ ἔχει καὶ ἀρθήσεται \tc2 \add ce\add* qu' il-a aussi sera-enlevé. 
\m
\v 27
\tr
\tcr1 πλὴν \tc2 Seulement
\tr
\tcr1 τούτους τοὺς ἐχθρούς μου \tc2 ces ennemis de-moi,
\tr
\tcr1 τοὺς \tc2 ceux
\tr
\tcr1 μὴ θελήσαντάς \tc2 n'ayant pas voulu
\tr
\tcr1 με βασιλεῦσαι ἐπ’ αὐτοὺς \tc2 moi régner sur eux,
\tr
\tcr1 ἀγάγετε ὧδε \tc2 conduisez-\add les\add* ici,
\tr
\tcr1 καὶ κατασφάξατε αὐτοὺς \tc2 et égorgez eux
\tr
\tcr1 ἔμπροσθέν μου \tc2 devant moi. »
\m
\v 28
\tr
\tcr1 καὶ εἰπὼν ταῦτα \tc2 Et ayant-dit ces \add choses\add*,
\tr
\tcr1 ἐπορεύετο ἔμπροσθεν \tc2 il-alla devant,
\tr
\tcr1 ἀναβαίνων εἰς Ἱεροσόλυμα \tc2 montant à Jérusalem.
\m
\v 29-30
\tr
\tcr1 καὶ ἐγένετο ὡς ἤγγισεν \tc2 Et il-advient comme il-approcha
\tr
