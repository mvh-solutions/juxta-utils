\v 28-30
\tr
\tcr1 καὶ πάντες \tc2 Et tous
\tr
\tcr1 ἀκούοντες ταῦτα \tc2 entendant ces \add choses\add*
\tr
\tcr1 ἐπλήσθησαν θυμοῦ \tc2 ont-été-remplis de-colère
\tr
\tcr1 ἐν τῇ συναγωγῇ \tc2 dans la synagogue ;
\tr
\tcr1 καὶ ἀναστάντες \tc2 et s'étant-levés,
\tr
\tcr1 ἐξέβαλον αὐτὸν \tc2 ils-ont-chassé lui
\tr
\tcr1 ἔξω τῆς πόλεως \tc2 hors-de la ville
\tr
\tcr1 καὶ ἤγαγον αὐτὸν \tc2 et ils-ont-conduit lui
\tr
\tcr1 ἕως \tc2 jusqu'à 
\tr
\tcr1 ὀφρύος τοῦ ὄρους \tc2 un-escarpement de-la montagne,
\tr
\tcr1 ἐφ’ οὗ \tc2 sur laquelle
\tr
\tcr1 ἡ πόλις αὐτῶν \tc2 la ville d'eux
\tr
\tcr1 ᾠκοδόμητο \tc2 avait été bâtie,
\tr
\tcr1 ὥστε κατακρημνίσαι αὐτόν \tc2 pour précipiter lui ;
\tr
\tcr1 δὲ αὐτὸς \tc2 mais lui,
\tr
\tcr1 διελθὼν διὰ μέσου αὐτῶν \tc2 ayant-passé au milieu d'eux,
\tr
\tcr1 ἐπορεύετο \tc2 s'en allait.
\m
\v 31
\tr
\tcr1 καὶ κατῆλθεν \tc2 Et il-est-descendu
\tr
\tcr1 εἰς Καφαρναοὺμ \tc2 à Capharnaüm,
\tr
\tcr1 πόλιν τῆς Γαλιλαίας \tc2 ville de Galilée.
\tr
\tcr1 καὶ ἦν διδάσκων αὐτοὺς \tc2 Et il-était enseignant eux
\tr
\tcr1 ἐν τοῖς Σάββασιν \tc2 dans les jours-du-sabbat.
\m
\v 32
\tr
\tcr1 καὶ ἐξεπλήσσοντο \tc2 Et ils-étaient-frappés
\tr
\tcr1 ἐπὶ τῇ διδαχῇ αὐτοῦ \tc2 au-sujet de-l' enseignement de-lui
\tr
\tcr1 ὅτι ὁ λόγος αὐτοῦ \tc2 car la parole de-lui
\tr
\tcr1 ἦν ἐν ἐξουσίᾳ \tc2 était dans \add la\add* puissance.
\m
\v 33-34
\tr
\tcr1 καὶ ἐν τῇ συναγωγῇ \tc2 Et dans la synagogue
\tr
\tcr1 ἦν ἄνθρωπος \tc2 il-y-avait un-homme
\tr
\tcr1 ἔχων πνεῦμα \tc2 ayant un-esprit 
\tr
\tcr1 δαιμονίου ἀκαθάρτου \tc2 d'un-démon impur ;
\tr
\tcr1 καὶ ἀνέκραξεν φωνῇ μεγάλῃ \tc2 et il-criait d'une-voix forte :
\tr
\tcr1 ἔα \tc2 « Laisse \add -nous\add* !
\tr
\tcr1 τί \tc2 Qu' \add y a-t-il\add*
\tr
\tcr1 ἡμῖν καὶ σοί \tc2 pour-nous et pour-toi,
\tr
\tcr1 Ἰησοῦ Ναζαρηνέ \tc2 Jésus Nazaréen ?
\tr
\tcr1 ἦλθες \tc2 Es-tu venu
\tr
\tcr1 ἀπολέσαι ἡμᾶς \tc2 détruire nous ?
\tr
\tcr1 οἶδά \tc2 Je sais
\tr
\tcr1 σε τίς εἶ \tc2 toi qui tu-es,
\tr
\tcr1 ὁ Ἅγιος τοῦ Θεοῦ \tc2 le saint de Dieu. »
\m
\v 35
\tr
\tcr1 καὶ ὁ Ἰησοῦς \tc2 Et Jésus
\tr
\tcr1 ἐπετίμησεν αὐτῷ \tc2 a-fait-des-reproches à-lui
\tr
\tcr1 λέγων \tc2 disant :
\tr
\tcr1 φιμώθητι \tc2 « Sois muselé
\tr
\tcr1 καὶ ἔξελθε \tc2 et pars
\tr
\tcr1 ἀπ’ αὐτοῦ \tc2 de lui ! »
\tr
\tcr1 καὶ τὸ δαιμόνιον \tc2 Et le démon
\tr
\tcr1 ῥίψαν αὐτὸν \tc2 ayant-jeté lui
\tr
\tcr1 εἰς τὸ μέσον \tc2 au milieu,
\tr
\tcr1 ἐξῆλθεν ἀπ’ αὐτοῦ \tc2 est-parti de lui,
\tr
\tcr1 βλάψαν αὐτόν μηδὲν \tc2 ayant-blessé lui nullement.
\m
\v 36
\tr
\tcr1 καὶ ἐγένετο θάμβος \tc2 Et il-y-a-eu une-crainte
\tr
\tcr1 ἐπὶ πάντας \tc2 sur tous,
\tr
\tcr1 καὶ συνελάλουν \tc2 et ils-ont-discuté
\tr
\tcr1 πρὸς ἀλλήλους \tc2 les uns les autres
\tr
\tcr1 λέγοντες \tc2 disant :
\tr
\tcr1 τίς \tc2 « Quelle \add est\add*
\tr
\tcr1 οὗτος ὁ λόγος \tc2 cette parole,
\tr
\tcr1 ὅτι ἐπιτάσσει \tc2 car il-ordonne
\tr
\tcr1 ἐν ἐξουσίᾳ καὶ δυνάμει \tc2 avec autorité et puissance
\tr
\tcr1 τοῖς πνεύμασιν ἀκαθάρτοις \tc2 aux esprits impurs,
\tr
\tcr1 καὶ ἐξέρχονται \tc2 et ils-sortent ? »
\m
\v 37
\tr
\tcr1 καὶ ἦχος περὶ αὐτοῦ \tc2 Et un-bruit au-sujet de-lui
\tr
\tcr1 ἐξεπορεύετο \tc2 est sorti
\tr
\tcr1 εἰς πάντα τόπον \tc2 en tout endroit
\tr
\tcr1 τῆς περιχώρου \tc2 de-la \add région\add* avoisinante. 
\m
\v 38
\tr
\tcr1 δὲ ἀναστὰς \tc2 Et s'étant-levé
\tr
\tcr1 ἀπὸ τῆς συναγωγῆς \tc2 hors-de la synagogue,
\tr
\tcr1 εἰσῆλθεν \tc2 il est entré
\tr
\tcr1 εἰς τὴν οἰκίαν Σίμωνος \tc2 dans la maison de-Simon.
\tr
\tcr1 δὲ πενθερὰ τοῦ Σίμωνος \tc2 Or la-belle-mère de Simon
\tr
\tcr1 ἦν συνεχομένη \tc2 était étant-possédée
\tr
\tcr1 πυρετῷ μεγάλῳ \tc2 par-une-fièvre forte,
\tr
\tcr1 καὶ \tc2 et 
\tr
\tcr1 ἠρώτησαν αὐτὸν \tc2 ils-ont-interrogé lui
\tr
\tcr1 περὶ αὐτῆς \tc2 à-propos d'elle.
\m
\v 39
\tr
\tcr1 καὶ ἐπιστὰς \tc2 Et s'étant-tenu
\tr
\tcr1 ἐπάνω αὐτῆς \tc2 au-dessus d'elle,
\tr
\tcr1 ἐπετίμησεν τῷ πυρετῷ \tc2 il-a-blâmé la fièvre,
\tr
\tcr1 καὶ ἀφῆκεν αὐτήν \tc2 et elle-a-quitté elle ;
\tr
\tcr1 δὲ παραχρῆμα \tc2 et aussitôt,
\tr
\tcr1 ἀναστᾶσα \tc2 s'étant-levée,
\tr
\tcr1 διηκόνει αὐτοῖς \tc2 elle-servait eux.
\m
\v 40
\tr
\tcr1 δὲ τοῦ ἡλίου δύνοντος \tc2 Et le soleil se-couchant
\tr
\tcr1 ἅπαντες ὅσοι εἶχον \tc2 tous ceux-qui avaient
\tr
\tcr1 ἀσθενοῦντας \tc2 des \add gens\add* étant-affaiblis
\tr
\tcr1 ποικίλαις νόσοις \tc2 par-diverses maladies,
\tr
\tcr1 ἤγαγον αὐτοὺς \tc2 amenaient eux
\tr
\tcr1 πρὸς αὐτόν \tc2 vers lui,
\tr
\tcr1 δὲ ὁ \tc2 et lui
\tr
\tcr1 ἐπιτιθεὶς τὰς χεῖρας \tc2 ayant-imposé les mains
\tr
\tcr1 ἑνὶ ἑκάστῳ αὐτῶν \tc2 à-un chacun d'eux,
\tr
\tcr1 ἐθεράπευεν αὐτούς \tc2 a-guéri eux.
\m
\v 41
\tr
\tcr1 δὲ δαιμόνια καὶ \tc2 Et des-démons aussi
\tr
\tcr1 ἐξήρχετο \tc2 sortaient
\tr
\tcr1 ἀπὸ πολλῶν \tc2 de beaucoup \add de gens\add*,
\tr
\tcr1 κραυγάζοντα \tc2 criant
\tr
\tcr1 καὶ λέγοντα ὅτι \tc2 et disant :
\tr
\tcr1 σὺ εἶ \tc2 « Toi tu-es
\tr
\tcr1 ὁ Υἱὸς τοῦ Θεοῦ \tc2 le Fils de Dieu. »
\tr
\tcr1 καὶ ἐπιτιμῶν \tc2 Et blâmant \add eux\add*,
\tr
\tcr1 οὐκ εἴα \tc2 il ne laissait pas
\tr
\tcr1 αὐτὰ \tc2 eux
\tr
\tcr1 λαλεῖν ὅτι ᾔδεισαν \tc2 dire qu' ils-savaient
\tr
\tcr1 αὐτὸν εἶναι τὸν Χριστὸν \tc2 lui être le Christ.
\m
\v 42
\tr
\tcr1 δὲ ἡμέρας γενομένης \tc2 Et le-jour ayant-été,
\tr
\tcr1 ἐξελθὼν \tc2 étant-sorti
\tr
\tcr1 ἐπορεύθη εἰς τόπον ἔρημον \tc2 il-est-allé dans un-lieu désert,
\tr
\tcr1 καὶ οἱ ὄχλοι \tc2 et les foules
\tr
\tcr1 ἐπεζήτουν αὐτόν \tc2 cherchaient lui
\tr
\tcr1 καὶ ἦλθον ἕως αὐτοῦ \tc2 et sont-venues jusqu'à lui
\tr
\tcr1 καὶ κατεῖχον αὐτὸν \tc2 et retenaient lui
\tr
\tcr1 τοῦ \tc2 pour
\tr
\tcr1 μὴ πορεύεσθαι \tc2 ne pas s'en aller
\tr
\tcr1 ἀπ’ αὐτῶν \tc2 loin-d' eux.
\m
\v 43
\tr
\tcr1 δὲ ὁ εἶπεν \tc2 Mais lui a-dit
\tr
\tcr1 πρὸς αὐτοὺς ὅτι \tc2 à eux que :
\tr
\tcr1 δεῖ με \tc2 « Il-faut moi
\tr
\tcr1 εὐαγγελίσασθαί \tc2 annoncer la bonne nouvelle
\tr
\tcr1 τὴν Βασιλείαν τοῦ Θεοῦ \tc2 du Royaume de Dieu
\tr
\tcr1 καὶ ταῖς ἑτέραις πόλεσιν \tc2 aussi aux autres villes
\tr
\tcr1 ὅτι ἀπεστάλην \tc2 car j'ai-été-envoyé
\tr
\tcr1 ἐπὶ τοῦτο \tc2 pour cela.
\m
\v 44
\tr
\tcr1 καὶ ἦν κηρύσσων \tc2 Et il-était prêchant
\tr
\tcr1 εἰς τὰς συναγωγὰς \tc2 dans les synagogues
\tr
\tcr1 τῆς Ἰουδαίας \tc2 de Judée.
\c 5
\m
\v 1-2
\tr
\tcr1 δὲ ἐγένετο \tc2 Et il-arriva
\tr
\tcr1 ἐν τῷ τὸν ὄχλον \tc2 dans le \add temps que\add* la foule
\tr
\tcr1 ἐπικεῖσθαι αὐτῷ \tc2 presser lui
\tr
\tcr1 καὶ ἀκούειν τὸν λόγον τοῦ Θεοῦ \tc2 et écouter la parole de Dieu,
\tr
\tcr1 καὶ αὐτὸς ἦν ἑστὼς \tc2 et lui-même était se-tenant
\tr
\tcr1 παρὰ τὴν λίμνην Γεννησαρέτ \tc2 près du lac de-Génésareth,
\tr
\tcr1 καὶ εἶδεν δύο πλοῖα \tc2 et il-a-vu deux barques
\tr
\tcr1 ἑστῶτα παρὰ τὴν λίμνην \tc2 arrêtées près du lac,
\tr
\tcr1 δὲ οἱ ἁλιεῖς \tc2 et les pêcheurs
\tr
\tcr1 ἀποβάντες ἀπ’ αὐτῶν \tc2 étant-descendus d' elles
\tr
\tcr1 ἔπλυνον τὰ δίκτυα \tc2 lavaient les filets.
\m
\v 3
\tr
\tcr1 δὲ ἐμβὰς \tc2 Et étant-entré
\tr
\tcr1 εἰς ἓν τῶν πλοίων \tc2 dans une des barques,
\tr
\tcr1 ὃ ἦν Σίμωνος \tc2 qui était de-Simon,
\tr
\tcr1 ἠρώτησεν αὐτὸν \tc2 il-a-demandé à-lui
\tr
\tcr1 ἐπαναγαγεῖν ὀλίγον \tc2 de-retourner un-peu \add plus loin\add*
\tr
\tcr1 ἀπὸ τῆς γῆς \tc2 de la terre ;
\tr
\tcr1 δὲ καθίσας \tc2 et s'étant-assis,
\tr
\tcr1 ἐδίδασκεν τοὺς ὄχλους \tc2 il-enseignait les foules
\tr
\tcr1 ἐκ τοῦ πλοίου \tc2 depuis la barque.
\m
\v 4
\tr
\tcr1 δὲ ὡς ἐπαύσατο λαλῶν \tc2 Et comme il-a-cessé parlant,
\tr
\tcr1 εἶπεν πρὸς τὸν Σίμωνα \tc2 il-a-dit à Simon,
\tr
\tcr1 ἐπανάγαγε \tc2 « Retourne
\tr
\tcr1 εἰς τὸ βάθος \tc2 vers l' eau-profonde,
\tr
\tcr1 καὶ χαλάσατε τὰ δίκτυα ὑμῶν \tc2 et lâchez les filets de-vous
\tr
\tcr1 εἰς ἄγραν \tc2 pour la-pêche. »
\m
\v 5
\tr
\tcr1 καὶ ἀποκριθεὶς \tc2 Et ayant-répondu
\tr
\tcr1 Σίμων εἶπεν \tc2 Simon a-dit :
\tr
\tcr1 Ἐπιστάτα \tc2 « Maître,
\tr
\tcr1 κοπιάσαντες \tc2 étant fatigués
\tr
\tcr1 δι’ ὅλης νυκτὸς \tc2 durant toute la-nuit,
\tr
\tcr1 ἐλάβομεν οὐδὲν \tc2 nous-\add n'\add*-avons-pris rien,
\tr
\tcr1 δὲ ἐπὶ τῷ ῥήματί σου \tc2 mais sur la parole de-toi,
\tr
\tcr1 χαλάσω τὰ δίκτυα \tc2 je-lâcherai les filets. »
\m
\v 6
\tr
\tcr1 καὶ ποιήσαντες τοῦτο \tc2 Et ayant-fait cela,
\tr
\tcr1 συνέκλεισαν \tc2 ils ont renfermé
\tr
\tcr1 πλῆθος πολύ \tc2 une-multitude nombreuse 
\tr
\tcr1 ἰχθύων \tc2 de-poissons ;
\tr
\tcr1 δὲ τὰ δίκτυα αὐτῶν \tc2 et les filets d'eux
\tr
\tcr1 διερρήσσετο \tc2 se déchiraient.
\m
\v 7
\tr
\tcr1 καὶ κατένευσαν \tc2 Et ils-ont-fait-signe
\tr
\tcr1 τοῖς μετόχοις \tc2 aux compagnons
\tr
\tcr1 ἐν τῷ ἑτέρῳ πλοίῳ \tc2 dans l' autre barque,
\tr
\tcr1 τοῦ ἐλθόντας \tc2 pour-que \add eux\add* étant-venus
\tr
\tcr1 συνλαβέσθαι αὐτοῖς \tc2 aider eux ;
\tr
\tcr1 καὶ ἦλθον \tc2 et ils-sont-venus,
\tr
\tcr1 καὶ ἔπλησαν τὰ ἀμφότερα πλοῖα \tc2 et ils-ont-rempli les deux barques,
\tr
\tcr1 ὥστε αὐτά βυθίζεσθαι \tc2 de-sorte-qu' elles s'enfoncer.
\m
\v 8
\tr
\tcr1 δὲ Σίμων Πέτρος ἰδὼν \tc2 Et Simon Pierre ayant-vu
\tr
\tcr1 προσέπεσεν \tc2 est tombé
\tr
\tcr1 τοῖς γόνασιν Ἰησοῦ \tc2 aux genoux de-Jésus
\tr
\tcr1 λέγων \tc2 disant :
\tr
\tcr1 Κύριε \tc2 « Seigneur,
\tr
\tcr1 ἔξελθε ἀπ’ ἐμοῦ \tc2 pars loin-de moi,
\tr
\tcr1 ὅτι εἰμι \tc2 car je-suis
\tr
\tcr1 ἀνὴρ ἁμαρτωλός \tc2 un-homme pêcheur. »
\m
\v 9-10
\tr
\tcr1 γὰρ θάμβος \tc2 En-effet un-effroi
\tr
\tcr1 περιέσχεν αὐτὸν \tc2 a-enveloppé lui
\tr
\tcr1 καὶ πάντας τοὺς σὺν αὐτῷ \tc2 et tous ceux avec lui,
\tr
\tcr1 ἐπὶ τῇ ἄγρᾳ τῶν ἰχθύων \tc2 à-propos-de la capture des poissons
\tr
\tcr1 ὧν συνέλαβον \tc2 qu' ils-avaient-pris ;
\tr
\tcr1 δὲ ὁμοίως καὶ \tc2 et pareillement aussi
\tr
\tcr1 Ἰάκωβον καὶ Ἰωάννην \tc2 Jacques et Jean,
\tr
\tcr1 υἱοὺς Ζεβεδαίου \tc2 fils de-Zébédée,
\tr
\tcr1 οἳ ἦσαν \tc2 qui étaient
\tr
\tcr1 κοινωνοὶ τῷ Σίμωνι \tc2 des-compagnons pour Simon.
\tr
\tcr1 καὶ ὁ Ἰησοῦς \tc2 Et Jésus
\tr
\tcr1 εἶπεν πρὸς τὸν Σίμωνα \tc2 a-dit à Simon :
\tr
\tcr1 μὴ φοβοῦ \tc2 « Ne crains pas ;
\tr
\tcr1 ἀπὸ τοῦ νῦν \tc2 à-partir de maintenant
\tr
\tcr1 ἔσῃ ζωγρῶν \tc2 tu-seras prenant
\tr
\tcr1 ἀνθρώπους \tc2 des hommes. »
\m
\v 11
\tr
\tcr1 καὶ καταγαγόντες τὰ πλοῖα \tc2 Et ayant-ramené les barques
\tr
\tcr1 ἐπὶ τὴν γῆν \tc2 sur la terre,
\tr
\tcr1 ἀφέντες πάντα \tc2 laissant toutes \add choses\add*
\tr
\tcr1 ἠκολούθησαν αὐτῷ \tc2 ils-ont-suivi lui. 
\m
\v 12
\tr
\tcr1 καὶ ἐγένετο \tc2 Et il-arriva
\tr
\tcr1 ἐν τῷ αὐτὸν εἶναι \tc2 pendant que lui être
\tr
\tcr1 ἐν μιᾷ τῶν πόλεων \tc2 dans une des villes
\tr
\tcr1 καὶ ἰδοὺ \tc2 et voici,
\tr
\tcr1 ἀνὴρ πλήρης λέπρας \tc2 un-homme plein de-lèpre \add est venu\add*,
\tr
\tcr1 καὶ ἰδὼν τὸν Ἰησοῦν \tc2 et ayant-vu Jésus,
\tr
\tcr1 πεσὼν ἐπὶ πρόσωπον \tc2 étant-tombé sur la-face,
\tr
\tcr1 ἐδεήθη αὐτοῦ \tc2 il-a-prié lui
\tr
\tcr1 λέγων \tc2 disant :
\tr
\tcr1 Κύριε \tc2 « Seigneur,
\tr
\tcr1 ἐὰν θέλῃς \tc2 si tu-veux,
\tr
\tcr1 δύνασαί καθαρίσαι με \tc2 tu-peux purifier moi. »
\m
\v 13
\tr
\tcr1 καὶ ἐκτείνας τὴν χεῖρα \tc2 Et ayant-étendu la main,
\tr
\tcr1 ἥψατο αὐτοῦ \tc2 il-a-touché lui
\tr
\tcr1 λέγων \tc2 disant :
\tr
\tcr1 θέλω \tc2 « Je \add le\add* veux,
\tr
\tcr1 καθαρίσθητι \tc2 sois purifié. »
\tr
\tcr1 καὶ εὐθέως ἡ λέπρα \tc2 Et aussitôt la lèpre
\tr
\tcr1 ἀπῆλθεν ἀπ’ αὐτοῦ \tc2 s'est-en-allée de lui. 
\m
\v 14
\tr
\tcr1 καὶ αὐτὸς παρήγγειλεν αὐτῷ \tc2 Et lui-même commanda à-lui,
\tr
\tcr1 εἰπεῖν μηδενὶ \tc2 \add de ne le\add* dire à-personne,
\tr
\tcr1 ἀλλὰ ἀπελθὼν \tc2 « Mais t'en-étant-allé,
\tr
\tcr1 δεῖξον σεαυτὸν \tc2 montre toi-même
\tr
\tcr1 τῷ ἱερεῖ \tc2 au prêtre,
\tr
\tcr1 καὶ προσένεγκε \tc2 et offre
\tr
\tcr1 περὶ τοῦ καθαρισμοῦ σου \tc2 pour la purification de-toi
\tr
\tcr1 καθὼς Μωϋσῆς προσέταξεν \tc2 comme Moïse a-ordonné,
\tr
\tcr1 εἰς μαρτύριον αὐτοῖς \tc2 pour témoignage à-eux. »
\m
\v 15
\tr
\tcr1 δὲ ὁ λόγος περὶ αὐτοῦ \tc2 Et le discours sur lui
\tr
\tcr1 διήρχετο μᾶλλον \tc2 se-répandait davantage ;
\tr
\tcr1 καὶ ὄχλοι πολλοὶ \tc2 et des-foules nombreuses
\tr
\tcr1 συνήρχοντο ἀκούειν \tc2 se-rassemblaient \add pour l'\add* entendre
\tr
\tcr1 καὶ θεραπεύεσθαι \tc2 et être-guéries
\tr
\tcr1 ἀπὸ τῶν ἀσθενειῶν αὐτῶν \tc2 des maladies d'elles-mêmes.
\m
\v 16
\tr
\tcr1 δὲ αὐτὸς ἦν ὑποχωρῶν \tc2 Mais lui-même était se-retirant
\tr
\tcr1 ἐν ταῖς ἐρήμοις \tc2 dans les déserts
\tr
\tcr1 καὶ προσευχόμενος \tc2 et priant.
\m
\v 17
\tr
\tcr1 καὶ ἐγένετο \tc2 Et il-arriva
\tr
\tcr1 ἐν μιᾷ τῶν ἡμερῶν \tc2 dans un des jours,
\tr
\tcr1 καὶ αὐτὸς ἦν διδάσκων \tc2 et lui-même était enseignant,
\tr
\tcr1 καὶ Φαρισαῖοι \tc2 et des-Pharisiens 
\tr
\tcr1 καὶ νομοδιδάσκαλοι \tc2 et docteurs-de-la-loi
\tr
\tcr1 ἦσαν καθήμενοι \tc2 étaient assis,
\tr
\tcr1 οἳ ἦσαν ἐληλυθότες \tc2 qui étaient venus
\tr
\tcr1 ἐκ πάσης κώμης \tc2 de tout village
\tr
\tcr1 τῆς Γαλιλαίας \tc2 de Galilée
\tr
\tcr1 καὶ Ἰουδαίας καὶ Ἰερουσαλήμ \tc2 et de-Judée et de-Jérusalem.
\tr
\tcr1 καὶ δύναμις Κυρίου \tc2 Et une-puissance du-Seigneur
\tr
\tcr1 ἦν εἰς τὸ \tc2 était pour le \add fait que\add*
\tr
\tcr1 αὐτόν ἰᾶσθαι \tc2 lui guérir.
\m
\v 18
\tr
\tcr1 καὶ ἰδοὺ \tc2 Et voici,
\tr
\tcr1 ἄνδρες φέροντες \tc2 des-hommes portant
\tr
