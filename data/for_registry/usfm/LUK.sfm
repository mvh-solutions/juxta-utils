\tr
\tcr1 ἀποκτενοῦσιν καὶ διώξουσιν \tc2 ils-tueront et persécuteront
\tr
\tcr1 ἵνα ἐκζητηθῇ \tc2 afin-que il-soit-demandé-des-comptes
\tr
\tcr1 τὸ αἷμα πάντων τῶν προφητῶν \tc2 du sang de-tous les prophètes,
\tr
\tcr1 τὸ ἐκχυννόμενον \tc2 celui étant-blâmé 
\tr
\tcr1 ἀπὸ καταβολῆς κόσμου \tc2 depuis \add la\add* fondation du-monde
\tr
\tcr1 ἀπὸ ταύτης τῆς γενεᾶς \tc2 de cette génération,
\tr
\tcr1 ἀπὸ αἵματος Ἂβελ \tc2 du sang d'Abel
\tr
\tcr1 ἕως αἵματος Ζαχαρίου \tc2 jusqu'au sang de-Zacharie
\tr
\tcr1 τοῦ ἀπολομένου \tc2 celui ayant-été-tué
\tr
\tcr1 μεταξὺ τοῦ θυσιαστηρίου \tc2 entre l' autel
\tr
\tcr1 καὶ τοῦ οἴκου \tc2 et la maison,
\tr
\tcr1 ναί λέγω ὑμῖν \tc2 oui je-dis à-vous,
\tr
\tcr1 ἐκζητηθήσεται \tc2 il sera demandé des comptes
\tr
\tcr1 ἀπὸ ταύτης τῆς γενεᾶς \tc2 de cette génération. 
\m
\v 52
\tr
\tcr1 οὐαὶ ὑμῖν τοῖς νομικοῖς \tc2 Malheur à-vous les spécialistes-de-la-loi,
\tr
\tcr1 ὅτι \tc2 parce que 
\tr
\tcr1 ἤρατε τὴν κλεῖδα τῆς γνώσεως \tc2 vous-enlevez la clef de-la connaissance,
\tr
\tcr1 οὐκ εἰσήλθατε \tc2 vous n'êtes pas entrés
\tr
\tcr1 αὐτοὶ \tc2 vous mêmes,
\tr
\tcr1 καὶ ἐκωλύσατε \tc2 et vous-avez-repoussé
\tr
\tcr1 τοὺς εἰσερχομένους \tc2 ceux entrant. »
\m
\v 53-54
\tr
\tcr1 κἀκεῖθεν αὐτοῦ ἐξελθόντος \tc2 Et-de-là lui étant-sorti,
\tr
\tcr1 οἱ γραμματεῖς καὶ οἱ Φαρισαῖοι \tc2 les scribes et les Pharisiens
\tr
