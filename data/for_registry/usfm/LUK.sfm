\tcr1 τὸν οὐρανὸν καὶ τὴν γῆν \tc2 le ciel et la terre
\tr
\tcr1 παρελθεῖν \tc2 passer
\tr
\tcr1 ἢ μίαν κερέαν τοῦ νόμου \tc2 qu' un-seul trait de-la loi
\tr
\tcr1 πεσεῖν \tc2 tomber. 
\m
\v 18
\tr
\tcr1 πᾶς ὁ ἀπολύων \tc2 Tout celui rejetant
\tr
\tcr1 τὴν γυναῖκα αὐτοῦ \tc2 la femme de-lui
\tr
\tcr1 καὶ γαμῶν ἑτέραν \tc2 et épousant une-autre 
\tr
\tcr1 μοιχεύει \tc2 est adultère,
\tr
\tcr1 καὶ ὁ γαμῶν \tc2 et l' \add homme\add* épousant
\tr
\tcr1 ἀπολελυμένην \tc2 une \add femme\add* rejetée
\tr
\tcr1 ἀπὸ ἀνδρὸς \tc2 par \add son\add* mari,
\tr
\tcr1 μοιχεύει \tc2 est adultère.
\m
\v 19
\tr
\tcr1 δέ τις ἄνθρωπος ἦν πλούσιος \tc2 Mais quelqu' homme était riche,
\tr
\tcr1 καὶ ἐνεδιδύσκετο \tc2 et s'est-revêtu
\tr
\tcr1 πορφύραν καὶ βύσσον \tc2 de-pourpre et de-fin-lin,
\tr
\tcr1 εὐφραινόμενος λαμπρῶς \tc2 se-réjouissant splendidement
\tr
\tcr1 καθ’ ἡμέραν \tc2 chaque jour. 
\m
\v 20-21
\tr
\tcr1 δέ τις πτωχὸς \tc2 Mais quelque pauvre 
\tr
\tcr1 ὀνόματι Λάζαρος \tc2 au-nom de-Lazare,
\tr
\tcr1 ἐβέβλητο \tc2 s'est jeté
\tr
\tcr1 πρὸς τὸν πυλῶνα αὐτοῦ \tc2 vers le portail de-lui,
\tr
\tcr1 εἱλκωμένος καὶ ἐπιθυμῶν \tc2 étant-traînant et désirant
\tr
\tcr1 χορτασθῆναι \tc2 être nourri
\tr
\tcr1 ἀπὸ τῶν πιπτόντων \tc2 avec les \add choses\add* tombant
\tr
\tcr1 ἀπὸ τῆς τραπέζης τοῦ πλουσίου \tc2 de la table du riche,
\tr
\tcr1 ἀλλὰ καὶ οἱ κύνες ἐρχόμενοι \tc2 mais aussi les chiens venant
\tr
\tcr1 ἐπέλειχον τὰ ἕλκη αὐτοῦ \tc2 léchaient les ulcères de-lui. 
\m
\v 22
\tr
\tcr1 δὲ ἐγένετο \tc2 Mais il-est-advenu 
\tr
\tcr1 τὸν πτωχὸν ἀποθανεῖν \tc2 le pauvre mourir,
\tr
\tcr1 καὶ αὐτὸν ἀπενεχθῆναι \tc2 et lui être-emporté
\tr
\tcr1 ὑπὸ τῶν ἀγγέλων \tc2 par les anges
\tr
\tcr1 εἰς τὸν κόλπον Ἀβραάμ \tc2 dans le sein d'Abraham. 
\tr
\tcr1 δὲ ὁ πλούσιος καὶ ἀπέθανεν \tc2 Or le riche aussi est-mort
\tr
\tcr1 καὶ ἐτάφη \tc2 et a-été-enterré. 
\m
\v 23
\tr
\tcr1 καὶ ἐπάρας \tc2 Et ayant-levé
\tr
\tcr1 τοὺς ὀφθαλμοὺς αὐτοῦ \tc2 les yeux de-lui
\tr
\tcr1 ἐν τῷ ᾍδῃ \tc2 dans l' Hadès, 
\tr
\tcr1 ὑπάρχων ἐν βασάνοις \tc2 étant en tortures,
\tr
\tcr1 ὁρᾷ Ἀβραὰμ ἀπὸ μακρόθεν \tc2 il-voit Abraham de loin,
\tr
\tcr1 καὶ Λάζαρον \tc2 et Lazare
\tr
\tcr1 ἐν τοῖς κόλποις αὐτοῦ \tc2 dans les seins de-lui.
\m
\v 24
\tr
\tcr1 καὶ αὐτὸς φωνήσας εἶπεν \tc2 Et lui ayant-appelé a-dit : 
\tr
\tcr1 Πάτερ Ἀβραάμ \tc2 "Père Abraham, 
\tr
\tcr1 ἐλέησόν με \tc2 aie-pitié-de moi
\tr
\tcr1 καὶ πέμψον Λάζαρον \tc2 et envoie Lazare,
\tr
\tcr1 ἵνα βάψῃ ὕδατος \tc2 afin-qu' il-trempe d'eau
\tr
\tcr1 τὸ ἄκρον τοῦ δακτύλου αὐτοῦ \tc2 le bout du doigt de-lui, 
\tr
\tcr1 καὶ καταψύξῃ τὴν γλῶσσάν μου \tc2 et refroidisse la langue de-moi, 
\tr
\tcr1 ὅτι ὀδυνῶμαι \tc2 parce-que je-suis-affligé
\tr
\tcr1 ἐν ταύτῃ τῇ φλογὶ \tc2 dans cette flamme." 
\m
\v 25
\tr
\tcr1 δὲ Ἀβραάμ εἶπεν \tc2 Mais Abraham a-dit : 
\tr
\tcr1 τέκνον μνήσθητι ὅτι \tc2 "Enfant, souviens-toi que
\tr
\tcr1 ἀπέλαβες τὰ ἀγαθά σου \tc2 tu-as-reçu les bonnes \add choses\add* de-toi
\tr
\tcr1 ἐν τῇ ζωῇ σου \tc2 dans la vie de-toi,
\tr
\tcr1 καὶ Λάζαρος ὁμοίως \tc2 et Lazare de-même
\tr
\tcr1 τὰ κακά \tc2 les \add choses\add* mauvaises." 
\tr
\tcr1 δὲ νῦν παρακαλεῖται ὧδε \tc2 Mais maintenant il-est-invité ici,
\tr
\tcr1 δὲ σὺ ὀδυνᾶσαι \tc2 mais toi tu-es-affligé. 
\m
\v 26
\tr
\tcr1 καὶ ἐν πᾶσι τούτοις \tc2 Et en toutes ces \add choses\add*, 
\tr
\tcr1 μέγα χάσμα ἐστήρικται \tc2 un-grand abîme a-été-fixé
\tr
\tcr1 μεταξὺ ἡμῶν καὶ ὑμῶν \tc2 entre nous et vous,
\tr
\tcr1 ὅπως οἱ θέλοντες διαβῆναι \tc2 de-sorte-que ceux voulant traverser
\tr
\tcr1 ἔνθεν πρὸς ὑμᾶς \tc2 de-là-même vers vous
\tr
\tcr1 μὴ δύνωνται \tc2 ne peuvent pas,
\tr
\tcr1 μηδὲ διαπερῶσιν \tc2 ni-ne traversent
\tr
\tcr1 ἐκεῖθεν πρὸς ἡμᾶς \tc2 de-là vers nous."
\m
\v 27-28
\tr
\tcr1 δέ εἶπεν \tc2 Mais il-a-dit : 
\tr
\tcr1 ἐρωτῶ οὖν σε \tc2 "Je-demande donc toi,
\tr
\tcr1 Πάτερ \tc2 Père,
\tr
\tcr1 ἵνα πέμψῃς αὐτὸν \tc2 afin-que tu-envoies lui
\tr
\tcr1 εἰς τὸν οἶκον τοῦ πατρός μου \tc2 dans la maison du père de-moi,
\tr
\tcr1 γὰρ ἔχω πέντε ἀδελφούς \tc2 car j'ai cinq frères,
\tr
\tcr1 ὅπως διαμαρτύρηται αὐτοῖς \tc2 pour-qu' il-soit-témoigné à-eux,
\tr
\tcr1 ἵνα αὐτοὶ καὶ \tc2 afin-que eux aussi
\tr
\tcr1 μὴ ἔλθωσιν \tc2 ne viennent pas
\tr
\tcr1 εἰς τοῦτον τὸν τόπον \tc2 dans ce lieu
\tr
\tcr1 τῆς βασάνου \tc2 de torture."
\m
\v 29
\tr
\tcr1 δὲ Ἀβραάμ λέγει \tc2 Mais Abraham dit : 
\tr
\tcr1 ἔχουσι Μωϋσέα καὶ τοὺς προφήτας \tc2 "Ils-ont Moïse et les prophètes,
\tr
\tcr1 ἀκουσάτωσαν αὐτῶν \tc2 \add qu'\add* ils-écoutent eux." 
\m
\v 30
\tr
\tcr1 δὲ ὁ εἶπεν \tc2 Mais il a-dit : 
\tr
\tcr1 οὐχί Πάτερ Ἀβραάμ \tc2 "Non Père Abraham,
\tr
\tcr1 ἀλλ’ ἐάν τις \tc2 mais si quelqu'un
\tr
\tcr1 πορευθῇ πρὸς αὐτοὺς \tc2 serait-venu vers eux
\tr
\tcr1 ἀπὸ νεκρῶν \tc2 de-chez \add les\add* morts,
\tr
\tcr1 μετανοήσουσιν \tc2 ils se repentiront." 
\m
\v 31
\tr
\tcr1 δὲ εἶπεν αὐτῷ \tc2 Mais il-a-dit à-lui : 
\tr
\tcr1 οὐδ’ ἐάν \tc2 "Même si
\tr
\tcr1 τις ἀναστῇ ἐκ νεκρῶν \tc2 quelqu'un se-relève des morts,
\tr
\tcr1 εἰ \tc2 si
\tr
\tcr1 οὐκ ἀκούουσιν \tc2 ils n'écoutent pas
\tr
\tcr1 Μωϋσέως καὶ τῶν προφητῶν \tc2 Moïse et les prophètes,
\tr
\tcr1 πεισθήσονται \tc2 \add ils ne\add* seront \add pas\add* convaincus." »
\c 17
\m
\v 1
\tr
\tcr1 δὲ εἶπεν \tc2 Mais il-a-dit 
\tr
\tcr1 πρὸς τοὺς μαθητὰς αὐτοῦ \tc2 vers les disciples de-lui : 
\tr
\tcr1 ἐστιν ἀνένδεκτόν \tc2 « Il-est impossible
\tr
\tcr1 τοῦ τὰ σκάνδαλα \tc2 le \add fait que\add* les sandales
\tr
\tcr1 μὴ ἐλθεῖν \tc2 ne-pas venir,
\tr
\tcr1 πλὴν οὐαὶ \tc2 seulement malheur \add à celui\add*
\tr
\tcr1 δι’ οὗ ἔρχεται \tc2 par qui ils-viennent !
\m
\v 2
\tr
\tcr1 λυσιτελεῖ αὐτῷ \tc2 Il-est-avantageux pour-lui
\tr
\tcr1 εἰ λίθος μυλικὸς περίκειται \tc2 si une-pierre de-meule est-entourée
\tr
\tcr1 περὶ τὸν τράχηλον αὐτοῦ \tc2 autour du cou de-lui,
\tr
\tcr1 ἔρριπται καὶ \tc2 \add qu'\add* il-soit-jeté aussi
\tr
\tcr1 εἰς τὴν θάλασσαν \tc2 dans la mer,
\tr
\tcr1 ἢ ἵνα σκανδαλίσῃ \tc2 plutôt qu' il-scandalise
\tr
\tcr1 ἕνα τούτων τῶν μικρῶν \tc2 un de-ces petits. 
\m
\v 3
\tr
\tcr1 προσέχετε \tc2 Tenez 
\tr
\tcr1 ἑαυτοῖς \tc2 à-vous-mêmes !
\tr
\tcr1 ἐὰν ὁ ἀδελφός σου ἁμάρτῃ \tc2 Si le frère de-toi pèche,
\tr
\tcr1 ἐπιτίμησον αὐτῷ \tc2 reproche à-lui,
\tr
\tcr1 καὶ ἐὰν μετανοήσῃ \tc2 et s' il-se-repent,
\tr
\tcr1 ἄφες αὐτῷ \tc2 pardonne à-lui.
\m
\v 4
\tr
\tcr1 καὶ ἐὰν ἁμαρτήσῃ \tc2 Et s' il-pèche
\tr
\tcr1 ἑπτάκις τῆς ἡμέρας \tc2 sept-fois de-la journée
\tr
\tcr1 εἰς σὲ \tc2 envers toi,
\tr
\tcr1 καὶ ἐπιστρέψῃ ἑπτάκις \tc2 et se-repent sept-fois
\tr
\tcr1 πρὸς σὲ \tc2 vers toi,
\tr
\tcr1 λέγων μετανοῶ \tc2 disant : "Je-me-repens",
\tr
\tcr1 ἀφήσεις αὐτῷ \tc2 tu-pardonneras à-lui. »
\m
\v 5
\tr
\tcr1 καὶ οἱ ἀπόστολοι εἶπαν \tc2 Et les apôtres ont-dit
\tr
\tcr1 τῷ Κυρίῳ \tc2 au Seigneur : 
\tr
\tcr1 πρόσθες \tc2 « Augmente 
\tr
\tcr1 πίστιν ἡμῖν \tc2 \add la\add* foi à-nous ! »
\m
\v 6
\tr
\tcr1 δὲ ὁ Κύριος εἶπεν \tc2 Mais le Seigneur a-dit : 
\tr
\tcr1 εἰ ἔχετε πίστιν \tc2 « Si vous-avez une-foi
\tr
\tcr1 ὡς κόκκον σινάπεως \tc2 comme un-grain de-sénevé,
\tr
\tcr1 ἂν ἐλέγετε \tc2 si vous-disiez 
\tr
\tcr1 ταύτῃ τῇ συκαμίνῳ \tc2 à-ce mûrier : 
\tr
\tcr1 ἐκριζώθητι καὶ φυτεύθητι \tc2 "Sois-déraciné et sois-planté
\tr
\tcr1 ἐν τῇ θαλάσσῃ \tc2 dans la mer",
\tr
\tcr1 ἂν ὑπήκουσεν καὶ ὑμῖν \tc2 il-obéirait aussi à-vous. 
\m
\v 7
\tr
\tcr1 δὲ τίς ἐξ ὑμῶν \tc2 Mais qui parmi vous
\tr
\tcr1 ἔχων δοῦλον \tc2 ayant un-serviteur, 
\tr
\tcr1 ἀροτριῶντα ἢ ποιμαίνοντα \tc2 labourant ou paissant,
\tr
\tcr1 ὃς εἰσελθόντι ἐκ τοῦ ἀγροῦ \tc2 qui étant-venu depuis le champ
\tr
\tcr1 ἐρεῖ αὐτῷ \tc2 dira à-lui : 
\tr
\tcr1 παρελθὼν εὐθέως \tc2 "Viens, tout-de-suite,
\tr
\tcr1 ἀνάπεσε \tc2 mets-toi à table" ? 
\m
\v 8
\tr
\tcr1 ἀλλ’ \tc2 Mais 
\tr
\tcr1 οὐχὶ ἐρεῖ \tc2 ne dira-t-il pas
\tr
\tcr1 αὐτῷ \tc2 à lui : 
\tr
\tcr1 ἑτοίμασον \tc2 "Prépare 
\tr
\tcr1 τί δειπνήσω \tc2 de-quoi je-dînerai"
\tr
\tcr1 καὶ περιζωσάμενος διακόνει μοι \tc2 et t'étant-ceint-d'un-caleçon sers moi
\tr
\tcr1 ἕως φάγω καὶ πίω \tc2 jusqu'à-ce-que je-mange et je-bois,
\tr
\tcr1 καὶ μετὰ ταῦτα \tc2 et après ces \add choses\add*
\tr
\tcr1 σύ φάγεσαι καὶ πίεσαι \tc2 toi tu-mangeras et tu-boiras" ?
\m
\v 9
\tr
\tcr1 μὴ ἔχει \tc2 Est-ce-qu' il-a
\tr
\tcr1 χάριν \tc2 reconnaissance
\tr
\tcr1 τῷ δούλῳ \tc2 au serviteur,
\tr
\tcr1 ὅτι ἐποίησεν \tc2 parce-qu' il-a-fait
\tr
\tcr1 τὰ διαταχθέντα \tc2 les \add choses\add* étant-disposées ?
\m
\v 10
\tr
\tcr1 οὕτως ὑμεῖς καὶ \tc2 Ainsi vous aussi
\tr
\tcr1 ὅταν ποιήσητε \tc2 lorsque vous-faites
\tr
\tcr1 πάντα τὰ διαταχθέντα ὑμῖν \tc2 toutes les \add choses\add* étant-disposées à-vous,
\tr
\tcr1 λέγετε ὅτι \tc2 dites : 
\tr
\tcr1 ἐσμεν δοῦλοι ἀχρεῖοί \tc2 "Nous-sommes des-serviteurs inutiles,
\tr
\tcr1 πεποιήκαμεν \tc2 nous avons fait
\tr
\tcr1 ὃ ὠφείλομεν ποιῆσαι \tc2 \add ce\add* que nous-devions faire". »
\m
\v 11
\tr
\tcr1 καὶ ἐγένετο \tc2 Et il-est-advenu
\tr
\tcr1 ἐν τῷ πορεύεσθαι εἰς Ἰερουσαλὴμ \tc2 dans le aller à Jérusalem,
\tr
\tcr1 αὐτὸς καὶ διήρχετο \tc2 lui aussi traversait
\tr
\tcr1 διὰ μέσον \tc2 par \add le\add* milieu
\tr
\tcr1 Σαμαρείας καὶ Γαλιλαίας \tc2 de-\add la\add*-Samarie et de-\add la\add*-Galilée. 
\m
\v 12
\tr
\tcr1 καὶ αὐτοῦ εἰσερχομένου \tc2 Et lui entrant
\tr
\tcr1 εἰς τινα κώμην \tc2 dans quelque village,
\tr
\tcr1 δέκα ἄνδρες λεπροὶ \tc2 dix hommes lépreux
\tr
\tcr1 ἀπήντησαν \tc2 sont venus à sa rencontre,
\tr
\tcr1 οἳ ἔστησαν πόρρωθεν \tc2 qui se-sont-placés de-loin.
\m
\v 13
\tr
\tcr1 καὶ αὐτοὶ ἦραν φωνὴν λέγοντες \tc2 Et ils ont-levé \add la\add* voix disant : 
\tr
\tcr1 Ἰησοῦ Ἐπιστάτα \tc2 « Jésus, Maître, 
\tr
\tcr1 ἐλέησον ἡμᾶς \tc2 aie-pitié-de nous. »
\m
\v 14
\tr
\tcr1 καὶ ἰδὼν εἶπεν αὐτοῖς \tc2 Et ayant-vu il-a-dit à-eux : 
\tr
\tcr1 πορευθέντες ἐπιδείξατε ἑαυτοὺς \tc2 « \add Vous\add* en-allant montrez vous-mêmes
\tr
\tcr1 τοῖς ἱερεῦσιν \tc2 aux prêtres. »
\tr
\tcr1 καὶ ἐγένετο \tc2 Et il-est-advenu
\tr
\tcr1 ἐν τῷ αὐτοὺς ὑπάγειν \tc2 dans le eux partir,
\tr
\tcr1 ἐκαθαρίσθησαν \tc2 ils ont été purifiés. 
\m
\v 15-16
\tr
\tcr1 δὲ εἷς ἐξ αὐτῶν \tc2 Mais un d' eux
\tr
\tcr1 ἰδὼν ὅτι ἰάθη \tc2 ayant-vu que il-a-été-soigné, 
\tr
\tcr1 ὑπέστρεψεν δοξάζων τὸν Θεόν \tc2 il-est-retourné glorifiant Dieu
\tr
\tcr1 μετὰ μεγάλης φωνῆς \tc2 avec une-grande voix,
\tr
\tcr1 καὶ ἔπεσεν ἐπὶ πρόσωπον \tc2 et il-est-tombé sur \add la\add* face
\tr
\tcr1 παρὰ τοὺς πόδας αὐτοῦ \tc2 auprès des pieds de-lui,
\tr
\tcr1 εὐχαριστῶν αὐτῷ \tc2 rendant-grâce à-lui,
\tr
\tcr1 καὶ αὐτὸς ἦν Σαμαρείτης \tc2 et il était Samaritain. 
\m
\v 17
\tr
\tcr1 δὲ ἀποκριθεὶς ὁ Ἰησοῦς εἶπεν \tc2 Mais ayant-répondu Jésus a-dit : 
\tr
\tcr1 οἱ δέκα \tc2 « Les dix
\tr
\tcr1 οὐχὶ ἐκαθαρίσθησαν \tc2 n'ont-ils pas été purifiés ?
\tr
\tcr1 δὲ ποῦ \tc2 Mais où \add sont\add* 
\tr
\tcr1 οἱ ἐννέα \tc2 les neuf ?
\m
\v 18
\tr
\tcr1 οὐχ εὑρέθησαν \tc2 N'ont-ils pas été trouvés
\tr
\tcr1 ὑποστρέψαντες \tc2 s'en étant retournés
\tr
\tcr1 δοῦναι δόξαν τῷ Θεῷ \tc2 \add pour\add* donner gloire à Dieu
\tr
\tcr1 εἰ μὴ οὗτος ὁ ἀλλογενὴς \tc2 si non cet \add homme\add* d'une-autre-race ?
\m
\v 19
\tr
\tcr1 καὶ εἶπεν αὐτῷ \tc2 Et il-a-dit à-lui : 
\tr
\tcr1 ἀναστὰς πορεύου \tc2 « T'étant-levé, va, 
\tr
\tcr1 ἡ πίστις σου \tc2 la foi de-toi 
\tr
\tcr1 σέσωκέν σε \tc2 a-sauvé toi ! »
\m
\v 20-21
\tr
\tcr1 δὲ ἐπερωτηθεὶς \tc2 Mais ayant-été-interrogé
\tr
\tcr1 ὑπὸ τῶν Φαρισαίων \tc2 par les Pharisiens
\tr
\tcr1 πότε ἔρχεται ἡ Βασιλεία τοῦ Θεοῦ \tc2 quand vient le Royaume de Dieu,
\tr
\tcr1 ἀπεκρίθη αὐτοῖς καὶ εἶπεν \tc2 il-a-répondu à-eux et a-dit : 
\tr
\tcr1 ἡ Βασιλεία τοῦ Θεοῦ \tc2 « Le Royaume de Dieu
\tr
\tcr1 οὐκ ἔρχεται \tc2 ne vient pas
\tr
\tcr1 μετὰ παρατηρήσεως \tc2 avec \add l'\add* observation-des-astres,
\tr
\tcr1 οὐδὲ ἐροῦσιν \tc2 on ne dira pas : 
\tr
\tcr1 ἰδοὺ ὧδε ἤ ἐκεῖ \tc2 "Voici ici" ou "là",
\tr
\tcr1 γὰρ ἰδοὺ \tc2 car voici,
\tr
\tcr1 ἡ Βασιλεία τοῦ Θεοῦ \tc2 le Royaume de Dieu
\tr
\tcr1 ἐστιν ἐντὸς ὑμῶν \tc2 est à-l'intérieur de-vous. »
\m
\v 22
\tr
\tcr1 δὲ εἶπεν πρὸς τοὺς μαθητάς \tc2 Mais il-a-dit vers les disciples : 
\tr
\tcr1 ἡμέραι ἐλεύσονται ὅτε \tc2 « Des-jours viendront lorsque
\tr
\tcr1 ἐπιθυμήσετε ἰδεῖν \tc2 vous-désirerez voir
\tr
\tcr1 μίαν τῶν ἡμερῶν \tc2 un des jours 
\tr
\tcr1 τοῦ Υἱοῦ τοῦ Ἀνθρώπου \tc2 du Fils de-l' Homme,
\tr
\tcr1 καὶ \tc2 et
\tr
\tcr1 οὐκ ὄψεσθε \tc2 vous ne verrez pas.
\m
\v 23
\tr
\tcr1 καὶ ἐροῦσιν ὑμῖν \tc2 Et on-dira à-vous : 
\tr
\tcr1 ἰδοὺ ἐκεῖ \tc2 "Voici, là",
\tr
\tcr1 ἤ ἰδοὺ ὧδε \tc2 ou "Voici, ici",
\tr
\tcr1 μὴ ἀπέλθητε \tc2 ne partez pas
\tr
\tcr1 μηδὲ διώξητε \tc2 ni ne poursuivez.
\m
\v 24
\tr
\tcr1 γὰρ ὥσπερ ἡ ἀστραπὴ ἀστράπτουσα \tc2 Car tout-comme l' éclair foudroyant
\tr
\tcr1 ἐκ τῆς ὑπὸ τὸν οὐρανὸν \tc2 depuis la \add partie\add* sous le ciel
\tr
\tcr1 λάμπει \tc2 lance des éclairs
\tr
\tcr1 εἰς τὴν ὑπ’ οὐρανὸν \tc2 vers la \add partie\add* sous \add le\add* ciel,
\tr
\tcr1 οὕτως ἔσται ὁ Υἱὸς τοῦ Ἀνθρώπου \tc2 ainsi sera le Fils de-l' Homme. 
\m
\v 25
\tr
\tcr1 δὲ δεῖ πρῶτον \tc2 Mais il-faut premièrement
\tr
\tcr1 αὐτὸν παθεῖν πολλὰ \tc2 lui souffrir de-nombreuses \add choses\add*,
\tr
\tcr1 καὶ ἀποδοκιμασθῆναι \tc2 et être-rejeté
\tr
\tcr1 ἀπὸ ταύτης τῆς γενεᾶς \tc2 par cette génération. 
\m
\v 26-27
\tr
\tcr1 καὶ καθὼς ἐγένετο \tc2 Et tout-comme il-est-advenu
\tr
\tcr1 ἐν ταῖς ἡμέραις Νῶε \tc2 dans les jours de-Noé,
\tr
\tcr1 οὕτως καὶ ἔσται \tc2 ainsi aussi il-sera
\tr
\tcr1 ἐν ταῖς ἡμέραις \tc2 dans les jours 
