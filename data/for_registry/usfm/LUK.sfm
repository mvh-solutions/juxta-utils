\m
\v 16
\tr
\tcr1 ὁ νόμος καὶ οἱ προφῆται \tc2 La loi et les prophètes 
\tr
\tcr1 μέχρι Ἰωάννου \tc2 jusqu'à Jean,
\tr
\tcr1 ἀπὸ τότε ἡ Βασιλεία τοῦ Θεοῦ \tc2 dès lors le Royaume de Dieu
\tr
