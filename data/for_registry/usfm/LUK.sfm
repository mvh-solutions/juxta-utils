\tr
\tcr1 δοξαζόμενος \tc2 étant glorifié
\tr
\tcr1 ὑπὸ πάντων \tc2 par tous.
\m
\v 16
\tr
\tcr1 καὶ ἦλθεν \tc2 Et il-est-venu
\tr
\tcr1 εἰς Ναζαρά \tc2 à Nazareth,
\tr
\tcr1 οὗ ἦν τεθραμμένος \tc2 où il-avait-été élevé ;
\tr
\tcr1 καὶ εἰσῆλθεν \tc2 et il-est-entré
\tr
\tcr1 εἰς τὴν συναγωγήν \tc2 dans la synagogue
\tr
\tcr1 κατὰ τὸ εἰωθὸς αὐτῷ \tc2 selon la \add chose\add* accoutumée à-lui
\tr
\tcr1 ἐν τῇ ἡμέρᾳ τῶν Σαββάτων \tc2 dans le jour des Sabbats,
\tr
\tcr1 καὶ ἀνέστη ἀναγνῶναι \tc2 et il-s'est-levé \add pour\add* lire.
\m
\v 17-19
\tr
\tcr1 καὶ βιβλίον τοῦ προφήτου Ἠσαΐου \tc2 Et le-livre du prophète Ésaïe
\tr
\tcr1 ἐπεδόθη αὐτῷ \tc2 a-été-donné à-lui,
\tr
\tcr1 καὶ ἀναπτύξας τὸ βιβλίον \tc2 et ayant-déroulé le livre
\tr
\tcr1 εὗρεν τὸν τόπον \tc2 il-a-trouvé le passage
\tr
\tcr1 οὗ ἦν γεγραμμένον \tc2 où il-avait-été écrit :
\tr
\tcr1 Πνεῦμα Κυρίου \tc2 « L'Esprit du-Seigneur
\tr
\tcr1 ἐπ’ ἐμέ \tc2 \add est\add* sur moi,
\tr
\tcr1 εἵνεκεν οὗ \tc2 à-cause de-quoi
\tr
\tcr1 ἔχρισέν με \tc2 il-a-oint moi
\tr
\tcr1 εὐαγγελίσασθαι \tc2 \add pour\add* annoncer-une-bonne-nouvelle 
\tr
\tcr1 πτωχοῖς \tc2 aux-pauvres :
\tr
\tcr1 ἀπέσταλκέν με \tc2 il-a-envoyé moi
\tr
\tcr1 κηρύξαι ἄφεσιν \tc2 \add pour\add* proclamer la-délivrance
\tr
\tcr1 αἰχμαλώτοις \tc2 aux prisonniers,
\tr
\tcr1 καὶ ἀνάβλεψιν \tc2 et le-recouvrement-de-la-vue
\tr
\tcr1 τυφλοῖς \tc2 aux aveugles,
\tr
\tcr1 ἀποστεῖλαι \tc2 \add pour\add* envoyer
\tr
\tcr1 ἐν ἀφέσει \tc2 en délivrance
\tr
\tcr1 τεθραυσμένους \tc2 \add les gens\add* ayant-été-blessés,
\tr
\tcr1 κηρύξαι \tc2 \add pour\add* proclamer
\tr
\tcr1 ἐνιαυτὸν δεκτόν Κυρίου \tc2 l'année favorable du-Seigneur. »
\m
\v 20
\tr
\tcr1 καὶ πτύξας τὸ βιβλίον \tc2 Et ayant-enroulé le livre
\tr
\tcr1 ἀποδοὺς τῷ ὑπηρέτῃ \tc2 \add l'\add* ayant-rendu au serviteur,
\tr
\tcr1 ἐκάθισεν καὶ \tc2 il-s'est-assis et
\tr
\tcr1 οἱ ὀφθαλμοὶ πάντων \tc2 les yeux de-tous
\tr
\tcr1 ἐν τῇ συναγωγῇ \tc2 dans la synagogue
\tr
\tcr1 ἦσαν ἀτενίζοντες αὐτῷ \tc2 étaient étant-fixés sur-lui.
\m
\v 21
\tr
\tcr1 δὲ ἤρξατο \tc2 Et il-a-commencé
\tr
\tcr1 λέγειν πρὸς αὐτοὺς ὅτι \tc2 à-dire à eux que :
\tr
\tcr1 σήμερον \tc2 « Aujourd'hui
\tr
\tcr1 αὕτη ἡ Γραφὴ \tc2 cette Écriture
\tr
\tcr1 πεπλήρωται \tc2 a été accomplie
\tr
\tcr1 ἐν τοῖς ὠσὶν ὑμῶν \tc2 dans les oreilles de-vous. »
\m
\v 22
\tr
\tcr1 καὶ πάντες \tc2 Et tous
\tr
\tcr1 ἐμαρτύρουν αὐτῷ \tc2 rendaient-témoignage à-lui,
\tr
\tcr1 καὶ ἐθαύμαζον \tc2 et s'étonnaient
\tr
\tcr1 ἐπὶ τοῖς λόγοις τῆς χάριτος \tc2 à-propos des paroles de-la grâce
\tr
\tcr1 τοῖς ἐκπορευομένοις \tc2 celles sortant
\tr
\tcr1 ἐκ τοῦ στόματος αὐτοῦ \tc2 de la bouche de-lui ;
\tr
\tcr1 καὶ ἔλεγον \tc2 et ils-disaient :
\tr
\tcr1 οὗτος \tc2 « Celui-ci
\tr
\tcr1 οὐχὶ ἐστιν \tc2 n'est-il pas
\tr
\tcr1 υἱός Ἰωσὴφ \tc2 \add le\add* fils de-Joseph ? »
\m
\v 23
\tr
\tcr1 καὶ εἶπεν πρὸς αὐτούς \tc2 Et il-a-dit à eux :
\tr
\tcr1 πάντως \tc2 « Dans tous les cas
\tr
\tcr1 ἐρεῖτέ μοι \tc2 vous-direz à-moi
\tr
\tcr1 ταύτην τὴν παραβολὴν \tc2 cette parabole :
\tr
\tcr1 ἰατρέ \tc2 "Médecin,
\tr
\tcr1 θεράπευσον σεαυτόν \tc2 guéris toi-même",
\tr
\tcr1 ποίησον καὶ ὧδε \tc2 fais aussi ici
\tr
\tcr1 ἐν τῇ πατρίδι σου \tc2 dans la patrie de-toi
\tr
\tcr1 ὅσα ἠκούσαμεν \tc2 les-choses-que nous-avons-entendues
\tr
\tcr1 γενόμενα \tc2 ayant eu lieu
\tr
\tcr1 εἰς τὴν Καφαρναοὺμ \tc2 à Capharnaüm. »
\m
\v 24
\tr
\tcr1 δέ εἶπεν \tc2 Et il-a-dit :
\tr
\tcr1 ἀμὴν \tc2 « Amen,
\tr
\tcr1 λέγω ὑμῖν \tc2 je-dis à-vous,
\tr
\tcr1 ὅτι οὐδεὶς προφήτης \tc2 qu' aucun prophète
\tr
\tcr1 ἐστιν δεκτός \tc2 n'est accepté
\tr
\tcr1 ἐν τῇ πατρίδι αὐτοῦ \tc2 dans la patrie de-lui.
\m
\v 25-26
\tr
\tcr1 δὲ λέγω ὑμῖν \tc2 Et je-dis à-vous
\tr
\tcr1 ἐπ’ ἀληθείας \tc2 en vérité :
\tr
\tcr1 πολλαὶ χῆραι \tc2 "De-nombreuses veuves
\tr
\tcr1 ἦσαν ἐν τῷ Ἰσραήλ \tc2 étaient en Israël
\tr
\tcr1 ἐν ταῖς ἡμέραις Ἠλείου \tc2 dans les jours d'Élie,
\tr
\tcr1 ὅτε ὁ οὐρανὸς ἐκλείσθη \tc2 quand le ciel a-été-fermé
\tr
