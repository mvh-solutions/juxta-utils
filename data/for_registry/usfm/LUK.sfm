\tr
\tcr1 καὶ αὐτοὶ \tc2 et vous-mêmes
\tr
\tcr1 οὐ προσψαύετε \tc2 vous ne touchez pas
\tr
\tcr1 ἑνὶ τῶν δακτύλων ὑμῶν \tc2 par-un des doigts de-vous
\tr
\tcr1 τοῖς φορτίοις \tc2 aux fardeaux. 
\m
\v 47
\tr
\tcr1 οὐαὶ ὑμῖν ὅτι \tc2 Malheur à-vous parce-que
\tr
\tcr1 οἰκοδομεῖτε \tc2 vous-construisez 
\tr
\tcr1 τὰ μνημεῖα τῶν προφητῶν \tc2 les tombeaux des prophètes,
\tr
\tcr1 δὲ οἱ πατέρες ὑμῶν \tc2 mais les pères de-vous
\tr
\tcr1 ἀπέκτειναν αὐτούς \tc2 ont-tué eux. 
\m
\v 48
\tr
\tcr1 ἄρα μαρτυρεῖτε \tc2 Ainsi vous-êtes-témoins 
\tr
\tcr1 καὶ συνευδοκεῖτε \tc2 et vous-approuvez
\tr
\tcr1 τοῖς ἔργοις τῶν πατέρων ὑμῶν \tc2 les œuvres des pères de-vous,
\tr
